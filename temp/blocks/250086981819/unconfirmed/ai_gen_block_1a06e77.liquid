{% doc %}
  @prompt
    Create a slim editorial advertorial story strip section designed to sit directly above the main hero section on the homepage. It should feel premium and editorial — inspired by Aesop and Apple's design language.
    
    The section should include:
    - A small eyebrow label (e.g. "A customer story") in all-caps, spaced tracking, muted tone
    - A large pull-quote style headline in 2–3 lines, warm serif or elegant sans-serif font
    - A short 2–3 sentence narrative paragraph below the headline (the story of a wife whose husband had cracked dry feet for 3 years, tried the goat milk foot mask, and woke up with soft heels)
    - A subtle before/after image pair side by side (small, tasteful — not clinical)
    - Clean minimal layout, full-width, warm cream background (#f5f0e8)
    - No heavy borders or boxes — open, airy, editorial feel
    - Mobile responsive
    - All content should be editable via theme editor blocks (eyebrow, headline, paragraph text, before image, after image, before label, after label)
    - Smooth fade-in animation on scroll for a premium feel, I want you to retouch this section. Make the typography dominant. FOr the before and after I dont want that. I want you to rework it into 3 individual cards marked by 1 session 2 session and 3 session. MAke sure it is mobile friendly
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-strip-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .ai-editorial-strip-{{ ai_gen_id }}.ai-editorial-strip-visible-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-editorial-strip__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-editorial-strip__eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    letter-spacing: {{ block.settings.eyebrow_tracking }};
    text-transform: uppercase;
    color: {{ block.settings.eyebrow_color }};
    font-weight: 500;
    margin: 0;
  }

  .ai-editorial-strip__headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    line-height: {{ block.settings.headline_line_height }};
    color: {{ block.settings.headline_color }};
    font-weight: {{ block.settings.headline_weight }};
    margin: 0;
    max-width: {{ block.settings.headline_max_width }}px;
  }

  .ai-editorial-strip__paragraph-{{ ai_gen_id }} {
    font-size: {{ block.settings.paragraph_size }}px;
    line-height: {{ block.settings.paragraph_line_height }};
    color: {{ block.settings.paragraph_color }};
    margin: 0;
    max-width: {{ block.settings.paragraph_max_width }}px;
  }

  .ai-editorial-strip__cards-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
    width: 100%;
    margin-top: {{ block.settings.cards_margin_top }}px;
  }

  .ai-editorial-strip__card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ block.settings.card_content_gap }}px;
  }

  .ai-editorial-strip__card-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_number_size }}px;
    font-weight: {{ block.settings.card_number_weight }};
    color: {{ block.settings.card_number_color }};
    line-height: 1;
    margin: 0;
  }

  .ai-editorial-strip__card-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_label_size }}px;
    letter-spacing: {{ block.settings.card_label_tracking }};
    text-transform: uppercase;
    color: {{ block.settings.card_label_color }};
    font-weight: 500;
    margin: 0;
  }

  .ai-editorial-strip__card-image-container-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.card_image_aspect_ratio }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    position: relative;
  }

  .ai-editorial-strip__card-image-container-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-strip__card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e6d5b8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-editorial-strip__card-image-placeholder-{{ ai_gen_id }} svg {
    width: 40%;
    height: 40%;
    opacity: 0.3;
  }

  @media screen and (max-width: 989px) {
    .ai-editorial-strip__cards-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_gap | times: 1.5 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-strip-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.6 }}px 16px {{ block.settings.padding_bottom | times: 0.6 }}px;
    }

    .ai-editorial-strip__eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_size | times: 0.9 }}px;
    }

    .ai-editorial-strip__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.5 }}px;
    }

    .ai-editorial-strip__paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.paragraph_size | times: 0.9 }}px;
    }

    .ai-editorial-strip__card-number-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_number_size | times: 0.7 }}px;
    }

    .ai-editorial-strip__card-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_label_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<ai-editorial-strip-{{ ai_gen_id }}
  class="ai-editorial-strip-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-editorial-strip__container-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank %}
      <p class="ai-editorial-strip__eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</p>
    {% endif %}

    {% if block.settings.headline != blank %}
      <h2 class="ai-editorial-strip__headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}

    {% if block.settings.paragraph != blank %}
      <div class="ai-editorial-strip__paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph }}</div>
    {% endif %}

    <div class="ai-editorial-strip__cards-{{ ai_gen_id }}">
      <div class="ai-editorial-strip__card-{{ ai_gen_id }}">
        <p class="ai-editorial-strip__card-number-{{ ai_gen_id }}">{{ block.settings.card_1_number }}</p>
        {% if block.settings.card_1_label != blank %}
          <p class="ai-editorial-strip__card-label-{{ ai_gen_id }}">{{ block.settings.card_1_label }}</p>
        {% endif %}
        <div class="ai-editorial-strip__card-image-container-{{ ai_gen_id }}">
          {% if block.settings.card_1_image %}
            <img
              src="{{ block.settings.card_1_image | image_url: width: 600 }}"
              alt="{{ block.settings.card_1_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.card_1_image.width }}"
              height="{{ block.settings.card_1_image.height }}"
            >
          {% else %}
            <div class="ai-editorial-strip__card-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-editorial-strip__card-{{ ai_gen_id }}">
        <p class="ai-editorial-strip__card-number-{{ ai_gen_id }}">{{ block.settings.card_2_number }}</p>
        {% if block.settings.card_2_label != blank %}
          <p class="ai-editorial-strip__card-label-{{ ai_gen_id }}">{{ block.settings.card_2_label }}</p>
        {% endif %}
        <div class="ai-editorial-strip__card-image-container-{{ ai_gen_id }}">
          {% if block.settings.card_2_image %}
            <img
              src="{{ block.settings.card_2_image | image_url: width: 600 }}"
              alt="{{ block.settings.card_2_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.card_2_image.width }}"
              height="{{ block.settings.card_2_image.height }}"
            >
          {% else %}
            <div class="ai-editorial-strip__card-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-editorial-strip__card-{{ ai_gen_id }}">
        <p class="ai-editorial-strip__card-number-{{ ai_gen_id }}">{{ block.settings.card_3_number }}</p>
        {% if block.settings.card_3_label != blank %}
          <p class="ai-editorial-strip__card-label-{{ ai_gen_id }}">{{ block.settings.card_3_label }}</p>
        {% endif %}
        <div class="ai-editorial-strip__card-image-container-{{ ai_gen_id }}">
          {% if block.settings.card_3_image %}
            <img
              src="{{ block.settings.card_3_image | image_url: width: 600 }}"
              alt="{{ block.settings.card_3_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.card_3_image.width }}"
              height="{{ block.settings.card_3_image.height }}"
            >
          {% else %}
            <div class="ai-editorial-strip__card-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</ai-editorial-strip-{{ ai_gen_id }}>

<script>
  (function() {
    class AiEditorialStrip{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.observer = null;
      }

      connectedCallback() {
        this.setupIntersectionObserver();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('ai-editorial-strip-visible-{{ ai_gen_id }}');
              this.observer.unobserve(entry.target);
            }
          });
        }, options);

        this.observer.observe(this);
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('ai-editorial-strip-{{ ai_gen_id }}', AiEditorialStrip{{ ai_gen_id }});
  })();
</script>

