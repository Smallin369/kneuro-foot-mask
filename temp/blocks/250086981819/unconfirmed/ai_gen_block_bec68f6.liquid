{% doc %}
  @prompt
    Create a premium 4-tile benefits section for a skincare brand homepage. Design inspired by Apple and Aesop — clean, editorial, trustworthy.
    
    Layout & Design:
    - 4 cards in a 2x2 grid on desktop, single column on mobile
    - Each card has a subtle background: alternating between warm cream (#f5f0e8) and deep maroon/plum (#3d2535) for visual contrast and premium feel
    - Cards with maroon background use light cream text (#fbf3e3); cream cards use dark ink text (#2a1c12)
    - Rounded corners (12px border radius) with no heavy drop shadows — just a very subtle 1px border on cream cards
    - Icon at top of each card in a small circle accent — amber (#e8833a) on cream cards, cream on maroon cards
    - Bold card title, smaller body text below
    - Section has a warm cream background (#f5f0e8)
    - Eyebrow label above: "WHAT YOU GET" in small all-caps spaced tracking
    - Section heading: "What this actually does"
    - Section subheading: "A 30-minute mask. No harsh acids. Soft skin without the 5-day peeling phase."
    
    4 tiles content:
    1. Icon: clock — Title: "Soft skin in 30 minutes" — Body: "One short session. No 5-day peeling phase to hide through."
    2. Icon: leaf — Title: "No harsh acids" — Body: "Goat milk + niacinamide. No salicylic, no glycolic, no burning."
    3. Icon: shield — Title: "Pregnancy-safe" — Body: "Gentle enough for pregnant skin, diabetics, sensitive feet."
    4. Icon: refresh/check — Title: "30-day money-back" — Body: "If your heels aren't softer, full refund. No questions."
    
    All text and colors fully editable via theme editor. Fully responsive.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-benefits-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.section_background }};
    padding: 80px 20px;
  }

  .ai-benefits-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-benefits-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 60px;
  }

  .ai-benefits-eyebrow-{{ ai_gen_id }} {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: {{ block.settings.eyebrow_color }};
    margin-bottom: 16px;
    font-weight: 600;
  }

  .ai-benefits-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-benefits-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    line-height: 1.6;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-benefits-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .ai-benefits-card-{{ ai_gen_id }} {
    padding: 40px 32px;
    border-radius: {{ block.settings.card_border_radius }}px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-benefits-card-{{ ai_gen_id }}--cream {
    background-color: {{ block.settings.cream_background }};
    border: 1px solid {{ block.settings.cream_border }};
  }

  .ai-benefits-card-{{ ai_gen_id }}--maroon {
    background-color: {{ block.settings.maroon_background }};
  }

  .ai-benefits-icon-wrapper-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-benefits-card-{{ ai_gen_id }}--cream .ai-benefits-icon-wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.amber_accent }};
  }

  .ai-benefits-card-{{ ai_gen_id }}--maroon .ai-benefits-icon-wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.cream_accent }};
  }

  .ai-benefits-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
  }

  .ai-benefits-card-{{ ai_gen_id }}--cream .ai-benefits-icon-{{ ai_gen_id }} {
    color: {{ block.settings.cream_background }};
  }

  .ai-benefits-card-{{ ai_gen_id }}--maroon .ai-benefits-icon-{{ ai_gen_id }} {
    color: {{ block.settings.maroon_background }};
  }

  .ai-benefits-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }

  .ai-benefits-card-{{ ai_gen_id }}--cream .ai-benefits-card-title-{{ ai_gen_id }} {
    color: {{ block.settings.dark_text }};
  }

  .ai-benefits-card-{{ ai_gen_id }}--maroon .ai-benefits-card-title-{{ ai_gen_id }} {
    color: {{ block.settings.light_text }};
  }

  .ai-benefits-card-body-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_body_size }}px;
    margin: 0;
    line-height: 1.6;
  }

  .ai-benefits-card-{{ ai_gen_id }}--cream .ai-benefits-card-body-{{ ai_gen_id }} {
    color: {{ block.settings.dark_text }};
    opacity: 0.8;
  }

  .ai-benefits-card-{{ ai_gen_id }}--maroon .ai-benefits-card-body-{{ ai_gen_id }} {
    color: {{ block.settings.light_text }};
    opacity: 0.9;
  }

  @media screen and (max-width: 749px) {
    .ai-benefits-section-{{ ai_gen_id }} {
      padding: 60px 20px;
    }

    .ai-benefits-header-{{ ai_gen_id }} {
      margin-bottom: 40px;
    }

    .ai-benefits-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .ai-benefits-card-{{ ai_gen_id }} {
      padding: 32px 24px;
    }

    .ai-benefits-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-benefits-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<benefits-section-{{ ai_gen_id }} class="ai-benefits-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-benefits-container-{{ ai_gen_id }}">
    <div class="ai-benefits-header-{{ ai_gen_id }}">
      {% if block.settings.eyebrow != blank %}
        <div class="ai-benefits-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</div>
      {% endif %}
      {% if block.settings.heading != blank %}
        <h2 class="ai-benefits-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-benefits-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="ai-benefits-grid-{{ ai_gen_id }}">
      <div class="ai-benefits-card-{{ ai_gen_id }} ai-benefits-card-{{ ai_gen_id }}--cream">
        <div class="ai-benefits-icon-wrapper-{{ ai_gen_id }}">
          <svg class="ai-benefits-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </div>
        <h3 class="ai-benefits-card-title-{{ ai_gen_id }}">{{ block.settings.card_1_title }}</h3>
        <p class="ai-benefits-card-body-{{ ai_gen_id }}">{{ block.settings.card_1_body }}</p>
      </div>

      <div class="ai-benefits-card-{{ ai_gen_id }} ai-benefits-card-{{ ai_gen_id }}--maroon">
        <div class="ai-benefits-icon-wrapper-{{ ai_gen_id }}">
          <svg class="ai-benefits-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"></path>
            <path d="M7 12c0-1.66 1.34-3 3-3s3 1.34 3 3-1.34 3-3 3-3-1.34-3-3zm10 0c0 1.66-1.34 3-3 3V9c1.66 0 3 1.34 3 3z"></path>
          </svg>
        </div>
        <h3 class="ai-benefits-card-title-{{ ai_gen_id }}">{{ block.settings.card_2_title }}</h3>
        <p class="ai-benefits-card-body-{{ ai_gen_id }}">{{ block.settings.card_2_body }}</p>
      </div>

      <div class="ai-benefits-card-{{ ai_gen_id }} ai-benefits-card-{{ ai_gen_id }}--maroon">
        <div class="ai-benefits-icon-wrapper-{{ ai_gen_id }}">
          <svg class="ai-benefits-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
        </div>
        <h3 class="ai-benefits-card-title-{{ ai_gen_id }}">{{ block.settings.card_3_title }}</h3>
        <p class="ai-benefits-card-body-{{ ai_gen_id }}">{{ block.settings.card_3_body }}</p>
      </div>

      <div class="ai-benefits-card-{{ ai_gen_id }} ai-benefits-card-{{ ai_gen_id }}--cream">
        <div class="ai-benefits-icon-wrapper-{{ ai_gen_id }}">
          <svg class="ai-benefits-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <polyline points="23 4 23 10 17 10"></polyline>
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
            <polyline points="9 11 12 14 22 4"></polyline>
          </svg>
        </div>
        <h3 class="ai-benefits-card-title-{{ ai_gen_id }}">{{ block.settings.card_4_title }}</h3>
        <p class="ai-benefits-card-body-{{ ai_gen_id }}">{{ block.settings.card_4_body }}</p>
      </div>
    </div>
  </div>
</benefits-section-{{ ai_gen_id }}>

<script>
  (function() {
    class BenefitsSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('benefits-section-{{ ai_gen_id }}', BenefitsSection{{ ai_gen_id }});
  })();
</script>

