{% doc %}
  @prompt
    Add a subtle outline/border to each bundle card. When a bundle card is selected or clicked, the outline becomes thicker to indicate the active/selected state. The default state should have a thin border, and the selected state should have a noticeably thicker border, using the same border color or a highlighted accent color., Looks really boring it needs to have a little more character. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bundle-cards-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 20px;
  }

  .ai-bundle-cards__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .ai-bundle-card-{{ ai_gen_id }} {
    background: linear-gradient(135deg, {{ block.settings.card_background }} 0%, {{ block.settings.card_background_gradient }} 100%);
    border: {{ block.settings.border_width_default }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: 28px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .ai-bundle-card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: linear-gradient(135deg, {{ block.settings.border_color_selected }}, {{ block.settings.border_color_hover }});
    border-radius: {{ block.settings.border_radius }}px;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: -1;
  }

  .ai-bundle-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .ai-bundle-card-{{ ai_gen_id }}.selected {
    border-width: {{ block.settings.border_width_selected }}px;
    border-color: {{ block.settings.border_color_selected }};
    transform: translateY(-6px);
    box-shadow: 0 12px 32px rgba(232, 131, 58, 0.2);
  }

  .ai-bundle-card-{{ ai_gen_id }}.selected::before {
    opacity: 0.1;
  }

  .ai-bundle-card__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    right: 16px;
    background: linear-gradient(135deg, {{ block.settings.badge_background }} 0%, {{ block.settings.badge_background_gradient }} 100%);
    color: {{ block.settings.badge_text_color }};
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .ai-bundle-card__icon-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, {{ block.settings.icon_background }} 0%, {{ block.settings.icon_background_gradient }} 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    color: {{ block.settings.icon_color }};
  }

  .ai-bundle-card__icon-{{ ai_gen_id }} svg {
    width: 28px;
    height: 28px;
  }

  .ai-bundle-card__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px 0;
    letter-spacing: -0.5px;
  }

  .ai-bundle-card__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color_secondary }};
    margin: 0 0 20px 0;
    line-height: 1.6;
  }

  .ai-bundle-card__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 12px;
  }

  .ai-bundle-card__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 800;
    color: {{ block.settings.text_color }};
    letter-spacing: -1px;
  }

  .ai-bundle-card__compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_size }}px;
    color: {{ block.settings.text_color_secondary }};
    text-decoration: line-through;
    opacity: 0.7;
  }

  .ai-bundle-card__savings-{{ ai_gen_id }} {
    display: inline-block;
    font-size: 13px;
    color: {{ block.settings.savings_color }};
    font-weight: 700;
    background-color: {{ block.settings.savings_background }};
    padding: 4px 10px;
    border-radius: 6px;
    margin-bottom: 16px;
  }

  .ai-bundle-card__divider-{{ ai_gen_id }} {
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, {{ block.settings.border_color }} 50%, transparent 100%);
    margin: 20px 0;
  }

  .ai-bundle-card__features-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-bundle-card__feature-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: {{ block.settings.text_color_secondary }};
    margin-bottom: 10px;
    padding-left: 4px;
  }

  .ai-bundle-card__feature-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-bundle-card__checkmark-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    background-color: {{ block.settings.checkmark_background }};
    color: {{ block.settings.checkmark_color }};
    border-radius: 50%;
    padding: 3px;
  }

  .ai-bundle-card__select-indicator-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    left: 16px;
    width: 24px;
    height: 24px;
    border: 2px solid {{ block.settings.border_color }};
    border-radius: 50%;
    transition: all 0.3s ease;
    background-color: white;
  }

  .ai-bundle-card-{{ ai_gen_id }}.selected .ai-bundle-card__select-indicator-{{ ai_gen_id }} {
    background-color: {{ block.settings.border_color_selected }};
    border-color: {{ block.settings.border_color_selected }};
  }

  .ai-bundle-card__select-indicator-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    width: 10px;
    height: 10px;
    background-color: white;
    border-radius: 50%;
    transition: transform 0.2s ease;
  }

  .ai-bundle-card-{{ ai_gen_id }}.selected .ai-bundle-card__select-indicator-{{ ai_gen_id }}::after {
    transform: translate(-50%, -50%) scale(1);
  }

  @media screen and (max-width: 749px) {
    .ai-bundle-cards__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<bundle-cards-{{ ai_gen_id }}
  class="ai-bundle-cards-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-bundle-cards__container-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign enabled_key = 'bundle_' | append: i | append: '_enabled'
        assign title_key = 'bundle_' | append: i | append: '_title'
        assign description_key = 'bundle_' | append: i | append: '_description'
        assign price_key = 'bundle_' | append: i | append: '_price'
        assign compare_price_key = 'bundle_' | append: i | append: '_compare_price'
        assign badge_key = 'bundle_' | append: i | append: '_badge'
        assign feature_1_key = 'bundle_' | append: i | append: '_feature_1'
        assign feature_2_key = 'bundle_' | append: i | append: '_feature_2'
        assign feature_3_key = 'bundle_' | append: i | append: '_feature_3'

        assign enabled = block.settings[enabled_key]
        assign title = block.settings[title_key]
        assign description = block.settings[description_key]
        assign price = block.settings[price_key]
        assign compare_price = block.settings[compare_price_key]
        assign badge = block.settings[badge_key]
        assign feature_1 = block.settings[feature_1_key]
        assign feature_2 = block.settings[feature_2_key]
        assign feature_3 = block.settings[feature_3_key]
      %}

      {% if enabled %}
        <div
          class="ai-bundle-card-{{ ai_gen_id }} {% if i == block.settings.default_selected %}selected{% endif %}"
          data-bundle-id="{{ i }}"
        >
          <div class="ai-bundle-card__select-indicator-{{ ai_gen_id }}"></div>

          {% if badge != blank %}
            <div class="ai-bundle-card__badge-{{ ai_gen_id }}">{{ badge }}</div>
          {% endif %}

          <div class="ai-bundle-card__icon-{{ ai_gen_id }}">
            {% if i == 1 %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
              </svg>
            {% elsif i == 2 %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
              </svg>
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
            {% endif %}
          </div>

          {% if title != blank %}
            <h3 class="ai-bundle-card__title-{{ ai_gen_id }}">{{ title }}</h3>
          {% endif %}

          {% if description != blank %}
            <p class="ai-bundle-card__description-{{ ai_gen_id }}">{{ description }}</p>
          {% endif %}

          <div class="ai-bundle-card__price-wrapper-{{ ai_gen_id }}">
            {% if price != blank %}
              <div class="ai-bundle-card__price-{{ ai_gen_id }}">{{ price }}</div>
            {% endif %}
            {% if compare_price != blank %}
              <div class="ai-bundle-card__compare-price-{{ ai_gen_id }}">{{ compare_price }}</div>
            {% endif %}
          </div>

          {% if price != blank and compare_price != blank %}
            <div class="ai-bundle-card__savings-{{ ai_gen_id }}">
              {{ block.settings.savings_text }}
            </div>
          {% endif %}

          <div class="ai-bundle-card__divider-{{ ai_gen_id }}"></div>

          {% if feature_1 != blank or feature_2 != blank or feature_3 != blank %}
            <ul class="ai-bundle-card__features-{{ ai_gen_id }}">
              {% if feature_1 != blank %}
                <li class="ai-bundle-card__feature-{{ ai_gen_id }}">
                  <svg
                    class="ai-bundle-card__checkmark-{{ ai_gen_id }}"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  {{ feature_1 }}
                </li>
              {% endif %}
              {% if feature_2 != blank %}
                <li class="ai-bundle-card__feature-{{ ai_gen_id }}">
                  <svg
                    class="ai-bundle-card__checkmark-{{ ai_gen_id }}"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  {{ feature_2 }}
                </li>
              {% endif %}
              {% if feature_3 != blank %}
                <li class="ai-bundle-card__feature-{{ ai_gen_id }}">
                  <svg
                    class="ai-bundle-card__checkmark-{{ ai_gen_id }}"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  {{ feature_3 }}
                </li>
              {% endif %}
            </ul>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</bundle-cards-{{ ai_gen_id }}>

<script>
  (function() {
    class BundleCards{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-bundle-card-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.cards.forEach((card) => {
          card.addEventListener('click', () => {
            this.cards.forEach((c) => c.classList.remove('selected'));
            card.classList.add('selected');
          });
        });
      }
    }

    customElements.define('bundle-cards-{{ ai_gen_id }}', BundleCards{{ ai_gen_id }});
  })();
</script>

