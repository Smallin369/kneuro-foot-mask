{% doc %}
  @prompt
    Create a complete long-form advertorial story section as ONE block with fully editable schema settings. Cream background (#F5F0EA). SCHEMA SETTINGS: Headline (default: "He hid his feet from me for three years."), Star rating (default: "4.8"), Review count (default: "1,400+"), Customer name (default: "SARAH K."), Customer location (default: "PHOENIX, AZ"), Body paragraphs 1-4 (each editable), Bold keyword (default: "goat-milk lactic acid"), Narrative text 1 (default: "The next morning he stopped in the kitchen and rubbed one foot against the other."), Pull quote (default: "Wait. Something's different."), Pull quote attribution (default: "— HIM, BEFORE COFFEE"), Progress image (image picker), Narrative text 2 (default: "Three weeks in, he walked out to get the mail. Barefoot. On the driveway."). LAYOUT: 1.Headline 2.Star rating row 3.Body paragraphs with bold keyword 4.Narrative text 1 5.Pull quote left border 3px solid black italic 6.Full-width progress image 7.Narrative text 2. CRITICAL IMAGE: width:100%; display:block; height:auto; NO side margins NO padding NO max-width on image container, bleeds fully edge to edge. DESIGN: cream #F5F0EA, headline 36px bold serif, body 16px sans-serif dark gray 1.7 line-height, narratives 28px bold serif, fully responsive.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-advertorial-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    padding: 60px 20px;
    width: 100%;
  }

  .ai-advertorial-container-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-advertorial-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 700;
    font-family: Georgia, serif;
    color: {{ block.settings.text_color }};
    margin: 0 0 24px;
    line-height: 1.2;
  }

  .ai-advertorial-rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  .ai-advertorial-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
  }

  .ai-advertorial-star-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    fill: {{ block.settings.star_color }};
  }

  .ai-advertorial-rating-text-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-advertorial-review-count-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.muted_color }};
    margin-bottom: 24px;
  }

  .ai-advertorial-customer-{{ ai_gen_id }} {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: {{ block.settings.text_color }};
    margin-bottom: 32px;
  }

  .ai-advertorial-body-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: {{ block.settings.body_color }};
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .ai-advertorial-bold-{{ ai_gen_id }} {
    font-weight: 700;
  }

  .ai-advertorial-narrative-{{ ai_gen_id }} {
    font-size: {{ block.settings.narrative_size }}px;
    font-weight: 700;
    font-family: Georgia, serif;
    color: {{ block.settings.text_color }};
    line-height: 1.3;
    margin: 40px 0;
  }

  .ai-advertorial-quote-{{ ai_gen_id }} {
    border-left: 3px solid {{ block.settings.text_color }};
    padding-left: 24px;
    margin: 40px 0;
  }

  .ai-advertorial-quote-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.narrative_size }}px;
    font-style: italic;
    font-family: Georgia, serif;
    color: {{ block.settings.text_color }};
    line-height: 1.3;
    margin: 0 0 8px;
  }

  .ai-advertorial-quote-attribution-{{ ai_gen_id }} {
    font-size: 14px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: {{ block.settings.muted_color }};
    font-style: normal;
  }

  .ai-advertorial-image-container-{{ ai_gen_id }} {
    width: 100%;
    margin: 40px 0;
    padding: 0;
  }

  .ai-advertorial-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-advertorial-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #e5e5e5;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 400px;
    position: relative;
  }

  .ai-advertorial-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-advertorial-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-advertorial-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-advertorial-headline-{{ ai_gen_id }} {
      font-size: 28px;
    }

    .ai-advertorial-narrative-{{ ai_gen_id }} {
      font-size: 22px;
    }

    .ai-advertorial-quote-text-{{ ai_gen_id }} {
      font-size: 22px;
    }

    .ai-advertorial-body-{{ ai_gen_id }} {
      font-size: 15px;
    }
  }
{% endstyle %}

<div class="ai-advertorial-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-advertorial-container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h2 class="ai-advertorial-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}

    <div class="ai-advertorial-rating-{{ ai_gen_id }}">
      <div class="ai-advertorial-stars-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          <svg class="ai-advertorial-star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        {% endfor %}
      </div>
      {% if block.settings.star_rating != blank %}
        <span class="ai-advertorial-rating-text-{{ ai_gen_id }}">{{ block.settings.star_rating }}</span>
      {% endif %}
    </div>

    {% if block.settings.review_count != blank %}
      <div class="ai-advertorial-review-count-{{ ai_gen_id }}">{{ block.settings.review_count }} reviews</div>
    {% endif %}

    {% if block.settings.customer_name != blank or block.settings.customer_location != blank %}
      <div class="ai-advertorial-customer-{{ ai_gen_id }}">
        {{ block.settings.customer_name }}{% if block.settings.customer_name != blank and block.settings.customer_location != blank %}, {% endif %}{{ block.settings.customer_location }}
      </div>
    {% endif %}

    {% if block.settings.body_paragraph_1 != blank %}
      <div class="ai-advertorial-body-{{ ai_gen_id }}">
        {{ block.settings.body_paragraph_1 }}
      </div>
    {% endif %}

    {% if block.settings.body_paragraph_2 != blank %}
      <div class="ai-advertorial-body-{{ ai_gen_id }}">
        {% assign paragraph_2 = block.settings.body_paragraph_2 %}
        {% if block.settings.bold_keyword != blank %}
          {% assign keyword = block.settings.bold_keyword %}
          {% assign bold_keyword = '<span class="ai-advertorial-bold-' | append: ai_gen_id | append: '">' | append: keyword | append: '</span>' %}
          {% assign paragraph_2 = paragraph_2 | replace: keyword, bold_keyword %}
        {% endif %}
        {{ paragraph_2 }}
      </div>
    {% endif %}

    {% if block.settings.body_paragraph_3 != blank %}
      <div class="ai-advertorial-body-{{ ai_gen_id }}">
        {{ block.settings.body_paragraph_3 }}
      </div>
    {% endif %}

    {% if block.settings.body_paragraph_4 != blank %}
      <div class="ai-advertorial-body-{{ ai_gen_id }}">
        {{ block.settings.body_paragraph_4 }}
      </div>
    {% endif %}

    {% if block.settings.narrative_text_1 != blank %}
      <div class="ai-advertorial-narrative-{{ ai_gen_id }}">
        {{ block.settings.narrative_text_1 }}
      </div>
    {% endif %}

    {% if block.settings.pull_quote != blank %}
      <div class="ai-advertorial-quote-{{ ai_gen_id }}">
        <div class="ai-advertorial-quote-text-{{ ai_gen_id }}">{{ block.settings.pull_quote }}</div>
        {% if block.settings.pull_quote_attribution != blank %}
          <div class="ai-advertorial-quote-attribution-{{ ai_gen_id }}">{{ block.settings.pull_quote_attribution }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-advertorial-image-container-{{ ai_gen_id }}">
      {% if block.settings.progress_image %}
        <img
          src="{{ block.settings.progress_image | image_url: width: 1600 }}"
          alt="{{ block.settings.progress_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.progress_image.width }}"
          height="{{ block.settings.progress_image.height }}"
          class="ai-advertorial-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-advertorial-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-advertorial-empty-state-{{ ai_gen_id }}">
            Next, add a progress image
          </div>
        </div>
      {% endif %}
    </div>

    {% if block.settings.narrative_text_2 != blank %}
      <div class="ai-advertorial-narrative-{{ ai_gen_id }}">
        {{ block.settings.narrative_text_2 }}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Advertorial story",
  "settings": [
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "He hid his feet from me for three years."
    },
    {
      "type": "range",
      "id": "headline_size",
      "label": "Headline size",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "header",
      "content": "Rating"
    },
    {
      "type": "text",
      "id": "star_rating",
      "label": "Star rating",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count",
      "default": "1,400+"
    },
    {
      "type": "header",
      "content": "Customer"
    },
    {
      "type": "text",
      "id": "customer_name",
      "label": "Customer name",
      "default": "SARAH K."
    },
    {
      "type": "text",
      "id": "customer_location",
      "label": "Customer location",
      "default": "PHOENIX, AZ"
    },
    {
      "type": "header",
      "content": "Body content"
    },
    {
      "type": "textarea",
      "id": "body_paragraph_1",
      "label": "Body paragraph 1"
    },
    {
      "type": "textarea",
      "id": "body_paragraph_2",
      "label": "Body paragraph 2"
    },
    {
      "type": "text",
      "id": "bold_keyword",
      "label": "Bold keyword in paragraph 2",
      "default": "goat-milk lactic acid"
    },
    {
      "type": "textarea",
      "id": "body_paragraph_3",
      "label": "Body paragraph 3"
    },
    {
      "type": "textarea",
      "id": "body_paragraph_4",
      "label": "Body paragraph 4"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body text size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Narrative sections"
    },
    {
      "type": "text",
      "id": "narrative_text_1",
      "label": "Narrative text 1",
      "default": "The next morning he stopped in the kitchen and rubbed one foot against the other."
    },
    {
      "type": "text",
      "id": "narrative_text_2",
      "label": "Narrative text 2",
      "default": "Three weeks in, he walked out to get the mail. Barefoot. On the driveway."
    },
    {
      "type": "range",
      "id": "narrative_size",
      "label": "Narrative text size",
      "min": 20,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "header",
      "content": "Pull quote"
    },
    {
      "type": "text",
      "id": "pull_quote",
      "label": "Pull quote",
      "default": "Wait. Something's different."
    },
    {
      "type": "text",
      "id": "pull_quote_attribution",
      "label": "Pull quote attribution",
      "default": "— HIM, BEFORE COFFEE"
    },
    {
      "type": "header",
      "content": "Progress image"
    },
    {
      "type": "image_picker",
      "id": "progress_image",
      "label": "Progress image"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#F5F0EA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#15110c"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text",
      "default": "#4a4a4a"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#999999"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star",
      "default": "#FFB800"
    }
  ],
  "presets": [
    {
      "name": "Advertorial story"
    }
  ]
}
{% endschema %}
