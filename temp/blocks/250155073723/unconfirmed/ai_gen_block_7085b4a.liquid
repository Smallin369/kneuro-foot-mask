{% doc %}
  @prompt
    Create a long-form advertorial hero section with fully editable schema settings. Cream/off-white background (#F5F0EA). SCHEMA SETTINGS must include: Headline text (default: "He hid his feet from me for three years."), Body paragraph 1, 2, 3, 4 (each as separate text fields), Bold keyword to highlight in body copy (default: "goat-milk lactic acid"), Large narrative text (default: "The next morning he stopped in the kitchen and rubbed one foot against the other."), Pull-quote text (default: "Wait. Something's different."), Pull-quote attribution (default: "— HIM, BEFORE COFFEE"), Star rating number (default: "4.8"), Review count (default: "1,400+"), Customer name (default: "SARAH K."), Customer location (default: "PHOENIX, AZ"). DESIGN: Cream background #F5F0EA. Headline: large bold serif font, black. Body copy: readable sans-serif, dark gray, good line height. Star rating row: gold stars + "4.8 · 1,400+ CUSTOMERS" in small caps, then "SARAH K. · PHOENIX, AZ" below. Large narrative paragraph in bold serif, larger than body text. Pull-quote with a left vertical border line, italic text, attribution in small caps below. All padding/spacing consistent with a premium DTC brand. Fully responsive for mobile and desktop.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-advertorial-hero-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    padding: 60px 20px;
    width: 100%;
  }

  .ai-advertorial-hero__container-{{ ai_gen_id }} {
    max-width: 720px;
    margin: 0 auto;
  }

  .ai-advertorial-hero__headline-{{ ai_gen_id }} {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 42px;
    font-weight: 700;
    line-height: 1.2;
    color: {{ block.settings.headline_color }};
    margin: 0 0 32px;
  }

  .ai-advertorial-hero__rating-section-{{ ai_gen_id }} {
    margin-bottom: 32px;
  }

  .ai-advertorial-hero__stars-row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .ai-advertorial-hero__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-advertorial-hero__star-{{ ai_gen_id }} {
    color: {{ block.settings.star_color }};
    font-size: 18px;
  }

  .ai-advertorial-hero__rating-text-{{ ai_gen_id }} {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: {{ block.settings.body_color }};
  }

  .ai-advertorial-hero__customer-info-{{ ai_gen_id }} {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: {{ block.settings.body_color }};
    opacity: 0.7;
  }

  .ai-advertorial-hero__body-{{ ai_gen_id }} {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 17px;
    line-height: 1.7;
    color: {{ block.settings.body_color }};
    margin-bottom: 24px;
  }

  .ai-advertorial-hero__body-{{ ai_gen_id }} strong {
    font-weight: 600;
  }

  .ai-advertorial-hero__narrative-{{ ai_gen_id }} {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 24px;
    font-weight: 700;
    line-height: 1.5;
    color: {{ block.settings.headline_color }};
    margin: 40px 0;
  }

  .ai-advertorial-hero__pullquote-{{ ai_gen_id }} {
    border-left: 3px solid {{ block.settings.headline_color }};
    padding-left: 24px;
    margin: 40px 0;
  }

  .ai-advertorial-hero__pullquote-text-{{ ai_gen_id }} {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 20px;
    font-style: italic;
    line-height: 1.6;
    color: {{ block.settings.headline_color }};
    margin: 0 0 12px;
  }

  .ai-advertorial-hero__pullquote-attribution-{{ ai_gen_id }} {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: {{ block.settings.body_color }};
    opacity: 0.7;
  }

  @media screen and (max-width: 749px) {
    .ai-advertorial-hero-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-advertorial-hero__headline-{{ ai_gen_id }} {
      font-size: 32px;
      margin-bottom: 24px;
    }

    .ai-advertorial-hero__body-{{ ai_gen_id }} {
      font-size: 16px;
      margin-bottom: 20px;
    }

    .ai-advertorial-hero__narrative-{{ ai_gen_id }} {
      font-size: 20px;
      margin: 32px 0;
    }

    .ai-advertorial-hero__pullquote-{{ ai_gen_id }} {
      padding-left: 16px;
      margin: 32px 0;
    }

    .ai-advertorial-hero__pullquote-text-{{ ai_gen_id }} {
      font-size: 18px;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-advertorial-hero-{{ ai_gen_id }} {
      padding: 80px 40px;
    }
  }
{% endstyle %}

<div class="ai-advertorial-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-advertorial-hero__container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h1 class="ai-advertorial-hero__headline-{{ ai_gen_id }}">
        {{ block.settings.headline }}
      </h1>
    {% endif %}

    <div class="ai-advertorial-hero__rating-section-{{ ai_gen_id }}">
      <div class="ai-advertorial-hero__stars-row-{{ ai_gen_id }}">
        <div class="ai-advertorial-hero__stars-{{ ai_gen_id }}">
          {% assign rating_floor = block.settings.star_rating | floor %}
          {% assign has_half_star = false %}
          {% assign decimal = block.settings.star_rating | minus: rating_floor %}
          {% if decimal >= 0.3 and decimal < 0.8 %}
            {% assign has_half_star = true %}
          {% elsif decimal >= 0.8 %}
            {% assign rating_floor = rating_floor | plus: 1 %}
          {% endif %}

          {% for i in (1..rating_floor) %}
            <span class="ai-advertorial-hero__star-{{ ai_gen_id }}">★</span>
          {% endfor %}
          {% if has_half_star %}
            <span class="ai-advertorial-hero__star-{{ ai_gen_id }}">★</span>
          {% endif %}
        </div>
        <span class="ai-advertorial-hero__rating-text-{{ ai_gen_id }}">
          {{ block.settings.star_rating }} · {{ block.settings.review_count }} CUSTOMERS
        </span>
      </div>
      {% if block.settings.customer_name != blank or block.settings.customer_location != blank %}
        <div class="ai-advertorial-hero__customer-info-{{ ai_gen_id }}">
          {% if block.settings.customer_name != blank %}{{ block.settings.customer_name }}{% endif %}{% if block.settings.customer_name != blank and block.settings.customer_location != blank %} · {% endif %}{% if block.settings.customer_location != blank %}{{ block.settings.customer_location }}{% endif %}
        </div>
      {% endif %}
    </div>

    {% if block.settings.body_paragraph_1 != blank %}
      <div class="ai-advertorial-hero__body-{{ ai_gen_id }}">
        {% if block.settings.bold_keyword != blank %}
          {% assign paragraph_with_bold = block.settings.body_paragraph_1 | replace: block.settings.bold_keyword, '<strong>' | append: block.settings.bold_keyword | append: '</strong>' %}
          {{ paragraph_with_bold }}
        {% else %}
          {{ block.settings.body_paragraph_1 }}
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.body_paragraph_2 != blank %}
      <div class="ai-advertorial-hero__body-{{ ai_gen_id }}">
        {% if block.settings.bold_keyword != blank %}
          {% assign paragraph_with_bold = block.settings.body_paragraph_2 | replace: block.settings.bold_keyword, '<strong>' | append: block.settings.bold_keyword | append: '</strong>' %}
          {{ paragraph_with_bold }}
        {% else %}
          {{ block.settings.body_paragraph_2 }}
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.narrative_text != blank %}
      <div class="ai-advertorial-hero__narrative-{{ ai_gen_id }}">
        {{ block.settings.narrative_text }}
      </div>
    {% endif %}

    {% if block.settings.body_paragraph_3 != blank %}
      <div class="ai-advertorial-hero__body-{{ ai_gen_id }}">
        {% if block.settings.bold_keyword != blank %}
          {% assign paragraph_with_bold = block.settings.body_paragraph_3 | replace: block.settings.bold_keyword, '<strong>' | append: block.settings.bold_keyword | append: '</strong>' %}
          {{ paragraph_with_bold }}
        {% else %}
          {{ block.settings.body_paragraph_3 }}
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.pullquote_text != blank %}
      <div class="ai-advertorial-hero__pullquote-{{ ai_gen_id }}">
        <p class="ai-advertorial-hero__pullquote-text-{{ ai_gen_id }}">
          {{ block.settings.pullquote_text }}
        </p>
        {% if block.settings.pullquote_attribution != blank %}
          <div class="ai-advertorial-hero__pullquote-attribution-{{ ai_gen_id }}">
            {{ block.settings.pullquote_attribution }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.body_paragraph_4 != blank %}
      <div class="ai-advertorial-hero__body-{{ ai_gen_id }}">
        {% if block.settings.bold_keyword != blank %}
          {% assign paragraph_with_bold = block.settings.body_paragraph_4 | replace: block.settings.bold_keyword, '<strong>' | append: block.settings.bold_keyword | append: '</strong>' %}
          {{ paragraph_with_bold }}
        {% else %}
          {{ block.settings.body_paragraph_4 }}
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Advertorial hero",
  "settings": [
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline text",
      "default": "He hid his feet from me for three years."
    },
    {
      "type": "header",
      "content": "Rating"
    },
    {
      "type": "text",
      "id": "star_rating",
      "label": "Star rating number",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count",
      "default": "1,400+"
    },
    {
      "type": "text",
      "id": "customer_name",
      "label": "Customer name",
      "default": "SARAH K."
    },
    {
      "type": "text",
      "id": "customer_location",
      "label": "Customer location",
      "default": "PHOENIX, AZ"
    },
    {
      "type": "header",
      "content": "Body copy"
    },
    {
      "type": "textarea",
      "id": "body_paragraph_1",
      "label": "Body paragraph 1",
      "default": "I didn't even know what his heels looked like. Every time I'd catch a glimpse, he'd pull his socks back on. It wasn't vanity. It was shame."
    },
    {
      "type": "textarea",
      "id": "body_paragraph_2",
      "label": "Body paragraph 2",
      "default": "Then I left a jar of something on the bathroom counter. I didn't say a word. The label said it had goat-milk lactic acid and urea. He rolled his eyes. But the jar started moving around the house."
    },
    {
      "type": "text",
      "id": "bold_keyword",
      "label": "Bold keyword to highlight",
      "default": "goat-milk lactic acid"
    },
    {
      "type": "header",
      "content": "Narrative text"
    },
    {
      "type": "textarea",
      "id": "narrative_text",
      "label": "Large narrative text",
      "default": "The next morning he stopped in the kitchen and rubbed one foot against the other."
    },
    {
      "type": "header",
      "content": "Pull quote"
    },
    {
      "type": "textarea",
      "id": "pullquote_text",
      "label": "Pull quote text",
      "default": "Wait. Something's different."
    },
    {
      "type": "text",
      "id": "pullquote_attribution",
      "label": "Pull quote attribution",
      "default": "— HIM, BEFORE COFFEE"
    },
    {
      "type": "header",
      "content": "More body copy"
    },
    {
      "type": "textarea",
      "id": "body_paragraph_3",
      "label": "Body paragraph 3",
      "default": "Two weeks later, he was walking around barefoot. The cracks were gone. The rough patches had softened. He didn't say much. But I noticed he stopped hiding."
    },
    {
      "type": "textarea",
      "id": "body_paragraph_4",
      "label": "Body paragraph 4",
      "default": "That's what happens when something actually works. You don't need to talk about it. You just stop being embarrassed."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#F5F0EA"
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Headline",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star rating",
      "default": "#D4AF37"
    }
  ],
  "presets": [
    {
      "name": "Advertorial hero"
    }
  ]
}
{% endschema %}
