      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "headline_size_desktop",
      "label": "Headline size (desktop)",
      "min": 32,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "headline_color",
