{% doc %}
  @prompt
    Create a complete long-form advertorial story section as ONE block with fully editable schema settings. Cream background (#F5F0EA). SCHEMA SETTINGS: Headline (default: "He hid his feet from me for three years."), Star rating (default: "4.8"), Review count (default: "1,400+"), Customer name (default: "SARAH K."), Customer location (default: "PHOENIX, AZ"), Body paragraph 1, 2, 3, 4 (each editable), Bold keyword (default: "goat-milk lactic acid"), Narrative text 1 (default: "The next morning he stopped in the kitchen and rubbed one foot against the other."), Pull quote (default: "Wait. Something's different."), Pull quote attribution (default: "— HIM, BEFORE COFFEE"), Progress image (image picker), Narrative text 2 (default: "Three weeks in, he walked out to get the mail. Barefoot. On the driveway."). LAYOUT ORDER: 1. Large bold serif headline. 2. Star rating row: gold stars + review count small caps + customer name/location. 3. Body paragraphs with bold keyword highlighted. 4. Large bold serif narrative text 1. 5. Pull quote with left vertical border 3px solid black, italic, attribution small caps. 6. Full-width progress image edge to edge, no padding, aspect-ratio 3/2, object-fit cover. 7. Large bold serif narrative text 2. DESIGN: Cream #F5F0EA throughout. Headline 36px bold serif. Body 16px sans-serif dark gray 1.7 line-height. Narrative 28px bold serif. Fully responsive.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-advertorial-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    padding: 60px 20px;
    width: 100%;
  }

  .ai-advertorial-container-{{ ai_gen_id }} {
    max-width: 720px;
    margin: 0 auto;
  }

  .ai-advertorial-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 700;
    font-family: Georgia, 'Times New Roman', serif;
    color: {{ block.settings.text_color }};
    margin: 0 0 24px;
    line-height: 1.2;
  }

  .ai-advertorial-rating-row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .ai-advertorial-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
  }

  .ai-advertorial-star-{{ ai_gen_id }} {
    color: {{ block.settings.star_color }};
    font-size: 18px;
  }

  .ai-advertorial-review-count-{{ ai_gen_id }} {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ block.settings.muted_color }};
  }

  .ai-advertorial-customer-{{ ai_gen_id }} {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ block.settings.muted_color }};
  }

  .ai-advertorial-body-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    color: {{ block.settings.body_color }};
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .ai-advertorial-bold-keyword-{{ ai_gen_id }} {
    font-weight: 700;
    color: {{ block.settings.text_color }};
  }

  .ai-advertorial-narrative-{{ ai_gen_id }} {
    font-size: {{ block.settings.narrative_size }}px;
    font-weight: 700;
    font-family: Georgia, 'Times New Roman', serif;
    color: {{ block.settings.text_color }};
    margin: 40px 0;
    line-height: 1.3;
  }

  .ai-advertorial-pullquote-{{ ai_gen_id }} {
    border-left: 3px solid {{ block.settings.text_color }};
    padding-left: 24px;
    margin: 40px 0;
  }

  .ai-advertorial-pullquote-text-{{ ai_gen_id }} {
    font-size: 24px;
    font-style: italic;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
    line-height: 1.4;
  }

  .ai-advertorial-pullquote-attribution-{{ ai_gen_id }} {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ block.settings.muted_color }};
  }

  .ai-advertorial-image-wrapper-{{ ai_gen_id }} {
    margin: 40px -20px;
    width: calc(100% + 40px);
  }

  .ai-advertorial-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
  }

  .ai-advertorial-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 3 / 2;
    background-color: #e5e5e5;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-advertorial-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-advertorial-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-advertorial-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-advertorial-headline-{{ ai_gen_id }} {
      font-size: 28px;
    }

    .ai-advertorial-narrative-{{ ai_gen_id }} {
      font-size: 22px;
    }

    .ai-advertorial-pullquote-text-{{ ai_gen_id }} {
      font-size: 20px;
    }

    .ai-advertorial-image-wrapper-{{ ai_gen_id }} {
      margin: 32px -16px;
      width: calc(100% + 32px);
    }
  }
{% endstyle %}

<advertorial-story-{{ ai_gen_id }} class="ai-advertorial-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-advertorial-container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h1 class="ai-advertorial-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
    {% endif %}

    <div class="ai-advertorial-rating-row-{{ ai_gen_id }}">
      <div class="ai-advertorial-stars-{{ ai_gen_id }}">
        {% assign star_rating = block.settings.star_rating %}
        {% assign full_stars = star_rating | floor %}
        {% assign has_half = star_rating | modulo: 1 %}
        
        {% for i in (1..full_stars) %}
          <span class="ai-advertorial-star-{{ ai_gen_id }}">★</span>
        {% endfor %}
        
        {% if has_half >= 0.5 %}
          <span class="ai-advertorial-star-{{ ai_gen_id }}">★</span>
        {% endif %}
      </div>

      {% if block.settings.review_count != blank %}
        <span class="ai-advertorial-review-count-{{ ai_gen_id }}">{{ block.settings.review_count }} reviews</span>
      {% endif %}

      {% if block.settings.customer_name != blank or block.settings.customer_location != blank %}
        <span class="ai-advertorial-customer-{{ ai_gen_id }}">
          {% if block.settings.customer_name != blank %}{{ block.settings.customer_name }}{% endif %}{% if block.settings.customer_name != blank and block.settings.customer_location != blank %}, {% endif %}{% if block.settings.customer_location != blank %}{{ block.settings.customer_location }}{% endif %}
        </span>
      {% endif %}
    </div>

    {% if block.settings.body_paragraph_1 != blank %}
      <div class="ai-advertorial-body-{{ ai_gen_id }}">
        {% assign paragraph_1 = block.settings.body_paragraph_1 %}
        {% if block.settings.bold_keyword != blank %}
          {% assign keyword = block.settings.bold_keyword %}
          {% assign paragraph_1 = paragraph_1 | replace: keyword, '<span class="ai-advertorial-bold-keyword-' | append: ai_gen_id | append: '">' | append: keyword | append: '</span>' %}
        {% endif %}
        {{ paragraph_1 }}
      </div>
    {% endif %}

    {% if block.settings.body_paragraph_2 != blank %}
      <div class="ai-advertorial-body-{{ ai_gen_id }}">
        {% assign paragraph_2 = block.settings.body_paragraph_2 %}
        {% if block.settings.bold_keyword != blank %}
          {% assign keyword = block.settings.bold_keyword %}
          {% assign paragraph_2 = paragraph_2 | replace: keyword, '<span class="ai-advertorial-bold-keyword-' | append: ai_gen_id | append: '">' | append: keyword | append: '</span>' %}
        {% endif %}
        {{ paragraph_2 }}
      </div>
    {% endif %}

    {% if block.settings.body_paragraph_3 != blank %}
      <div class="ai-advertorial-body-{{ ai_gen_id }}">
        {% assign paragraph_3 = block.settings.body_paragraph_3 %}
        {% if block.settings.bold_keyword != blank %}
          {% assign keyword = block.settings.bold_keyword %}
          {% assign paragraph_3 = paragraph_3 | replace: keyword, '<span class="ai-advertorial-bold-keyword-' | append: ai_gen_id | append: '">' | append: keyword | append: '</span>' %}
        {% endif %}
        {{ paragraph_3 }}
      </div>
    {% endif %}

    {% if block.settings.body_paragraph_4 != blank %}
      <div class="ai-advertorial-body-{{ ai_gen_id }}">
        {% assign paragraph_4 = block.settings.body_paragraph_4 %}
        {% if block.settings.bold_keyword != blank %}
          {% assign keyword = block.settings.bold_keyword %}
          {% assign paragraph_4 = paragraph_4 | replace: keyword, '<span class="ai-advertorial-bold-keyword-' | append: ai_gen_id | append: '">' | append: keyword | append: '</span>' %}
        {% endif %}
        {{ paragraph_4 }}
      </div>
    {% endif %}

    {% if block.settings.narrative_text_1 != blank %}
      <div class="ai-advertorial-narrative-{{ ai_gen_id }}">{{ block.settings.narrative_text_1 }}</div>
    {% endif %}

    {% if block.settings.pullquote != blank %}
      <div class="ai-advertorial-pullquote-{{ ai_gen_id }}">
        <p class="ai-advertorial-pullquote-text-{{ ai_gen_id }}">{{ block.settings.pullquote }}</p>
        {% if block.settings.pullquote_attribution != blank %}
          <p class="ai-advertorial-pullquote-attribution-{{ ai_gen_id }}">{{ block.settings.pullquote_attribution }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-advertorial-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.progress_image %}
        <img
          src="{{ block.settings.progress_image | image_url: width: 1440 }}"
          alt="{{ block.settings.progress_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.progress_image.width }}"
          height="{{ block.settings.progress_image.height }}"
          class="ai-advertorial-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-advertorial-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-advertorial-empty-state-{{ ai_gen_id }}">
            Next, add a progress image
          </div>
        </div>
      {% endif %}
    </div>

    {% if block.settings.narrative_text_2 != blank %}
      <div class="ai-advertorial-narrative-{{ ai_gen_id }}">{{ block.settings.narrative_text_2 }}</div>
    {% endif %}
  </div>
</advertorial-story-{{ ai_gen_id }}>

<script>
  (function() {
    class AdvertorialStory{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('advertorial-story-{{ ai_gen_id }}', AdvertorialStory{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Advertorial story",
  "settings": [
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "default": "He hid his feet from me for three years."
    },
    {
      "type": "range",
      "id": "headline_size",
      "label": "Headline size",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "header",
      "content": "Rating"
    },
    {
      "type": "range",
      "id": "star_rating",
      "label": "Star rating",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "default": 4.5
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count",
      "default": "1,400+"
    },
    {
      "type": "text",
      "id": "customer_name",
      "label": "Customer name",
      "default": "SARAH K."
    },
    {
      "type": "text",
      "id": "customer_location",
      "label": "Customer location",
      "default": "PHOENIX, AZ"
    },
    {
      "type": "header",
      "content": "Body content"
    },
    {
      "type": "textarea",
      "id": "body_paragraph_1",
      "label": "Body paragraph 1",
      "default": "I didn't even know it was a problem until I found the socks. Balled up. Hidden in the back of his drawer. He'd been wearing them to bed. In summer."
    },
    {
      "type": "textarea",
      "id": "body_paragraph_2",
      "label": "Body paragraph 2",
      "default": "When I finally asked, he just shrugged. Said his feet were rough. Embarrassing. He didn't want me to see them."
    },
    {
      "type": "textarea",
      "id": "body_paragraph_3",
      "label": "Body paragraph 3",
      "default": "So I ordered this. Didn't tell him. Just left it by the shower with a note: Try this. The goat-milk lactic acid formula is supposed to work overnight."
    },
    {
      "type": "textarea",
      "id": "body_paragraph_4",
      "label": "Body paragraph 4",
      "default": "He didn't say anything. But I noticed the tube was lighter every few days."
    },
    {
      "type": "text",
      "id": "bold_keyword",
      "label": "Bold keyword",
      "default": "goat-milk lactic acid"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body text size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Narrative moments"
    },
    {
      "type": "textarea",
      "id": "narrative_text_1",
      "label": "Narrative text 1",
      "default": "The next morning he stopped in the kitchen and rubbed one foot against the other."
    },
    {
      "type": "textarea",
      "id": "narrative_text_2",
      "label": "Narrative text 2",
      "default": "Three weeks in, he walked out to get the mail. Barefoot. On the driveway."
    },
    {
      "type": "range",
      "id": "narrative_size",
      "label": "Narrative text size",
      "min": 20,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "header",
      "content": "Pull quote"
    },
    {
      "type": "textarea",
      "id": "pullquote",
      "label": "Pull quote",
      "default": "Wait. Something's different."
    },
    {
      "type": "text",
      "id": "pullquote_attribution",
      "label": "Pull quote attribution",
      "default": "— HIM, BEFORE COFFEE"
    },
    {
      "type": "header",
      "content": "Progress image"
    },
    {
      "type": "image_picker",
      "id": "progress_image",
      "label": "Progress image"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#F5F0EA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#15110c"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text",
      "default": "#4a4a4a"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#999999"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star",
      "default": "#FFB800"
    }
  ],
  "presets": [
    {
      "name": "Advertorial story"
    }
  ]
}
{% endschema %}
