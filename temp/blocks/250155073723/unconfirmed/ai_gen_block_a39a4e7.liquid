{% doc %}
  @prompt
    Create a 3-column before/after progress photo section with fully editable schema settings. Cream background (#F5F0EA). SCHEMA SETTINGS must include: Image 1 (image picker), Image 1 label (default: "Before"), Image 2 (image picker), Image 2 label (default: "2 Weeks In"), Image 3 (image picker), Image 3 label (default: "After 3 Weeks"), Section top padding (range), Section bottom padding (range). DESIGN: 3 equal-width columns side by side, minimal 2px gap between images. Each image fills its column fully, portrait crop. Small label overlay in top-left corner of each image: white text on semi-transparent dark background, small caps, tight padding. Images are full-bleed edge to edge on mobile. No heading, no subtext — just the 3 images with labels. Below the images, a large bold serif narrative text block on cream background: "Three weeks in, he walked out to get the mail. Barefoot. On the driveway." — editable schema setting. Generous padding above and below the narrative text. Fully responsive for mobile and desktop.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-progress-photos-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-progress-photos__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    width: 100%;
  }

  .ai-progress-photos__column-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-progress-photos__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 133%;
    overflow: hidden;
  }

  .ai-progress-photos__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-progress-photos__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #e5e5e5;
  }

  .ai-progress-photos__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-progress-photos__label-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: rgba(0, 0, 0, 0.7);
    color: #ffffff;
    padding: 6px 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 1;
  }

  .ai-progress-photos__narrative-{{ ai_gen_id }} {
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 20px;
    text-align: center;
  }

  .ai-progress-photos__narrative-text-{{ ai_gen_id }} {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 32px;
    font-weight: 700;
    line-height: 1.4;
    color: {{ block.settings.narrative_text_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-progress-photos__narrative-text-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-progress-photos__narrative-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-progress-photos__label-{{ ai_gen_id }} {
      top: 8px;
      left: 8px;
      padding: 4px 8px;
      font-size: 10px;
    }
  }
{% endstyle %}

<progress-photos-{{ ai_gen_id }} class="ai-progress-photos-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-progress-photos__grid-{{ ai_gen_id }}">
    <div class="ai-progress-photos__column-{{ ai_gen_id }}">
      <div class="ai-progress-photos__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image_1 %}
          <img
            src="{{ block.settings.image_1 | image_url: width: 800 }}"
            alt="{{ block.settings.image_1.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_1.width }}"
            height="{{ block.settings.image_1.height }}"
            class="ai-progress-photos__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-progress-photos__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
        {% if block.settings.label_1 != blank %}
          <div class="ai-progress-photos__label-{{ ai_gen_id }}">
            {{ block.settings.label_1 }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-progress-photos__column-{{ ai_gen_id }}">
      <div class="ai-progress-photos__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image_2 %}
          <img
            src="{{ block.settings.image_2 | image_url: width: 800 }}"
            alt="{{ block.settings.image_2.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_2.width }}"
            height="{{ block.settings.image_2.height }}"
            class="ai-progress-photos__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-progress-photos__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
        {% if block.settings.label_2 != blank %}
          <div class="ai-progress-photos__label-{{ ai_gen_id }}">
            {{ block.settings.label_2 }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-progress-photos__column-{{ ai_gen_id }}">
      <div class="ai-progress-photos__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image_3 %}
          <img
            src="{{ block.settings.image_3 | image_url: width: 800 }}"
            alt="{{ block.settings.image_3.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_3.width }}"
            height="{{ block.settings.image_3.height }}"
            class="ai-progress-photos__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-progress-photos__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
        {% if block.settings.label_3 != blank %}
          <div class="ai-progress-photos__label-{{ ai_gen_id }}">
            {{ block.settings.label_3 }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  {% if block.settings.narrative_text != blank %}
    <div class="ai-progress-photos__narrative-{{ ai_gen_id }}">
      <p class="ai-progress-photos__narrative-text-{{ ai_gen_id }}">
        {{ block.settings.narrative_text }}
      </p>
    </div>
  {% endif %}
</progress-photos-{{ ai_gen_id }}>

<script>
  (function() {
    class ProgressPhotos{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('progress-photos-{{ ai_gen_id }}', ProgressPhotos{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Progress photos",
  "settings": [
    {
      "type": "header",
      "content": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "label_1",
      "label": "Label",
      "default": "Before"
    },
    {
      "type": "header",
      "content": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "label_2",
      "label": "Label",
      "default": "2 Weeks In"
    },
    {
      "type": "header",
      "content": "Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "label_3",
      "label": "Label",
      "default": "After 3 Weeks"
    },
    {
      "type": "header",
      "content": "Narrative text"
    },
    {
      "type": "textarea",
      "id": "narrative_text",
      "label": "Text",
      "default": "Three weeks in, he walked out to get the mail. Barefoot. On the driveway."
    },
    {
      "type": "color",
      "id": "narrative_text_color",
      "label": "Text color",
      "default": "#15110c"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F5F0EA"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Progress photos"
    }
  ]
}
{% endschema %}
