{% doc %}
  @prompt
    Create a 3-column before/after progress photo section with fully editable schema settings. Cream background (#F5F0EA). SCHEMA SETTINGS: Image 1 (image picker), Image 1 label (default: "Before"), Image 2 (image picker), Image 2 label (default: "2 Weeks In"), Image 3 (image picker), Image 3 label (default: "After 3 Weeks"), Narrative text (default: "Three weeks in, he walked out to get the mail. Barefoot. On the driveway."). DESIGN: 3 images in a single row, each exactly 1/3 screen width. Image height fixed at 180px mobile, 240px desktop - DO NOT let images stretch full height. object-fit: cover. Minimal 2px gap between columns. No extra whitespace. Small label overlay top-left: white text, dark semi-transparent background, 8px padding, 11px font size. Below images: large bold serif narrative text on cream #F5F0EA, 28px font size, generous top/bottom padding. Full width mobile, max-width 600px centered desktop. Fully responsive.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-progress-photos-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-progress-photos__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    width: 100%;
  }

  .ai-progress-photos__column-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 180px;
    overflow: hidden;
  }

  .ai-progress-photos__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-progress-photos__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e5e5e5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-progress-photos__placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
  }

  .ai-progress-photos__label-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    background-color: rgba(0, 0, 0, 0.6);
    color: #ffffff;
    padding: 8px;
    font-size: 11px;
    line-height: 1.2;
    font-weight: 500;
  }

  .ai-progress-photos__narrative-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: 40px 20px;
    text-align: center;
  }

  .ai-progress-photos__narrative-text-{{ ai_gen_id }} {
    font-family: Georgia, serif;
    font-size: 28px;
    font-weight: 700;
    line-height: 1.4;
    color: {{ block.settings.text_color }};
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  @media screen and (min-width: 750px) {
    .ai-progress-photos__column-{{ ai_gen_id }} {
      height: 240px;
    }

    .ai-progress-photos__narrative-{{ ai_gen_id }} {
      padding: 60px 40px;
    }
  }
{% endstyle %}

<ai-progress-photos-{{ ai_gen_id }} class="ai-progress-photos-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-progress-photos__grid-{{ ai_gen_id }}">
    <div class="ai-progress-photos__column-{{ ai_gen_id }}">
      {% if block.settings.image_1 %}
        <img
          src="{{ block.settings.image_1 | image_url: width: 800 }}"
          alt="{{ block.settings.image_1.alt | escape }}"
          class="ai-progress-photos__image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.image_1.width }}"
          height="{{ block.settings.image_1.height }}"
        >
      {% else %}
        <div class="ai-progress-photos__placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
      {% if block.settings.label_1 != blank %}
        <div class="ai-progress-photos__label-{{ ai_gen_id }}">{{ block.settings.label_1 }}</div>
      {% endif %}
    </div>

    <div class="ai-progress-photos__column-{{ ai_gen_id }}">
      {% if block.settings.image_2 %}
        <img
          src="{{ block.settings.image_2 | image_url: width: 800 }}"
          alt="{{ block.settings.image_2.alt | escape }}"
          class="ai-progress-photos__image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.image_2.width }}"
          height="{{ block.settings.image_2.height }}"
        >
      {% else %}
        <div class="ai-progress-photos__placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
      {% if block.settings.label_2 != blank %}
        <div class="ai-progress-photos__label-{{ ai_gen_id }}">{{ block.settings.label_2 }}</div>
      {% endif %}
    </div>

    <div class="ai-progress-photos__column-{{ ai_gen_id }}">
      {% if block.settings.image_3 %}
        <img
          src="{{ block.settings.image_3 | image_url: width: 800 }}"
          alt="{{ block.settings.image_3.alt | escape }}"
          class="ai-progress-photos__image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.image_3.width }}"
          height="{{ block.settings.image_3.height }}"
        >
      {% else %}
        <div class="ai-progress-photos__placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
      {% if block.settings.label_3 != blank %}
        <div class="ai-progress-photos__label-{{ ai_gen_id }}">{{ block.settings.label_3 }}</div>
      {% endif %}
    </div>
  </div>

  {% if block.settings.narrative_text != blank %}
    <div class="ai-progress-photos__narrative-{{ ai_gen_id }}">
      <p class="ai-progress-photos__narrative-text-{{ ai_gen_id }}">{{ block.settings.narrative_text }}</p>
    </div>
  {% endif %}
</ai-progress-photos-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Progress photos",
  "settings": [
    {
      "type": "header",
      "content": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "label_1",
      "label": "Label",
      "default": "Before"
    },
    {
      "type": "header",
      "content": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "label_2",
      "label": "Label",
      "default": "2 Weeks In"
    },
    {
      "type": "header",
      "content": "Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "label_3",
      "label": "Label",
      "default": "After 3 Weeks"
    },
    {
      "type": "header",
      "content": "Narrative"
    },
    {
      "type": "textarea",
      "id": "narrative_text",
      "label": "Text",
      "default": "Three weeks in, he walked out to get the mail. Barefoot. On the driveway."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#F5F0EA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#15110c"
    }
  ],
  "presets": [
    {
      "name": "Progress photos"
    }
  ]
}
{% endschema %}
