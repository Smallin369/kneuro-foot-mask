      "default": "What happened next is hard to ignore:"
    },
    {
      "type": "image_picker",
      "id": "proof_image",
      "label": "Proof image"
    },
    {
      "type": "textarea",
      "id": "bridge_line",
      "label": "Bridge line",
      "default": "This wasn't just moisturizing the surface… something deeper was happening."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fffaee"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label",
      "default": "#8a7560"
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Headline",
      "default": "#2a1c12"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#2a1c12"
    }
  ],
  "presets": [
    {
      "name": "Customer story"
    }
  ]
}
{% endschema %}
