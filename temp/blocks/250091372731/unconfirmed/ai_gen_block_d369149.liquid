{% doc %}
  @prompt
    Create an emotionally engaging advertorial story section with dramatic pacing and strong visual hierarchy. Requirements:
    
    LAYOUT:
    - Warm cream background (#f5f0e8)
    - Narrow centered column, max-width 600px, left-aligned text inside
    - Generous spacing between each story beat (each line/paragraph is its own moment)
    - Mobile-friendly and readable
    
    TYPOGRAPHY:
    - Serif font (Fraunces or similar) for story text
    - Normal weight for opening lines
    - Bold for emphasis lines
    - Italic or bold-italic for emotional turning points
    - "Look at this:" is the largest, boldest element — centered, with significant space above it — acts as a visual transition cue into the before/after section below
    
    COPY (use exactly as written, each line is its own paragraph with spacing):
    - "Sarah's husband stopped walking barefoot—even at home." — normal
    - "His heels were so dry and cracked they would catch on socks." — normal
    - "He tried everything… creams, scrubs, all those "miracle fixes"…" — normal italic
    - "nothing actually worked." — bold, slightly larger
    - "At some point, he just gave up." — italic, weighted
    - "Then one night, she got him to try something different." — normal
    - "He didn't expect much." — normal, smaller/quieter
    - "But the next morning was… strange." — bold italic
    - "Over the next few days, it got even stranger." — bold italic
    - "Look at this:" — largest text, bold, centered, extra margin above, acts as section transition
    
    STYLE: Premium, clean, editorial. Not loud or salesy. Feels like a real customer story unfolding.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-story-section-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 20px;
    width: 100%;
  }

  .ai-story-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: left;
  }

  .ai-story-paragraph-{{ ai_gen_id }} {
    font-family: {{ block.settings.story_font.family }}, serif;
    font-weight: {{ block.settings.story_font.weight }};
    font-style: {{ block.settings.story_font.style }};
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.base_font_size }}px;
    line-height: 1.6;
    margin: 0 0 {{ block.settings.paragraph_spacing }}px 0;
  }

  .ai-story-paragraph-{{ ai_gen_id }}--normal {
    font-weight: 400;
    font-style: normal;
  }

  .ai-story-paragraph-{{ ai_gen_id }}--italic {
    font-weight: 400;
    font-style: italic;
  }

  .ai-story-paragraph-{{ ai_gen_id }}--bold {
    font-weight: 700;
    font-style: normal;
    font-size: {{ block.settings.base_font_size | times: 1.1 }}px;
  }

  .ai-story-paragraph-{{ ai_gen_id }}--bold-italic {
    font-weight: 700;
    font-style: italic;
  }

  .ai-story-paragraph-{{ ai_gen_id }}--weighted {
    font-weight: 500;
    font-style: italic;
  }

  .ai-story-paragraph-{{ ai_gen_id }}--quiet {
    font-weight: 400;
    font-style: normal;
    font-size: {{ block.settings.base_font_size | times: 0.9 }}px;
    opacity: 0.85;
  }

  .ai-story-transition-{{ ai_gen_id }} {
    font-family: {{ block.settings.story_font.family }}, serif;
    font-weight: 700;
    font-style: normal;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.transition_font_size }}px;
    line-height: 1.3;
    text-align: center;
    margin: {{ block.settings.transition_margin_top }}px 0 {{ block.settings.transition_margin_bottom }}px 0;
  }

  @media screen and (max-width: 749px) {
    .ai-story-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.7 }}px 16px;
    }

    .ai-story-paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.base_font_size | times: 0.95 }}px;
    }

    .ai-story-paragraph-{{ ai_gen_id }}--bold {
      font-size: {{ block.settings.base_font_size | times: 1.05 }}px;
    }

    .ai-story-paragraph-{{ ai_gen_id }}--quiet {
      font-size: {{ block.settings.base_font_size | times: 0.85 }}px;
    }

    .ai-story-transition-{{ ai_gen_id }} {
      font-size: {{ block.settings.transition_font_size | times: 0.85 }}px;
      margin: {{ block.settings.transition_margin_top | times: 0.7 }}px 0 {{ block.settings.transition_margin_bottom | times: 0.7 }}px 0;
    }
  }
{% endstyle %}

<div class="ai-story-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-story-container-{{ ai_gen_id }}">
    <p class="ai-story-paragraph-{{ ai_gen_id }} ai-story-paragraph-{{ ai_gen_id }}--normal">
      Sarah's husband stopped walking barefoot—even at home.
    </p>

    <p class="ai-story-paragraph-{{ ai_gen_id }} ai-story-paragraph-{{ ai_gen_id }}--normal">
      His heels were so dry and cracked they would catch on socks.
    </p>

    <p class="ai-story-paragraph-{{ ai_gen_id }} ai-story-paragraph-{{ ai_gen_id }}--italic">
      He tried everything… creams, scrubs, all those "miracle fixes"…
    </p>

    <p class="ai-story-paragraph-{{ ai_gen_id }} ai-story-paragraph-{{ ai_gen_id }}--bold">
      nothing actually worked.
    </p>

    <p class="ai-story-paragraph-{{ ai_gen_id }} ai-story-paragraph-{{ ai_gen_id }}--weighted">
      At some point, he just gave up.
    </p>

    <p class="ai-story-paragraph-{{ ai_gen_id }} ai-story-paragraph-{{ ai_gen_id }}--normal">
      Then one night, she got him to try something different.
    </p>

    <p class="ai-story-paragraph-{{ ai_gen_id }} ai-story-paragraph-{{ ai_gen_id }}--quiet">
      He didn't expect much.
    </p>

    <p class="ai-story-paragraph-{{ ai_gen_id }} ai-story-paragraph-{{ ai_gen_id }}--bold-italic">
      But the next morning was… strange.
    </p>

    <p class="ai-story-paragraph-{{ ai_gen_id }} ai-story-paragraph-{{ ai_gen_id }}--bold-italic">
      Over the next few days, it got even stranger.
    </p>

    <p class="ai-story-transition-{{ ai_gen_id }}">
      Look at this:
    </p>
  </div>
</div>

{% schema %}
{
  "name": "Story section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 400,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "paragraph_spacing",
      "label": "Paragraph spacing",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 35
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f5f0e8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#2c2c2c"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "story_font",
      "label": "Story font",
      "default": "serif"
    },
    {
      "type": "range",
      "id": "base_font_size",
      "label": "Base font size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "transition_font_size",
      "label": "Transition text size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 42
    },
    {
      "type": "range",
      "id": "transition_margin_top",
      "label": "Transition top margin",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "transition_margin_bottom",
      "label": "Transition bottom margin",
      "min": 20,
      "max": 80,
      "step": 10,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Story section"
    }
  ]
}
{% endschema %}
