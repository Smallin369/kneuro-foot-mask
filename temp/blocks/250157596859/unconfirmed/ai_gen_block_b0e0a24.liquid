{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-magazine-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px;
  }

  .ai-magazine-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-magazine-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
    padding-bottom: {{ block.settings.header_spacing | divided_by: 2 }}px;
    border-bottom: {{ block.settings.divider_width }}px solid {{ block.settings.divider_color }};
  }

  .ai-magazine-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.category_size }}px;
    color: {{ block.settings.accent_color }};
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .ai-magazine-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    line-height: 1.2;
    font-weight: 700;
  }

  .ai-magazine-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.muted_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-magazine-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-featured-{{ ai_gen_id }} {
    grid-column: span {{ block.settings.columns_desktop }};
    position: relative;
  }

  .ai-magazine-featured-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.featured_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-magazine-featured-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.featured_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-magazine-featured-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-magazine-featured-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px 0;
  }

  .ai-magazine-featured-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.featured_title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
    line-height: 1.3;
    font-weight: 700;
  }

  .ai-magazine-featured-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    color: {{ block.settings.muted_color }};
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .ai-magazine-meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.muted_color }};
  }

  .ai-magazine-author-{{ ai_gen_id }} {
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-magazine-date-{{ ai_gen_id }} {
    color: {{ block.settings.muted_color }};
  }

  .ai-magazine-article-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ai-magazine-article-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.article_height }}px;
    object-fit: cover;
    display: block;
    margin-bottom: 16px;
  }

  .ai-magazine-article-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.article_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }

  .ai-magazine-article-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-magazine-article-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.accent_color }};
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .ai-magazine-article-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.article_title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
    line-height: 1.4;
    font-weight: 700;
  }

  .ai-magazine-article-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    color: {{ block.settings.muted_color }};
    line-height: 1.6;
    margin-bottom: 12px;
    flex-grow: 1;
  }

  .ai-magazine-read-more-{{ ai_gen_id }} {
    display: inline-block;
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.accent_color }};
    text-decoration: none;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-magazine-read-more-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  @media screen and (max-width: 749px) {
    .ai-magazine-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-magazine-featured-{{ ai_gen_id }} {
      grid-column: span {{ block.settings.columns_mobile }};
    }

    .ai-magazine-featured-image-{{ ai_gen_id }},
    .ai-magazine-featured-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.featured_height | times: 0.6 }}px;
    }

    .ai-magazine-article-image-{{ ai_gen_id }},
    .ai-magazine-article-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.article_height | times: 0.8 }}px;
    }

    .ai-magazine-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-magazine-featured-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.featured_title_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-magazine-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-magazine-container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-magazine-header-{{ ai_gen_id }}">
        {% if block.settings.category != blank %}
          <div class="ai-magazine-category-{{ ai_gen_id }}">{{ block.settings.category }}</div>
        {% endif %}
        {% if block.settings.title != blank %}
          <h2 class="ai-magazine-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <div class="ai-magazine-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-magazine-grid-{{ ai_gen_id }}">
      {% if block.settings.show_featured %}
        <article class="ai-magazine-featured-{{ ai_gen_id }}">
          {% if block.settings.featured_image %}
            <img
              src="{{ block.settings.featured_image | image_url: width: 1200 }}"
              alt="{{ block.settings.featured_image.alt | escape }}"
              class="ai-magazine-featured-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.featured_image.width }}"
              height="{{ block.settings.featured_image.height }}"
            >
          {% else %}
            <div class="ai-magazine-featured-placeholder-{{ ai_gen_id }}">
              {{ 'hero-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
          <div class="ai-magazine-featured-content-{{ ai_gen_id }}">
            {% if block.settings.featured_title != blank %}
              <h3 class="ai-magazine-featured-title-{{ ai_gen_id }}">{{ block.settings.featured_title }}</h3>
            {% endif %}
            {% if block.settings.featured_excerpt != blank %}
              <div class="ai-magazine-featured-excerpt-{{ ai_gen_id }}">{{ block.settings.featured_excerpt }}</div>
            {% endif %}
            <div class="ai-magazine-meta-{{ ai_gen_id }}">
              {% if block.settings.featured_author != blank %}
                <span class="ai-magazine-author-{{ ai_gen_id }}">{{ block.settings.featured_author }}</span>
              {% endif %}
              {% if block.settings.featured_date != blank %}
                <span class="ai-magazine-date-{{ ai_gen_id }}">{{ block.settings.featured_date }}</span>
              {% endif %}
            </div>
          </div>
        </article>
      {% endif %}

      {% for i in (1..6) %}
        {% liquid
          assign article_enabled_key = 'article_' | append: i | append: '_enabled'
          assign article_image_key = 'article_' | append: i | append: '_image'
          assign article_category_key = 'article_' | append: i | append: '_category'
          assign article_title_key = 'article_' | append: i | append: '_title'
          assign article_excerpt_key = 'article_' | append: i | append: '_excerpt'
          assign article_link_key = 'article_' | append: i | append: '_link'

          assign article_enabled = block.settings[article_enabled_key]
          assign article_image = block.settings[article_image_key]
          assign article_category = block.settings[article_category_key]
          assign article_title = block.settings[article_title_key]
          assign article_excerpt = block.settings[article_excerpt_key]
          assign article_link = block.settings[article_link_key]
        %}

        {% if article_enabled %}
          <article class="ai-magazine-article-{{ ai_gen_id }}">
            {% if article_image %}
              <img
                src="{{ article_image | image_url: width: 600 }}"
                alt="{{ article_image.alt | escape }}"
                class="ai-magazine-article-image-{{ ai_gen_id }}"
                loading="lazy"
                width="{{ article_image.width }}"
                height="{{ article_image.height }}"
              >
            {% else %}
              <div class="ai-magazine-article-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
            {% if article_category != blank %}
              <div class="ai-magazine-article-category-{{ ai_gen_id }}">{{ article_category }}</div>
            {% endif %}
            {% if article_title != blank %}
              <h4 class="ai-magazine-article-title-{{ ai_gen_id }}">{{ article_title }}</h4>
            {% endif %}
            {% if article_excerpt != blank %}
              <div class="ai-magazine-article-excerpt-{{ ai_gen_id }}">{{ article_excerpt }}</div>
            {% endif %}
            {% if article_link != blank %}
              <a href="{{ article_link }}" class="ai-magazine-read-more-{{ ai_gen_id }}">Read More</a>
            {% endif %}
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

