{% doc %}
  @prompt
    Create a Shopify Liquid theme block called "Advertorial Story". Cream background #F5F0EA on all elements. No white backgrounds anywhere. SCHEMA SETTINGS (all editable in theme editor sidebar): "headline" text field, default: "He hid his feet from me for three years."; "star_rating" text field, default: "4.8"; "review_count" text field, default: "1,400+"; "customer_name" text field, default: "SARAH K."; "customer_location" text field, default: "PHOENIX, AZ"; "paragraph_1" textarea; "paragraph_2" textarea; "paragraph_3" textarea; "paragraph_4" textarea; "bold_keyword" text field, default: "goat-milk lactic acid"; "narrative_1" textarea, default: "The next morning he stopped in the kitchen and rubbed one foot against the other."; "pull_quote" text field, default: "Wait. Something's different."; "pull_quote_attr" text field, default: "— HIM, BEFORE COFFEE"; "progress_image" image_picker; "narrative_2" textarea, default: "Three weeks in, he walked out to get the mail. Barefoot. On the driveway.". HTML AND CSS: Section wrapper: background #F5F0EA, padding 0, margin 0. Content wrapper: max-width 480px, margin 0 auto, padding 0 24px. 1.HEADLINE: font-size 32px, font-weight 800, Georgia serif, color #111, line-height 1.2, padding-top 40px. 2.STAR RATING: flex row, gold stars ★★★★★ color #E8A020, 16px; rating text 13px uppercase; customer name/location 11px uppercase #666. 3.BODY PARAGRAPHS: 16px sans-serif #333, line-height 1.75, bold keyword in strong tag. 4.NARRATIVE 1: 26px bold Georgia #111, line-height 1.3, margin 32px 0. 5.PULL QUOTE: border-left 3px solid #111, padding-left 16px, italic 20px Georgia; attribution 11px uppercase #555. 6.PROGRESS IMAGE CRITICAL: container width 100vw, position relative, left 50%, transform translateX(-50%), margin 32px 0, overflow hidden; img width 100%, height auto, display block, object-fit cover. 7.NARRATIVE 2: same as narrative 1, padding-bottom 48px. Fully responsive. No box shadows. No extra borders.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-advertorial-story-{{ ai_gen_id }} {
    background-color: #F5F0EA;
    padding: 0;
    margin: 0;
    display: block;
  }

  .ai-advertorial-story__wrapper-{{ ai_gen_id }} {
    max-width: 480px;
    margin: 0 auto;
    padding: 0 24px;
    background-color: #F5F0EA;
  }

  .ai-advertorial-story__headline-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 800;
    font-family: Georgia, serif;
    color: #111;
    line-height: 1.2;
    padding-top: 40px;
    margin: 0 0 24px 0;
  }

  .ai-advertorial-story__rating-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
  }

  .ai-advertorial-story__stars-{{ ai_gen_id }} {
    color: #E8A020;
    font-size: 16px;
    line-height: 1;
  }

  .ai-advertorial-story__rating-text-{{ ai_gen_id }} {
    font-size: 13px;
    text-transform: uppercase;
    color: #111;
    font-weight: 600;
  }

  .ai-advertorial-story__customer-info-{{ ai_gen_id }} {
    font-size: 11px;
    text-transform: uppercase;
    color: #666;
    margin-top: 8px;
  }

  .ai-advertorial-story__paragraph-{{ ai_gen_id }} {
    font-size: 16px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    color: #333;
    line-height: 1.75;
    margin-bottom: 16px;
  }

  .ai-advertorial-story__narrative-{{ ai_gen_id }} {
    font-size: 26px;
    font-weight: bold;
    font-family: Georgia, serif;
    color: #111;
    line-height: 1.3;
    margin: 32px 0;
  }

  .ai-advertorial-story__pull-quote-{{ ai_gen_id }} {
    border-left: 3px solid #111;
    padding-left: 16px;
    margin: 32px 0;
  }

  .ai-advertorial-story__pull-quote-text-{{ ai_gen_id }} {
    font-style: italic;
    font-size: 20px;
    font-family: Georgia, serif;
    color: #111;
    line-height: 1.4;
    margin: 0 0 8px 0;
  }

  .ai-advertorial-story__pull-quote-attr-{{ ai_gen_id }} {
    font-size: 11px;
    text-transform: uppercase;
    color: #555;
    font-style: normal;
  }

  .ai-advertorial-story__image-container-{{ ai_gen_id }} {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    margin: 32px 0;
    overflow: hidden;
    background-color: #F5F0EA;
  }

  .ai-advertorial-story__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-advertorial-story__narrative-final-{{ ai_gen_id }} {
    font-size: 26px;
    font-weight: bold;
    font-family: Georgia, serif;
    color: #111;
    line-height: 1.3;
    margin: 32px 0;
    padding-bottom: 48px;
  }
{% endstyle %}

<advertorial-story-{{ ai_gen_id }} class="ai-advertorial-story-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-advertorial-story__wrapper-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h1 class="ai-advertorial-story__headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
    {% endif %}

    <div class="ai-advertorial-story__rating-container-{{ ai_gen_id }}">
      <div class="ai-advertorial-story__stars-{{ ai_gen_id }}">★★★★★</div>
      {% if block.settings.star_rating != blank %}
        <div class="ai-advertorial-story__rating-text-{{ ai_gen_id }}">{{ block.settings.star_rating }}</div>
      {% endif %}
      {% if block.settings.review_count != blank %}
        <div class="ai-advertorial-story__rating-text-{{ ai_gen_id }}">({{ block.settings.review_count }} REVIEWS)</div>
      {% endif %}
    </div>

    {% if block.settings.customer_name != blank or block.settings.customer_location != blank %}
      <div class="ai-advertorial-story__customer-info-{{ ai_gen_id }}">
        {% if block.settings.customer_name != blank %}{{ block.settings.customer_name }}{% endif %}
        {% if block.settings.customer_name != blank and block.settings.customer_location != blank %} · {% endif %}
        {% if block.settings.customer_location != blank %}{{ block.settings.customer_location }}{% endif %}
      </div>
    {% endif %}

    {% if block.settings.paragraph_1 != blank %}
      <div class="ai-advertorial-story__paragraph-{{ ai_gen_id }}">
        {{ block.settings.paragraph_1 | newline_to_br }}
      </div>
    {% endif %}

    {% if block.settings.paragraph_2 != blank %}
      <div class="ai-advertorial-story__paragraph-{{ ai_gen_id }}">
        {% if block.settings.bold_keyword != blank %}
          {% assign p2_with_bold = block.settings.paragraph_2 | replace: block.settings.bold_keyword, '<strong>' | append: block.settings.bold_keyword | append: '</strong>' %}
          {{ p2_with_bold | newline_to_br }}
        {% else %}
          {{ block.settings.paragraph_2 | newline_to_br }}
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.paragraph_3 != blank %}
      <div class="ai-advertorial-story__paragraph-{{ ai_gen_id }}">
        {{ block.settings.paragraph_3 | newline_to_br }}
      </div>
    {% endif %}

    {% if block.settings.paragraph_4 != blank %}
      <div class="ai-advertorial-story__paragraph-{{ ai_gen_id }}">
        {{ block.settings.paragraph_4 | newline_to_br }}
      </div>
    {% endif %}

    {% if block.settings.narrative_1 != blank %}
      <div class="ai-advertorial-story__narrative-{{ ai_gen_id }}">
        {{ block.settings.narrative_1 }}
      </div>
    {% endif %}

    {% if block.settings.pull_quote != blank %}
      <div class="ai-advertorial-story__pull-quote-{{ ai_gen_id }}">
        <div class="ai-advertorial-story__pull-quote-text-{{ ai_gen_id }}">{{ block.settings.pull_quote }}</div>
        {% if block.settings.pull_quote_attr != blank %}
          <div class="ai-advertorial-story__pull-quote-attr-{{ ai_gen_id }}">{{ block.settings.pull_quote_attr }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.progress_image != blank %}
      <div class="ai-advertorial-story__image-container-{{ ai_gen_id }}">
        <img
          src="{{ block.settings.progress_image | image_url: width: 1200 }}"
          alt="{{ block.settings.progress_image.alt | escape }}"
          class="ai-advertorial-story__image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.progress_image.width }}"
          height="{{ block.settings.progress_image.height }}"
        >
      </div>
    {% endif %}

    {% if block.settings.narrative_2 != blank %}
      <div class="ai-advertorial-story__narrative-final-{{ ai_gen_id }}">
        {{ block.settings.narrative_2 }}
      </div>
    {% endif %}
  </div>
</advertorial-story-{{ ai_gen_id }}>

<script>
  (function() {
    class AdvertorialStory{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('advertorial-story-{{ ai_gen_id }}', AdvertorialStory{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Advertorial story",
  "settings": [
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "He hid his feet from me for three years."
    },
    {
      "type": "header",
      "content": "Rating"
    },
    {
      "type": "text",
      "id": "star_rating",
      "label": "Star rating",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count",
      "default": "1,400+"
    },
    {
      "type": "text",
      "id": "customer_name",
      "label": "Customer name",
      "default": "SARAH K."
    },
    {
      "type": "text",
      "id": "customer_location",
      "label": "Customer location",
      "default": "PHOENIX, AZ"
    },
    {
      "type": "header",
      "content": "Body paragraphs"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragraph 1"
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragraph 2"
    },
    {
      "type": "text",
      "id": "bold_keyword",
      "label": "Bold keyword",
      "default": "goat-milk lactic acid"
    },
    {
      "type": "textarea",
      "id": "paragraph_3",
      "label": "Paragraph 3"
    },
    {
      "type": "textarea",
      "id": "paragraph_4",
      "label": "Paragraph 4"
    },
    {
      "type": "header",
      "content": "Narrative sections"
    },
    {
      "type": "textarea",
      "id": "narrative_1",
      "label": "Narrative 1",
      "default": "The next morning he stopped in the kitchen and rubbed one foot against the other."
    },
    {
      "type": "header",
      "content": "Pull quote"
    },
    {
      "type": "text",
      "id": "pull_quote",
      "label": "Pull quote",
      "default": "Wait. Something's different."
    },
    {
      "type": "text",
      "id": "pull_quote_attr",
      "label": "Pull quote attribution",
      "default": "— HIM, BEFORE COFFEE"
    },
    {
      "type": "header",
      "content": "Progress image"
    },
    {
      "type": "image_picker",
      "id": "progress_image",
      "label": "Progress image"
    },
    {
      "type": "header",
      "content": "Final narrative"
    },
    {
      "type": "textarea",
      "id": "narrative_2",
      "label": "Narrative 2",
      "default": "Three weeks in, he walked out to get the mail. Barefoot. On the driveway."
    }
  ],
  "presets": [
    {
      "name": "Advertorial story"
    }
  ]
}
{% endschema %}
