{% doc %}
  @prompt
    Create a Shopify Liquid theme block called "Product Hero CTA". Cream background #F5F0EA throughout. No white backgrounds. SCHEMA SETTINGS: "product_image" image_picker; "cta_left_text" text default "SHOP THE FOOT MASK"; "cta_right_text" text default "FROM $19.99"; "cta_url" url; "trust_line" text default "30-DAY MONEY-BACK · FREE SHIPPING ON 5-PACK"; "badge_1_title" default "Pregnancy & diabetes safe"; "badge_1_desc" default "No salicylic acid"; "badge_2_title" default "30 days, no questions"; "badge_2_desc" default "Money-back refund"; "badge_3_title" default "Free US shipping"; "badge_3_desc" default "On orders over $50". HTML AND CSS: 1.PRODUCT IMAGE: container width 100vw, position relative, left 50%, transform translateX(-50%), overflow hidden, padding 0, margin 0; img width 100%, height auto, display block, object-fit cover. 2.CTA BAR: full width, background #111, color #fff, display flex, justify-content space-between, align-items center, padding 18px 20px; left text 14px bold uppercase letter-spacing 0.08em; right text "FROM $19.99 →" 14px font-weight 600; entire bar is anchor tag linking to cta_url; no border radius. 3.TRUST LINE: 11px uppercase letter-spacing 0.08em color #333, padding 14px 20px, border-bottom 1px solid #ddd. 4.TRUST BADGES: grid 3 columns, each badge padding 16px 12px, border-right 1px solid #ddd (last none); SVG icon 20px (heart, circular arrow, truck); title 13px bold #111; desc 12px #666. Background #F5F0EA. Fully responsive.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-hero-cta-{{ ai_gen_id }} {
    display: block;
    background-color: #F5F0EA;
    width: 100%;
  }

  .ai-product-hero-cta__image-container-{{ ai_gen_id }} {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    overflow: hidden;
    padding: 0;
    margin: 0;
  }

  .ai-product-hero-cta__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-product-hero-cta__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #e8e3dd;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 400px;
  }

  .ai-product-hero-cta__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-product-hero-cta__cta-bar-{{ ai_gen_id }} {
    width: 100%;
    background-color: #111;
    color: #fff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 20px;
    text-decoration: none;
    border-radius: 0;
  }

  .ai-product-hero-cta__cta-bar-{{ ai_gen_id }}:hover {
    background-color: #000;
  }

  .ai-product-hero-cta__cta-left-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
  }

  .ai-product-hero-cta__cta-right-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: #fff;
  }

  .ai-product-hero-cta__trust-line-{{ ai_gen_id }} {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #333;
    padding: 14px 20px;
    border-bottom: 1px solid #ddd;
    background-color: #F5F0EA;
    text-align: center;
  }

  .ai-product-hero-cta__badges-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background-color: #F5F0EA;
  }

  .ai-product-hero-cta__badge-{{ ai_gen_id }} {
    padding: 16px 12px;
    border-right: 1px solid #ddd;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
  }

  .ai-product-hero-cta__badge-{{ ai_gen_id }}:last-child {
    border-right: none;
  }

  .ai-product-hero-cta__badge-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    color: #111;
  }

  .ai-product-hero-cta__badge-title-{{ ai_gen_id }} {
    font-size: 13px;
    font-weight: 700;
    color: #111;
    margin: 0;
  }

  .ai-product-hero-cta__badge-desc-{{ ai_gen_id }} {
    font-size: 12px;
    color: #666;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-product-hero-cta__badges-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-product-hero-cta__badge-{{ ai_gen_id }} {
      border-right: none;
      border-bottom: 1px solid #ddd;
    }

    .ai-product-hero-cta__badge-{{ ai_gen_id }}:last-child {
      border-bottom: none;
    }

    .ai-product-hero-cta__cta-left-{{ ai_gen_id }} {
      font-size: 12px;
    }

    .ai-product-hero-cta__cta-right-{{ ai_gen_id }} {
      font-size: 12px;
    }
  }
{% endstyle %}

<div class="ai-product-hero-cta-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-hero-cta__image-container-{{ ai_gen_id }}">
    {% if block.settings.product_image %}
      <img
        src="{{ block.settings.product_image | image_url: width: 2000 }}"
        alt="{{ block.settings.product_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.product_image.width }}"
        height="{{ block.settings.product_image.height }}"
        class="ai-product-hero-cta__image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-product-hero-cta__image-placeholder-{{ ai_gen_id }}">
        {{ 'product-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  {% if block.settings.cta_url != blank %}
    <a href="{{ block.settings.cta_url }}" class="ai-product-hero-cta__cta-bar-{{ ai_gen_id }}">
      <span class="ai-product-hero-cta__cta-left-{{ ai_gen_id }}">{{ block.settings.cta_left_text }}</span>
      <span class="ai-product-hero-cta__cta-right-{{ ai_gen_id }}">{{ block.settings.cta_right_text }} →</span>
    </a>
  {% else %}
    <div class="ai-product-hero-cta__cta-bar-{{ ai_gen_id }}">
      <span class="ai-product-hero-cta__cta-left-{{ ai_gen_id }}">{{ block.settings.cta_left_text }}</span>
      <span class="ai-product-hero-cta__cta-right-{{ ai_gen_id }}">{{ block.settings.cta_right_text }} →</span>
    </div>
  {% endif %}

  {% if block.settings.trust_line != blank %}
    <div class="ai-product-hero-cta__trust-line-{{ ai_gen_id }}">
      {{ block.settings.trust_line }}
    </div>
  {% endif %}

  <div class="ai-product-hero-cta__badges-{{ ai_gen_id }}">
    <div class="ai-product-hero-cta__badge-{{ ai_gen_id }}">
      <svg class="ai-product-hero-cta__badge-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
      <p class="ai-product-hero-cta__badge-title-{{ ai_gen_id }}">{{ block.settings.badge_1_title }}</p>
      <p class="ai-product-hero-cta__badge-desc-{{ ai_gen_id }}">{{ block.settings.badge_1_desc }}</p>
    </div>

    <div class="ai-product-hero-cta__badge-{{ ai_gen_id }}">
      <svg class="ai-product-hero-cta__badge-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="23 4 23 10 17 10"></polyline>
        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
      </svg>
      <p class="ai-product-hero-cta__badge-title-{{ ai_gen_id }}">{{ block.settings.badge_2_title }}</p>
      <p class="ai-product-hero-cta__badge-desc-{{ ai_gen_id }}">{{ block.settings.badge_2_desc }}</p>
    </div>

    <div class="ai-product-hero-cta__badge-{{ ai_gen_id }}">
      <svg class="ai-product-hero-cta__badge-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="1" y="3" width="15" height="13"></rect>
        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
        <circle cx="5.5" cy="18.5" r="2.5"></circle>
        <circle cx="18.5" cy="18.5" r="2.5"></circle>
      </svg>
      <p class="ai-product-hero-cta__badge-title-{{ ai_gen_id }}">{{ block.settings.badge_3_title }}</p>
      <p class="ai-product-hero-cta__badge-desc-{{ ai_gen_id }}">{{ block.settings.badge_3_desc }}</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product hero CTA",
  "settings": [
    {
      "type": "header",
      "content": "Product image"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "header",
      "content": "CTA bar"
    },
    {
      "type": "text",
      "id": "cta_left_text",
      "label": "Left text",
      "default": "SHOP THE FOOT MASK"
    },
    {
      "type": "text",
      "id": "cta_right_text",
      "label": "Right text",
      "default": "FROM $19.99"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Trust line"
    },
    {
      "type": "text",
      "id": "trust_line",
      "label": "Trust line text",
      "default": "30-DAY MONEY-BACK · FREE SHIPPING ON 5-PACK"
    },
    {
      "type": "header",
      "content": "Badge 1"
    },
    {
      "type": "text",
      "id": "badge_1_title",
      "label": "Title",
      "default": "Pregnancy & diabetes safe"
    },
    {
      "type": "text",
      "id": "badge_1_desc",
      "label": "Description",
      "default": "No salicylic acid"
    },
    {
      "type": "header",
      "content": "Badge 2"
    },
    {
      "type": "text",
      "id": "badge_2_title",
      "label": "Title",
      "default": "30 days, no questions"
    },
    {
      "type": "text",
      "id": "badge_2_desc",
      "label": "Description",
      "default": "Money-back refund"
    },
    {
      "type": "header",
      "content": "Badge 3"
    },
    {
      "type": "text",
      "id": "badge_3_title",
      "label": "Title",
      "default": "Free US shipping"
    },
    {
      "type": "text",
      "id": "badge_3_desc",
      "label": "Description",
      "default": "On orders over $50"
    }
  ],
  "presets": [
    {
      "name": "Product hero CTA"
    }
  ]
}
{% endschema %}
