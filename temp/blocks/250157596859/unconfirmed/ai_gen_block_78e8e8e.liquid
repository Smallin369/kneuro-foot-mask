{% doc %}
  @prompt
    Create a Shopify Liquid theme block called "Before After Gallery". Cream background #F5F0EA throughout. No white backgrounds. CRITICAL: auto-scrolling photo gallery using CSS animation infinite scroll loop. SCHEMA: trust_line text default "1,400+ VERIFIED BUYERS · 4.8 ★"; headline text default "Before. After. Believe it."; subtext text default "Real customer photos. Submitted, unedited. Same heel, 30 minutes apart."; reviews_url url; reviews_button_text default "READ ALL 1,400+ REVIEWS →"; image_1 through image_6 image_picker; image_1_label through image_6_label text alternating BEFORE/AFTER. HTML ORDER: 1.TRUST LINE div style="font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#8B4513;padding:20px 20px 8px;background:#F5F0EA". 2.HEADLINE h2 style="font-size:36px;font-weight:800;font-family:Georgia,serif;color:#111;line-height:1.1;padding:0 20px;margin:0 0 12px;background:#F5F0EA". 3.SUBTEXT p style="font-size:15px;color:#444;line-height:1.6;padding:0 20px;margin:0 0 24px;background:#F5F0EA". 4.AUTO-SCROLL GALLERY: outer wrapper overflow:hidden width:100%; inner track display:flex gap:4px animation:scroll-left 20s linear infinite; duplicate all images twice for seamless loop; each image item position:relative flex-shrink:0 width:160px height:200px overflow:hidden; img width:100% height:100% object-fit:cover; label overlay position:absolute top:8px left:8px background:#111 color:#fff font-size:10px font-weight:700 padding:4px 8px uppercase; CSS keyframes scroll-left 0% translateX(0) 100% translateX(-50%). 5.REVIEWS BUTTON full-width outlined dark border #111 centered text uppercase 12px bold padding 16px 20px background #F5F0EA.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-before-after-gallery-{{ ai_gen_id }} {
    width: 100%;
    background: #F5F0EA;
  }

  .ai-before-after-trust-{{ ai_gen_id }} {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #8B4513;
    padding: 20px 20px 8px;
    background: #F5F0EA;
  }

  .ai-before-after-headline-{{ ai_gen_id }} {
    font-size: 36px;
    font-weight: 800;
    font-family: Georgia, serif;
    color: #111;
    line-height: 1.1;
    padding: 0 20px;
    margin: 0 0 12px;
    background: #F5F0EA;
  }

  .ai-before-after-subtext-{{ ai_gen_id }} {
    font-size: 15px;
    color: #444;
    line-height: 1.6;
    padding: 0 20px;
    margin: 0 0 24px;
    background: #F5F0EA;
  }

  .ai-before-after-gallery-wrapper-{{ ai_gen_id }} {
    overflow: hidden;
    width: 100%;
    background: #F5F0EA;
    margin-bottom: 24px;
  }

  .ai-before-after-gallery-track-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    animation: ai-scroll-left-{{ ai_gen_id }} 20s linear infinite;
  }

  .ai-before-after-gallery-item-{{ ai_gen_id }} {
    position: relative;
    flex-shrink: 0;
    width: 160px;
    height: 200px;
    overflow: hidden;
  }

  .ai-before-after-gallery-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-before-after-gallery-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #E5DDD5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-before-after-gallery-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
  }

  .ai-before-after-label-{{ ai_gen_id }} {
    position: absolute;
    top: 8px;
    left: 8px;
    background: #111;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    padding: 4px 8px;
    text-transform: uppercase;
  }

  .ai-before-after-button-{{ ai_gen_id }} {
    width: 100%;
    text-align: center;
    text-transform: uppercase;
    font-size: 12px;
    font-weight: 700;
    padding: 16px 20px;
    background: #F5F0EA;
    border: 2px solid #111;
    color: #111;
    text-decoration: none;
    display: block;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .ai-before-after-button-{{ ai_gen_id }}:hover {
    background: #111;
    color: #fff;
  }

  @keyframes ai-scroll-left-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
{% endstyle %}

<div class="ai-before-after-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-before-after-trust-{{ ai_gen_id }}">
    {{ block.settings.trust_line }}
  </div>

  <h2 class="ai-before-after-headline-{{ ai_gen_id }}">
    {{ block.settings.headline }}
  </h2>

  <p class="ai-before-after-subtext-{{ ai_gen_id }}">
    {{ block.settings.subtext }}
  </p>

  <div class="ai-before-after-gallery-wrapper-{{ ai_gen_id }}">
    <div class="ai-before-after-gallery-track-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% assign image_key = 'image_' | append: i %}
        {% assign label_key = 'image_' | append: i | append: '_label' %}
        {% assign image = block.settings[image_key] %}
        {% assign label = block.settings[label_key] %}

        <div class="ai-before-after-gallery-item-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 320 }}"
              alt="{{ label | escape }}"
              loading="lazy"
              width="160"
              height="200"
            >
          {% else %}
            <div class="ai-before-after-gallery-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
          {% if label != blank %}
            <div class="ai-before-after-label-{{ ai_gen_id }}">{{ label }}</div>
          {% endif %}
        </div>
      {% endfor %}

      {% for i in (1..6) %}
        {% assign image_key = 'image_' | append: i %}
        {% assign label_key = 'image_' | append: i | append: '_label' %}
        {% assign image = block.settings[image_key] %}
        {% assign label = block.settings[label_key] %}

        <div class="ai-before-after-gallery-item-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 320 }}"
              alt="{{ label | escape }}"
              loading="lazy"
              width="160"
              height="200"
            >
          {% else %}
            <div class="ai-before-after-gallery-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
          {% if label != blank %}
            <div class="ai-before-after-label-{{ ai_gen_id }}">{{ label }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>

  {% if block.settings.reviews_url != blank %}
    <a href="{{ block.settings.reviews_url }}" class="ai-before-after-button-{{ ai_gen_id }}">
      {{ block.settings.reviews_button_text }}
    </a>
  {% else %}
    <div class="ai-before-after-button-{{ ai_gen_id }}" style="cursor: default; opacity: 0.5;">
      {{ block.settings.reviews_button_text }}
    </div>
  {% endif %}
</div>

