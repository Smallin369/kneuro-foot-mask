<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#0a0a0a">
  <title>{{ page_title }}</title>
  {%- if page_description != blank -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- elsif template.name == 'index' -%}
    <meta name="description" content="Goat milk + niacinamide foot mask. Softens cracked heels in 30 minutes — no harsh acids, no painful peel. Pregnancy-safe, dermatologist-tested. From $19.99.">
  {%- elsif template.name == 'product' and product.description != blank -%}
    <meta name="description" content="{{ product.description | strip_html | truncate: 155 | escape }}">
  {%- endif -%}
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="dns-prefetch" href="https://connect.facebook.net">

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <style>
    :root {
      --cream: #f4eee5;
      --cream-soft: #faf5ec;
      --surface: #ffffff;
      --ink: #0f0f0f;
      --ink-2: #2a2a2a;
      --muted: #6a6a6a;
      --line: #e8e3da;
      /* Charcoal minimal brand system */
      --accent: #0f0f0f;
      --accent-deep: #000000;
      --accent-soft: #ECE4DC;
      --accent-glaze: rgba(15, 15, 15, 0.08);
      --sage: #0f0f0f;
      --rose: #ECE4DC;
      --font-heading: 'Manrope', 'Manrope Fallback', -apple-system, BlinkMacSystemFont, sans-serif;
      --font-body: 'Inter', 'Inter Fallback', -apple-system, BlinkMacSystemFont, sans-serif;
    }
    body { background: #ffffff; }
  </style>

  <link rel="preload" as="font" type="font/woff2" href="{{ 'manrope-var-latin.woff2' | asset_url }}" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="{{ 'inter-var-latin.woff2' | asset_url }}" crossorigin>
  <style>
    @font-face{font-family:'Manrope';font-style:normal;font-weight:400 800;font-display:swap;src:url('{{ "manrope-var-latin.woff2" | asset_url }}') format('woff2-variations'),url('{{ "manrope-var-latin.woff2" | asset_url }}') format('woff2');}
    @font-face{font-family:'Inter';font-style:normal;font-weight:400 700;font-display:swap;src:url('{{ "inter-var-latin.woff2" | asset_url }}') format('woff2-variations'),url('{{ "inter-var-latin.woff2" | asset_url }}') format('woff2');}
    @font-face{font-family:'Manrope Fallback';src:local('Arial');size-adjust:100.5%;ascent-override:99%;descent-override:31%;line-gap-override:0%;}
    @font-face{font-family:'Inter Fallback';src:local('Arial');size-adjust:107.4%;ascent-override:90%;descent-override:22.43%;line-gap-override:0%;}
  </style>

  {%- if template contains 'product' and product.featured_image -%}
    <link rel="preload" as="image"
          href="{{ product.featured_image | image_url: width: 900, format: 'webp' }}"
          imagesrcset="{{ product.featured_image | image_url: width: 600, format: 'webp' }} 600w, {{ product.featured_image | image_url: width: 900, format: 'webp' }} 900w, {{ product.featured_image | image_url: width: 1200, format: 'webp' }} 1200w"
          imagesizes="(max-width: 768px) 100vw, 600px"
          fetchpriority="high">
  {%- endif -%}

  <script src="{{ 'theme.js' | asset_url }}" type="module" defer></script>

  {{ content_for_header }}
</head>
<body>
  {% section 'reading-progress' %}
  {%- unless template.suffix == 'quick-sell' -%}
    {% section 'site-header' %}
  {%- endunless -%}
  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>
  {% section 'site-footer' %}
  {% section 'exit-popup' %}
  {%- unless template contains 'cart' or template contains 'customers' -%}
    {% section 'sticky-mobile-cta' %}
  {%- endunless -%}
</body>
</html>
