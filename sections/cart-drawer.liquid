<div id="cartDrawer" class="cd" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="cdHeading">
  <div class="cd__backdrop" data-cd-close></div>
  <aside class="cd__panel" tabindex="-1">
    <header class="cd__head">
      <h2 id="cdHeading" class="cd__title">Your cart <span class="cd__count" data-cd-count>0</span></h2>
      <button type="button" class="cd__close" aria-label="Close cart" data-cd-close>×</button>
    </header>

    <div class="cd__body" data-cd-body>
      <p class="cd__empty" data-cd-empty>Your cart is empty.</p>
      <ul class="cd__items" data-cd-items hidden></ul>
    </div>

    <footer class="cd__foot">
      <div class="cd__row">
        <span>Subtotal</span>
        <span class="cd__subtotal" data-cd-subtotal>$0.00</span>
      </div>
      <p class="cd__note">Shipping calculated at checkout · 30-day money-back</p>
      <a href="/checkout" class="cd__checkout" data-cd-checkout>Checkout →</a>
    </footer>
  </aside>
</div>

<style>
  .cd { position: fixed; inset: 0; z-index: 300; visibility: hidden; }
  .cd[aria-hidden="false"] { visibility: visible; }
  .cd__backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.4); opacity: 0; transition: opacity .25s; }
  .cd[aria-hidden="false"] .cd__backdrop { opacity: 1; }
  .cd__panel { position: absolute; top: 0; right: 0; height: 100%; width: 420px; max-width: 92vw; background: #fff; transform: translateX(100%); transition: transform .3s cubic-bezier(.2,.9,.3,1); display: flex; flex-direction: column; box-shadow: -8px 0 24px rgba(0,0,0,0.08); }
  .cd[aria-hidden="false"] .cd__panel { transform: translateX(0); }
  .cd__head { display: flex; align-items: center; justify-content: space-between; padding: 18px 20px; border-bottom: 1px solid var(--line, #ececec); flex-shrink: 0; }
  .cd__title { font-family: var(--font-heading); font-size: 17px; font-weight: 700; margin: 0; color: var(--ink); }
  .cd__count { font-weight: 400; color: var(--muted); font-size: 14px; margin-left: 4px; }
  .cd__close { background: transparent; border: 0; font-size: 28px; line-height: 1; color: var(--ink); cursor: pointer; padding: 0 4px; }
  .cd__body { flex: 1; overflow-y: auto; padding: 8px 20px 20px; }
  .cd__empty { font-family: var(--font-body); color: var(--muted); text-align: center; padding: 40px 0; }
  .cd__items { list-style: none; padding: 0; margin: 0; }
  .cd__item { display: grid; grid-template-columns: 64px 1fr auto; gap: 12px; padding: 14px 0; border-bottom: 1px solid var(--line, #ececec); align-items: center; }
  .cd__item-img img { width: 64px; height: 64px; object-fit: cover; border-radius: 8px; display: block; background: var(--cream-soft); }
  .cd__item-name { font-family: var(--font-body); font-size: 14px; font-weight: 600; color: var(--ink); margin: 0 0 2px; line-height: 1.3; }
  .cd__item-variant { font-size: 12px; color: var(--muted); margin: 0 0 6px; }
  .cd__item-qty { display: inline-flex; align-items: center; gap: 6px; }
  .cd__qbtn { width: 22px; height: 22px; border: 1px solid var(--line); background: #fff; cursor: pointer; border-radius: 4px; font-size: 14px; line-height: 1; }
  .cd__qval { font-size: 13px; min-width: 20px; text-align: center; }
  .cd__item-price { font-family: var(--font-body); font-size: 14px; font-weight: 600; color: var(--ink); }
  .cd__item-remove { display: block; font-size: 11px; color: var(--muted); background: transparent; border: 0; cursor: pointer; padding: 4px 0 0; text-decoration: underline; text-align: left; }
  .cd__foot { padding: 16px 20px max(16px, env(safe-area-inset-bottom)); border-top: 1px solid var(--line, #ececec); flex-shrink: 0; background: #fff; }
  .cd__row { display: flex; justify-content: space-between; font-family: var(--font-body); font-size: 15px; font-weight: 600; color: var(--ink); margin-bottom: 6px; }
  .cd__note { font-family: var(--font-body); font-size: 12px; color: var(--muted); margin: 0 0 12px; }
  .cd__checkout { display: block; padding: 14px 20px; background: var(--accent, #0a0a0a); color: #fff; text-align: center; text-decoration: none; font-family: var(--font-body); font-size: 15px; font-weight: 600; border-radius: 999px; }
  .cd__checkout:hover { background: var(--accent-deep, #2a2a2a); }
  .cd__checkout[aria-disabled="true"] { opacity: .5; pointer-events: none; }
</style>

<script>
(function() {
  var drawer = document.getElementById('cartDrawer');
  if (!drawer) return;
  var body = drawer.querySelector('[data-cd-body]');
  var emptyEl = drawer.querySelector('[data-cd-empty]');
  var itemsEl = drawer.querySelector('[data-cd-items]');
  var subtotalEl = drawer.querySelector('[data-cd-subtotal]');
  var countEl = drawer.querySelector('[data-cd-count]');
  var checkoutBtn = drawer.querySelector('[data-cd-checkout]');
  var lastFocus = null;

  function fmt(cents) {
    return '$' + (cents / 100).toFixed(2);
  }

  function open() {
    lastFocus = document.activeElement;
    drawer.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    var panel = drawer.querySelector('.cd__panel');
    if (panel) panel.focus();
  }
  function close() {
    drawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (lastFocus && lastFocus.focus) lastFocus.focus();
  }

  drawer.querySelectorAll('[data-cd-close]').forEach(function(el) {
    el.addEventListener('click', function(e) { e.preventDefault(); close(); });
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && drawer.getAttribute('aria-hidden') === 'false') close();
  });

  function render(cart) {
    countEl.textContent = cart.item_count;
    subtotalEl.textContent = fmt(cart.total_price);
    if (cart.item_count === 0) {
      emptyEl.hidden = false;
      itemsEl.hidden = true;
      itemsEl.innerHTML = '';
      checkoutBtn.setAttribute('aria-disabled', 'true');
      return;
    }
    emptyEl.hidden = true;
    itemsEl.hidden = false;
    checkoutBtn.removeAttribute('aria-disabled');
    itemsEl.innerHTML = cart.items.map(function(it) {
      var imgUrl = it.image ? it.image.replace(/(\.[^.]+)$/, '_64x64$1') : '';
      var variantLine = it.variant_title && it.variant_title !== 'Default Title' ? '<p class="cd__item-variant">' + it.variant_title + '</p>' : '';
      return ''
        + '<li class="cd__item" data-key="' + it.key + '">'
        +   '<div class="cd__item-img">'
        +     (imgUrl ? '<img src="' + imgUrl + '" alt="" loading="lazy">' : '')
        +   '</div>'
        +   '<div>'
        +     '<p class="cd__item-name">' + it.product_title + '</p>'
        +     variantLine
        +     '<div class="cd__item-qty">'
        +       '<button type="button" class="cd__qbtn" data-cd-dec aria-label="Decrease">−</button>'
        +       '<span class="cd__qval">' + it.quantity + '</span>'
        +       '<button type="button" class="cd__qbtn" data-cd-inc aria-label="Increase">+</button>'
        +     '</div>'
        +     '<button type="button" class="cd__item-remove" data-cd-remove>Remove</button>'
        +   '</div>'
        +   '<div class="cd__item-price">' + fmt(it.final_line_price) + '</div>'
        + '</li>';
    }).join('');
  }

  function fetchCart() {
    return fetch('/cart.js', { credentials: 'same-origin' }).then(function(r) { return r.json(); });
  }

  function updateLine(key, qty) {
    return fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ id: key, quantity: qty })
    }).then(function(r) { return r.json(); });
  }

  itemsEl.addEventListener('click', function(e) {
    var li = e.target.closest('.cd__item');
    if (!li) return;
    var key = li.dataset.key;
    var qval = li.querySelector('.cd__qval');
    var current = parseInt(qval.textContent, 10);
    if (e.target.matches('[data-cd-inc]')) {
      updateLine(key, current + 1).then(render);
    } else if (e.target.matches('[data-cd-dec]')) {
      updateLine(key, Math.max(0, current - 1)).then(render);
    } else if (e.target.matches('[data-cd-remove]')) {
      updateLine(key, 0).then(render);
    }
  });

  // Update header cart counts site-wide
  function syncHeaderCount(count) {
    document.querySelectorAll('[data-cart-count]').forEach(function(el) { el.textContent = count; });
  }

  // Intercept all add-to-cart forms
  document.addEventListener('submit', function(e) {
    var form = e.target;
    if (!form || !form.matches) return;
    var action = (form.getAttribute('action') || '').toLowerCase();
    if (!action.endsWith('/cart/add')) return;
    e.preventDefault();
    var formData = new FormData(form);
    var btn = form.querySelector('button[type="submit"], [type="submit"]');
    var origLabel = btn ? btn.textContent : '';
    if (btn) { btn.disabled = true; btn.textContent = 'Adding…'; }

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      credentials: 'same-origin',
      body: formData
    })
    .then(function(r) { return r.json(); })
    .then(function() { return fetchCart(); })
    .then(function(cart) {
      render(cart);
      syncHeaderCount(cart.item_count);
      open();
    })
    .catch(function() {
      // Fall back to native form submission on error
      form.submit();
    })
    .finally(function() {
      if (btn) { btn.disabled = false; btn.textContent = origLabel; }
    });
  });

  // Intercept clicks on /cart links to open drawer instead of navigating
  document.addEventListener('click', function(e) {
    var a = e.target.closest('a[href]');
    if (!a) return;
    var href = a.getAttribute('href') || '';
    if (href === '/cart' || href === '/cart/') {
      e.preventDefault();
      fetchCart().then(render).then(open);
    }
  });

  // Initial state
  fetchCart().then(function(cart) {
    syncHeaderCount(cart.item_count);
    render(cart);
  });
})();
</script>

{% schema %}
{
  "name": "Cart drawer",
  "settings": [],
  "presets": [{ "name": "Cart drawer" }]
}
{% endschema %}
