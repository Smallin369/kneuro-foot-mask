{%- liquid
  assign cta_url = section.settings.cta_url | default: '/products/goat-milk-callus-mask'
-%}
<section class="adv-hero" style="padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px; background:{{ section.settings.bg | default: 'transparent' }};">
  <div class="adv-hero__inner">

    {% if section.settings.publication != blank or section.settings.category != blank %}
      <div class="adv-hero__pub">
        {% if section.settings.publication != blank %}<span class="adv-hero__pub-name">{{ section.settings.publication }}</span>{% endif %}
        {% if section.settings.category != blank %}<span class="adv-hero__pub-cat">{{ section.settings.category }}</span>{% endif %}
      </div>
    {% endif %}

    <h1 class="adv-hero__title">{{ section.settings.headline }}</h1>

    {% if section.settings.subhead != blank %}
      <p class="adv-hero__sub">{{ section.settings.subhead }}</p>
    {% endif %}

    {% if section.settings.byline != blank or section.settings.date != blank or section.settings.read_time != blank %}
      <div class="adv-hero__byline">
        {% if section.settings.byline != blank %}<span>By <strong>{{ section.settings.byline }}</strong></span>{% endif %}
        {% if section.settings.date != blank %}<span>· {{ section.settings.date }}</span>{% endif %}
        {% if section.settings.read_time != blank %}<span>· {{ section.settings.read_time }}</span>{% endif %}
      </div>
    {% endif %}

    {% if section.settings.hero_image %}
      <figure class="adv-hero__fig">
        <img class="adv-hero__img" src="{{ section.settings.hero_image | image_url: width: 1200, format: 'webp' }}" srcset="{{ section.settings.hero_image | image_url: width: 600, format: 'webp' }} 600w, {{ section.settings.hero_image | image_url: width: 1200, format: 'webp' }} 1200w" sizes="(max-width:768px) 100vw, 720px" alt="{{ section.settings.headline | escape }}" width="900" height="900" fetchpriority="high">
        {% if section.settings.caption != blank %}<figcaption class="adv-hero__caption">{{ section.settings.caption }}</figcaption>{% endif %}
      </figure>
    {% endif %}

  </div>
</section>

<style>
  .adv-hero { background: #ffffff; }
  .adv-hero__inner { max-width: 680px; margin: 0 auto; padding: 0 20px; }
  .adv-hero__pub { display:flex; align-items:center; gap:12px; padding-bottom:14px; margin-bottom:22px; border-bottom: 1px solid #e8e3da; }
  .adv-hero__pub-name { font-family: var(--font-heading); font-weight: 800; font-size: 1.05rem; letter-spacing: -0.01em; color: var(--ink); }
  .adv-hero__pub-cat { text-transform: uppercase; letter-spacing: .14em; font-size: .68rem; font-weight: 700; color: #b03a3a; padding: 3px 8px; border: 1px solid #b03a3a; border-radius: 4px; }
  .adv-hero__title { font-family: var(--font-heading); font-size: clamp(1.75rem, 5.5vw, 2.6rem); font-weight: 800; line-height: 1.15; letter-spacing: -0.02em; margin: 0 0 14px; color: var(--ink); }
  .adv-hero__sub { font-size: 1.1rem; line-height: 1.55; color: var(--ink-2); margin: 0 0 18px; font-weight: 500; }
  .adv-hero__byline { display:flex; flex-wrap:wrap; gap:6px; font-size:.82rem; color: var(--muted); margin: 0 0 24px; padding-bottom: 18px; border-bottom: 1px solid #e8e3da; }
  .adv-hero__byline strong { color: var(--ink); font-weight: 700; }
  .adv-hero__fig { margin: 0 0 8px; }
  .adv-hero__img { width: 100%; max-height: 460px; object-fit: cover; border-radius: 6px; display: block; }
  .adv-hero__caption { color: var(--muted); font-size: .8rem; font-style: italic; margin: 10px 0 0; line-height: 1.45; }
  .adv-hero__ing { margin: 22px 0 4px; padding: 18px 16px; background: var(--cream-soft, #fbf6ee); border-radius: 14px; }
  .adv-hero__ing-h { font-family: var(--font-heading); font-size: .98rem; font-weight: 700; color: var(--ink); margin: 0 0 12px; text-align: center; letter-spacing: -0.01em; }
  .adv-hero__ing-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  .adv-hero__ing-card { display: flex; flex-direction: column; gap: 2px; padding: 10px 8px; background: #fff; border-radius: 10px; text-align: center; align-items: center; }
  .adv-hero__ing-ico { font-size: 1.3rem; margin-bottom: 2px; }
  .adv-hero__ing-card strong { font-size: .82rem; font-weight: 700; color: var(--ink); line-height: 1.2; }
  .adv-hero__ing-body { font-size: .68rem; line-height: 1.35; color: var(--muted); margin-top: 2px; }
  @media (max-width: 480px) {
    .adv-hero__title { font-size: 1.6rem; }
    .adv-hero__sub { font-size: 1rem; }
    .adv-hero__img { max-height: 360px; }
    .adv-hero__ing-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
  }
</style>

{% schema %}
{
  "name": "Advertorial hero",
  "settings": [
    { "type": "header", "content": "Publication header" },
    { "type": "text", "id": "publication", "label": "Publication name", "default": "Soft Skin Daily" },
    { "type": "text", "id": "category", "label": "Category tag", "default": "Skincare" },
    { "type": "header", "content": "Article" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "I tried 6 foot creams, 2 peels, and a $90 pedicure. Only one thing actually softened my heels." },
    { "type": "textarea", "id": "subhead", "label": "Deck (subhead)", "default": "Three years of cracked, dry heels. A goat milk mask from Seoul fixed it in 30 minutes — without the harsh acids my dermatologist warned me about." },
    { "type": "text", "id": "byline", "label": "Byline", "default": "Sarah K." },
    { "type": "text", "id": "date", "label": "Publish date", "default": "April 2026" },
    { "type": "text", "id": "read_time", "label": "Read time", "default": "4 min read" },
    { "type": "header", "content": "Lead image" },
    { "type": "image_picker", "id": "hero_image", "label": "Lead image (UGC-style works best)" },
    { "type": "text", "id": "caption", "label": "Image caption", "default": "Real customer photo. One pair, one nap, soft feet." },
    { "type": "header", "content": "Hidden / legacy" },
    { "type": "url", "id": "cta_url", "label": "CTA link (used by inline links)" },
    { "type": "header", "content": "Layout" },
    { "type": "color", "id": "bg", "label": "Background" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 28 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 24 }
  ],
  "presets": [{ "name": "Advertorial hero" }]
}
{% endschema %}
