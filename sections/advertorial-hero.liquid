{%- liquid
  assign cta_url = section.settings.cta_url | default: '/products/goat-milk-foot-mask'
-%}
<section class="adv-hero" style="padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px; background:{{ section.settings.bg | default: 'transparent' }};">
  <div class="adv-hero__inner">

    {% if section.settings.eyebrow != blank %}
      <span class="adv-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}

    <h1 class="adv-hero__title">{{ section.settings.headline }}</h1>

    {% if section.settings.subhead != blank %}
      <p class="adv-hero__sub">{{ section.settings.subhead }}</p>
    {% endif %}

    {% if section.settings.chip_1 != blank or section.settings.chip_2 != blank or section.settings.chip_3 != blank %}
      <ul class="adv-hero__chips">
        {% if section.settings.chip_1 != blank %}<li>{{ section.settings.chip_1 }}</li>{% endif %}
        {% if section.settings.chip_2 != blank %}<li>{{ section.settings.chip_2 }}</li>{% endif %}
        {% if section.settings.chip_3 != blank %}<li>{{ section.settings.chip_3 }}</li>{% endif %}
      </ul>
    {% endif %}

    <div class="adv-hero__cta-wrap">
      <a class="adv-hero__cta" href="{{ cta_url }}">{{ section.settings.cta_label | default: 'Shop now — from $19.99' }}</a>
      {% if section.settings.cta_subtext != blank %}<small>{{ section.settings.cta_subtext }}</small>{% endif %}
    </div>

    {% if section.settings.hero_image %}
      <img class="adv-hero__img" src="{{ section.settings.hero_image | image_url: width: 1200 }}" srcset="{{ section.settings.hero_image | image_url: width: 600 }} 600w, {{ section.settings.hero_image | image_url: width: 1200 }} 1200w" sizes="(max-width:768px) 100vw, 720px" alt="{{ section.settings.headline | escape }}" width="900" height="900" fetchpriority="high">
    {% else %}
      <div class="adv-hero__img-placeholder">Product image goes here</div>
    {% endif %}

    {% if section.settings.caption != blank %}
      <p class="adv-hero__caption">{{ section.settings.caption }}</p>
    {% endif %}
  </div>
</section>

<style>
  .adv-hero { background: #ffffff; }
  .adv-hero__inner { max-width: 720px; margin: 0 auto; padding: 0 20px; text-align: center; }
  .adv-hero__eyebrow { display:inline-block; text-transform:uppercase; letter-spacing:.14em; font-size:.7rem; font-weight:700; color:var(--ink-2); margin-bottom:18px; }
  .adv-hero__title { font-family: var(--font-heading); font-size: clamp(1.9rem, 6.5vw, 3rem); font-weight:800; line-height:1.05; letter-spacing:-0.02em; margin: 0 0 14px; color: var(--ink); }
  .adv-hero__sub { font-size: 1.05rem; line-height:1.55; color: var(--ink-2); margin: 0 auto 22px; max-width: 540px; }
  .adv-hero__chips { list-style:none; padding:0; margin:0 0 22px; display:flex; flex-wrap:wrap; gap:8px; justify-content:center; }
  .adv-hero__chips li { font-size:.78rem; font-weight:600; color:var(--ink-2); background:#f4f0eb; padding:6px 12px; border-radius:999px; }
  .adv-hero__cta-wrap { margin: 0 0 26px; }
  .adv-hero__cta { display:inline-block; background: var(--ink); color:#fff; text-decoration:none; padding:16px 32px; border-radius:999px; font-weight:700; font-size:1rem; letter-spacing:.01em; transition: transform .15s ease, background .15s ease; }
  .adv-hero__cta:hover { background: var(--accent-deep); transform: translateY(-1px); }
  .adv-hero__cta-wrap small { display:block; color:var(--muted); margin-top:10px; font-size:.78rem; }
  .adv-hero__img { width:100%; max-width:560px; border-radius:18px; margin: 6px auto 14px; display:block; }
  .adv-hero__img-placeholder { width:100%; max-width:560px; aspect-ratio: 1/1; background:#f4f0eb; border-radius:18px; margin: 6px auto 14px; display:flex; align-items:center; justify-content:center; color:var(--muted); font-size:.85rem; font-style:italic; }
  .adv-hero__caption { color: var(--muted); font-size:.82rem; font-style: italic; margin: 0; }
  @media (max-width: 480px) {
    .adv-hero__title { font-size: 2rem; }
    .adv-hero__chips li { font-size:.72rem; padding:5px 10px; }
  }
</style>

{% schema %}
{
  "name": "Advertorial hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "★ 4.8 · 1,200+ REVIEWS" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Soft feet. In 30 minutes." },
    { "type": "textarea", "id": "subhead", "label": "Subhead", "default": "Cracked heels? Dry skin? Our goat milk + niacinamide foot mask softens without harsh acids. Gentle, pregnancy-safe, dermatologist-tested." },
    { "type": "header", "content": "Benefit chips" },
    { "type": "text", "id": "chip_1", "label": "Chip 1", "default": "Pregnancy-safe" },
    { "type": "text", "id": "chip_2", "label": "Chip 2", "default": "No harsh acids" },
    { "type": "text", "id": "chip_3", "label": "Chip 3", "default": "30-min results" },
    { "type": "header", "content": "Call to action" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop now — from $19.99" },
    { "type": "text", "id": "cta_subtext", "label": "CTA sub-text", "default": "Free US shipping over $30 · 30-day money-back guarantee" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "header", "content": "Hero image" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image (product or UGC)" },
    { "type": "text", "id": "caption", "label": "Image caption" },
    { "type": "header", "content": "Layout" },
    { "type": "color", "id": "bg", "label": "Background" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 32 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 32 }
  ],
  "presets": [{ "name": "Advertorial hero" }]
}
{% endschema %}
