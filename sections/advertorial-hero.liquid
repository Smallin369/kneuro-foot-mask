{%- liquid
  assign cta_url = section.settings.cta_url | default: '/products/furgone-gloves'
-%}
<section class="adv-hero" style="padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px; background:{{ section.settings.bg | default: 'transparent' }};">
  <div class="adv-hero__inner">
    {% if section.settings.eyebrow != blank %}
      <span class="adv-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}
    <h1 class="adv-hero__title">{{ section.settings.headline }}</h1>
    {% if section.settings.subhead != blank %}
      <p class="adv-hero__sub">{{ section.settings.subhead }}</p>
    {% endif %}

    {% if section.settings.byline != blank %}
      <div class="adv-hero__byline">
        {% if section.settings.byline_avatar %}
          <img src="{{ section.settings.byline_avatar | image_url: width: 80 }}" alt="" width="40" height="40" loading="eager">
        {% endif %}
        <span>{{ section.settings.byline }}</span>
      </div>
    {% endif %}

    {% if section.settings.hero_image %}
      <img class="adv-hero__img" src="{{ section.settings.hero_image | image_url: width: 1200 }}" srcset="{{ section.settings.hero_image | image_url: width: 600 }} 600w, {{ section.settings.hero_image | image_url: width: 1200 }} 1200w" sizes="(max-width:768px) 100vw, 900px" alt="{{ section.settings.headline | escape }}" width="900" height="1100" fetchpriority="high">
    {% endif %}

    {% if section.settings.caption != blank %}
      <p class="adv-hero__caption">{{ section.settings.caption }}</p>
    {% endif %}

    <a class="adv-hero__cta" href="{{ cta_url }}">{{ section.settings.cta_label | default: 'See how it works →' }}</a>
  </div>
</section>

<style>
  .adv-hero { background: var(--cream-soft); }
  .adv-hero__inner { max-width: 760px; margin: 0 auto; padding: 0 20px; text-align: center; }
  .adv-hero__eyebrow { display:inline-block; text-transform:uppercase; letter-spacing:.18em; font-size:.72rem; font-weight:700; color:var(--accent-deep); padding:6px 12px; border-radius:999px; background:rgba(232,131,58,.12); margin-bottom:18px; }
  .adv-hero__title { font-family: var(--font-heading); font-size: clamp(1.9rem, 5vw, 3rem); font-weight:600; line-height:1.15; margin: 0 0 18px; color: var(--ink); }
  .adv-hero__sub { font-size: 1.1rem; line-height:1.55; color: var(--ink-2); margin: 0 0 22px; }
  .adv-hero__byline { display:flex; align-items:center; justify-content:center; gap:10px; margin: 0 0 28px; color: var(--muted); font-size:.92rem; }
  .adv-hero__byline img { border-radius: 50%; object-fit: cover; }
  .adv-hero__img { width:100%; max-width:680px; border-radius:16px; box-shadow:0 18px 40px -18px rgba(42,28,18,.25); margin: 4px 0 14px; }
  .adv-hero__caption { color: var(--muted); font-size:.85rem; font-style: italic; margin: 0 0 28px; }
  .adv-hero__cta { display:inline-block; background: var(--accent); color:#fff; text-decoration:none; padding:14px 26px; border-radius:999px; font-weight:700; box-shadow:0 8px 22px -8px rgba(232,131,58,.6); }
  .adv-hero__cta:hover { background: var(--accent-deep); }
</style>

{% schema %}
{
  "name": "Advertorial hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "PET PARENT DIARIES" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "I tried 7 things to stop my golden's shedding. Only one worked." },
    { "type": "textarea", "id": "subhead", "label": "Subhead", "default": "Three goldens, one black couch, six months of fur in my coffee. Here's what finally fixed it." },
    { "type": "text", "id": "byline", "label": "Byline", "default": "Sarah K. · Golden retriever mom · Posted April 2026" },
    { "type": "image_picker", "id": "byline_avatar", "label": "Byline avatar (small)" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image (UGC-style preferred)" },
    { "type": "text", "id": "caption", "label": "Image caption", "default": "Six months of golden retriever fur, lifted in 90 seconds." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Skip ahead — see the mitt →" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "color", "id": "bg", "label": "Background" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 40 }
  ],
  "presets": [{ "name": "Advertorial hero" }]
}
{% endschema %}
