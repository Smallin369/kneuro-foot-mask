{%- liquid
  assign first_image = null
  for b in section.blocks
    if b.type == 'image' and b.settings.image and first_image == null
      assign first_image = b.settings.image
    endif
  endfor
-%}

{%- assign hero_asset_url = null -%}
{%- if section.settings.hero_asset != blank -%}
  {%- assign hero_asset_url = section.settings.hero_asset | asset_url -%}
{%- endif -%}
{%- assign hero_video_url = null -%}
{%- if section.settings.video_asset != blank -%}
  {%- assign hero_video_url = section.settings.video_asset | asset_url -%}
{%- endif -%}
{%- assign hero_video_poster_url = null -%}
{%- if section.settings.video_poster -%}
  {%- assign hero_video_poster_url = section.settings.video_poster | image_url: width: 1080, format: 'webp' -%}
{%- elsif section.settings.hero_image -%}
  {%- assign hero_video_poster_url = section.settings.hero_image | image_url: width: 1080, format: 'webp' -%}
{%- elsif hero_asset_url -%}
  {%- assign hero_video_poster_url = hero_asset_url -%}
{%- endif -%}
{%- assign preload_image = first_image | default: section.settings.hero_image -%}
{%- if hero_video_url -%}
  {%- comment -%} Video hero: skip image preload — autoplay video drives LCP {%- endcomment -%}
{%- elsif hero_asset_url -%}
  <link rel="preload" as="image" href="{{ hero_asset_url }}" fetchpriority="high">
{%- elsif preload_image -%}
  <link rel="preload" as="image"
        href="{{ preload_image | image_url: width: 720, format: 'webp' }}"
        imagesrcset="{{ preload_image | image_url: width: 480, format: 'webp' }} 480w, {{ preload_image | image_url: width: 720, format: 'webp' }} 720w, {{ preload_image | image_url: width: 1080, format: 'webp' }} 1080w"
        imagesizes="(max-width: 768px) 100vw, 680px"
        fetchpriority="high">
{%- endif -%}

<section class="adv-hero" style="padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px; background:{{ section.settings.bg | default: 'transparent' }};">
  <div class="adv-hero__inner">

    {%- if section.blocks.size == 0 -%}
      {%- comment -%} Legacy fallback: image-first layout for impulse-buy presale pages {%- endcomment -%}

      {% if hero_video_url %}
        <figure class="adv-hero__fig adv-hero__fig--top adv-hero__fig--video">
          <video class="adv-hero__video"
                 autoplay muted loop playsinline preload="auto"
                 {% if hero_video_poster_url %}poster="{{ hero_video_poster_url }}"{% endif %}
                 aria-label="{{ section.settings.headline | escape }}">
            <source src="{{ hero_video_url }}" type="video/mp4">
            {% if hero_video_poster_url %}<img src="{{ hero_video_poster_url }}" alt="{{ section.settings.headline | escape }}" width="1080" height="1080">{% endif %}
          </video>
        </figure>
      {% elsif hero_asset_url %}
        <figure class="adv-hero__fig adv-hero__fig--top">
          <img class="adv-hero__img" src="{{ hero_asset_url }}" alt="{{ section.settings.headline | escape }}" width="1080" height="1080" fetchpriority="high" decoding="async">
        </figure>
      {% elsif section.settings.hero_image %}
        <figure class="adv-hero__fig adv-hero__fig--top">
          <img class="adv-hero__img" src="{{ section.settings.hero_image | image_url: width: 900, format: 'webp' }}" srcset="{{ section.settings.hero_image | image_url: width: 600, format: 'webp' }} 600w, {{ section.settings.hero_image | image_url: width: 900, format: 'webp' }} 900w, {{ section.settings.hero_image | image_url: width: 1280, format: 'webp' }} 1280w" sizes="(max-width:768px) 100vw, 680px" alt="{{ section.settings.headline | escape }}" width="900" height="900" fetchpriority="high" decoding="async">
        </figure>
      {% endif %}

      {% if section.settings.headline != blank %}<h1 class="adv-hero__title">{{ section.settings.headline }}</h1>{% endif %}
      {% if section.settings.subhead != blank %}<p class="adv-hero__sub">{{ section.settings.subhead }}</p>{% endif %}

      {% if section.settings.trust_t1 != blank or section.settings.trust_t2 != blank or section.settings.trust_t3 != blank or section.settings.trust_t4 != blank %}
        <ul class="adv-hero__trust">
          {% if section.settings.trust_t1 != blank %}<li>{{ section.settings.trust_t1 }}</li>{% endif %}
          {% if section.settings.trust_t2 != blank %}<li>{{ section.settings.trust_t2 }}</li>{% endif %}
          {% if section.settings.trust_t3 != blank %}<li>{{ section.settings.trust_t3 }}</li>{% endif %}
          {% if section.settings.trust_t4 != blank %}<li>{{ section.settings.trust_t4 }}</li>{% endif %}
        </ul>
      {% endif %}

      {% if section.settings.show_stars %}
        <div class="adv-hero__rating" aria-label="{{ section.settings.stars_label | default: 'Rated 5 out of 5 stars by early customers' | escape }}">
          <span class="adv-hero__rating-stars" aria-hidden="true">★★★★★</span>
          {% if section.settings.stars_label != blank %}
            <span class="adv-hero__rating-label">{{ section.settings.stars_label }}</span>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.cta_url != blank or section.settings.cta_label != blank %}
        <div class="adv-hero__buybox">
          {% if section.settings.cta_price != blank %}
            <p class="adv-hero__cta-price">{{ section.settings.cta_price }}</p>
          {% endif %}
          <a class="adv-hero__cta" href="{{ section.settings.cta_url | default: '#' }}">{{ section.settings.cta_label | default: 'Shop now →' }}</a>
          {% if section.settings.cta_subtext != blank %}<p class="adv-hero__cta-sub">{{ section.settings.cta_subtext }}</p>{% endif %}
        </div>
      {% endif %}

      {% if section.settings.caption != blank %}<p class="adv-hero__caption">{{ section.settings.caption }}</p>{% endif %}

      {% if section.settings.byline != blank or section.settings.date != blank %}
        <div class="adv-hero__byline">
          {% if section.settings.byline != blank %}<span>By <strong>{{ section.settings.byline }}</strong></span>{% endif %}
          {% if section.settings.date != blank %}<span>· {{ section.settings.date }}</span>{% endif %}
        </div>
      {% endif %}

    {%- endif -%}

    {% for block in section.blocks %}
      {% case block.type %}

        {% when 'pub_meta' %}
          <div class="adv-hero__pub" {{ block.shopify_attributes }}>
            {% if block.settings.publication != blank %}<span class="adv-hero__pub-name">{{ block.settings.publication }}</span>{% endif %}
            {% if block.settings.category != blank %}<span class="adv-hero__pub-cat">{{ block.settings.category }}</span>{% endif %}
          </div>

        {% when 'headline' %}
          <h1 class="adv-hero__title" {{ block.shopify_attributes }}>{{ block.settings.text }}</h1>

        {% when 'subhead' %}
          <p class="adv-hero__sub" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>

        {% when 'byline' %}
          <div class="adv-hero__byline" {{ block.shopify_attributes }}>
            {% if block.settings.byline != blank %}<span>By <strong>{{ block.settings.byline }}</strong></span>{% endif %}
            {% if block.settings.date != blank %}<span>· {{ block.settings.date }}</span>{% endif %}
            {% if block.settings.read_time != blank %}<span>· {{ block.settings.read_time }}</span>{% endif %}
          </div>

        {% when 'image' %}
          <figure class="adv-hero__fig" {{ block.shopify_attributes }}>
            {% if block.settings.image %}
              <img class="adv-hero__img"
                   src="{{ block.settings.image | image_url: width: 720, format: 'webp' }}"
                   srcset="{{ block.settings.image | image_url: width: 480, format: 'webp' }} 480w, {{ block.settings.image | image_url: width: 720, format: 'webp' }} 720w, {{ block.settings.image | image_url: width: 1080, format: 'webp' }} 1080w"
                   sizes="(max-width:768px) 100vw, 680px"
                   alt="{{ block.settings.alt | escape }}"
                   width="900" height="900"
                   decoding="async"
                   {% if forloop.first %}fetchpriority="high"{% else %}loading="lazy"{% endif %}>
            {% endif %}
            {% if block.settings.caption != blank %}<figcaption class="adv-hero__caption">{{ block.settings.caption }}</figcaption>{% endif %}
          </figure>

        {% when 'divider' %}
          <hr class="adv-hero__rule" {{ block.shopify_attributes }}>

      {% endcase %}
    {% endfor %}
  </div>
</section>

<style>
  .adv-hero { background: #ffffff; }
  .adv-hero__inner { max-width: 680px; margin: 0 auto; padding: 0 20px; }
  /* Desktop: 2-col split — image left, copy + buybox right, vertically centered */
  @media (min-width: 960px) {
    .adv-hero__inner { max-width: 1080px; display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); column-gap: 56px; align-items: center; }
    .adv-hero__inner > .adv-hero__fig--top { grid-column: 1; grid-row: 1 / span 99; align-self: center; margin: 0; }
    .adv-hero__inner > .adv-hero__fig--top .adv-hero__img { max-height: 600px; aspect-ratio: 4/5; }
    .adv-hero__inner > :not(.adv-hero__fig--top):not(.adv-hero__fig) { grid-column: 2; }
    .adv-hero__inner > .adv-hero__buybox { margin-bottom: 0; }
  }
  .adv-hero__fig--top { margin: 0 0 28px; border-radius: 20px; overflow: hidden; }
  .adv-hero__fig--top .adv-hero__img { width: 100%; height: auto; max-height: 540px; object-fit: cover; aspect-ratio: 4/3; border-radius: 20px; display: block; }
  .adv-hero__fig--top.adv-hero__fig--video { background: var(--cream-soft, #faf8f5); margin: 0 auto 24px; max-width: 100%; }
  .adv-hero__video { width: 100%; height: auto; aspect-ratio: 9 / 16; max-height: 78vh; object-fit: cover; display: block; border-radius: 0; }
  @media (min-width: 760px) {
    .adv-hero__fig--top.adv-hero__fig--video { max-width: 460px; margin: 0 auto 32px; border-radius: 22px; overflow: hidden; box-shadow: 0 22px 60px -28px rgba(42,28,18,.4); }
    .adv-hero__video { aspect-ratio: 9 / 16; max-height: 660px; border-radius: 22px; }
  }
  .adv-hero__buybox { background: transparent; border: 0; border-top: 1px solid var(--line, #ece4dc); border-bottom: 1px solid var(--line, #ece4dc); border-radius: 0; padding: 22px 0 26px; margin: 12px 0 22px; text-align: center; }
  .adv-hero__buybox .adv-hero__cta-price { margin: 0 0 14px; font-size: 1.15rem; }
  .adv-hero__buybox .adv-hero__cta { display: block; width: 100%; padding: 20px 32px; font-size: 1.12rem; font-weight: 800; letter-spacing: .005em; box-shadow: 0 8px 24px -8px rgba(15,15,15,.35), 0 2px 4px rgba(15,15,15,.12); transition: transform .15s ease, box-shadow .2s ease, background .15s ease; }
  .adv-hero__buybox .adv-hero__cta:hover { transform: translateY(-2px); box-shadow: 0 14px 32px -8px rgba(15,15,15,.45), 0 4px 8px rgba(15,15,15,.18); }
  .adv-hero__buybox .adv-hero__cta:active { transform: translateY(0); box-shadow: 0 4px 12px -4px rgba(15,15,15,.3); }
  .adv-hero__buybox .adv-hero__cta-sub { margin-top: 12px; font-size: .8rem; }

  /* Star rating block — sits between trust pills and buybox */
  .adv-hero__rating { display: inline-flex; align-items: center; gap: 8px; padding: 6px 14px; margin: 4px 0 16px; border-radius: 999px; background: var(--cream-soft, #fbf6ee); border: 1px solid var(--line, #ece4dc); }
  .adv-hero__rating-stars { color: #e8a93d; font-size: .9rem; letter-spacing: 1.5px; line-height: 1; }
  .adv-hero__rating-label { font-family: var(--font-heading); font-size: .78rem; font-weight: 700; letter-spacing: .04em; color: var(--ink); }
  .adv-hero__caption { font-family: var(--font-body); font-size: .82rem; color: var(--muted, #6a6a6a); text-align: center; margin: 8px 0 16px; font-style: italic; }
  @media (min-width: 760px) {
    .adv-hero__fig--top { margin: 0 0 32px; }
    .adv-hero__fig--top .adv-hero__img { border-radius: 18px; }
  }
  .adv-hero__pub { display:flex; align-items:center; gap:14px; padding-bottom:16px; margin-bottom:28px; border-bottom: 1px solid #e8e3da; }
  .adv-hero__pub-name { font-family: var(--font-heading); font-weight: 800; font-size: 1.1rem; letter-spacing: -0.015em; color: var(--ink); }
  .adv-hero__pub-cat { text-transform: uppercase; letter-spacing: .16em; font-size: .65rem; font-weight: 800; color: #b03a3a; padding: 4px 10px; border: 1px solid #b03a3a; border-radius: 3px; }
  .adv-hero__title { font-family: var(--font-heading); font-size: clamp(1.6rem, 5vw, 2.3rem); font-weight: 800; line-height: 1.12; letter-spacing: -0.02em; margin: 0 0 8px; color: var(--ink); text-wrap: balance; }
  .adv-hero__sub { font-family: var(--font-body); font-size: 1.1rem; line-height: 1.45; color: var(--ink-2); margin: 0 0 20px; font-weight: 500; letter-spacing: -0.005em; text-wrap: pretty; }
  .adv-hero__byline { display:flex; flex-wrap:wrap; gap:8px; font-size:.8rem; color: var(--muted); margin: 0 0 28px; padding-bottom: 20px; border-bottom: 1px solid #e8e3da; letter-spacing: .01em; }
  .adv-hero__byline strong { color: var(--ink); font-weight: 700; letter-spacing: 0; }
  .adv-hero__fig { margin: 0 0 8px; }
  .adv-hero__img { width: 100%; max-height: 480px; object-fit: cover; border-radius: 4px; display: block; }
  .adv-hero__caption { color: var(--muted); font-size: .82rem; font-style: italic; margin: 12px 0 0; line-height: 1.5; letter-spacing: .005em; }
  .adv-hero__rule { border: 0; border-top: 1px solid #e8e3da; margin: 28px 0; }
  .adv-hero__trust { list-style: none; padding: 0; margin: 0 0 22px; display: grid; grid-template-columns: 1fr; gap: 8px; }
  .adv-hero__trust li { position: relative; color: var(--ink-2); font-family: var(--font-body); font-size: .9rem; font-weight: 500; letter-spacing: 0; padding-left: 24px; line-height: 1.35; }
  .adv-hero__trust li::before { content: "\2713"; position: absolute; left: 0; top: 0; color: var(--accent-deep, var(--ink)); font-weight: 800; }
  .adv-hero__cta-wrap { margin: 0 0 28px; }
  .adv-hero__cta-price { font-family: var(--font-heading); font-size: 1.05rem; font-weight: 700; color: var(--ink); margin: 0 0 12px; letter-spacing: -0.01em; }
  .adv-hero__cta { display: inline-block; padding: 16px 32px; background: var(--accent, #0a0a0a); color: #ffffff; text-decoration: none; font-family: var(--font-body); font-size: 1rem; font-weight: 700; letter-spacing: .01em; border-radius: 999px; transition: background .15s ease, transform .15s ease; }
  .adv-hero__cta:hover { background: var(--accent-deep, #2a2a2a); transform: translateY(-1px); }
  .adv-hero__cta-sub { font-family: var(--font-body); font-size: .78rem; color: var(--muted, #6a6a6a); margin: 10px 0 0; letter-spacing: .01em; }
  @media (max-width: 480px) {
    .adv-hero__title { font-size: 1.85rem; line-height: 1.12; letter-spacing: -0.03em; }
    .adv-hero__sub { font-size: 1.05rem; }
    .adv-hero__img { max-height: 380px; }
    .adv-hero__cta { width: 100%; padding: 18px 24px; text-align: center; }
  }
</style>

{% schema %}
{
  "name": "Advertorial hero",
  "settings": [
    { "type": "paragraph", "content": "Tip: prefer adding blocks below for full modularity. Settings here are a legacy fallback used only when no blocks exist." },
    { "type": "header", "content": "Legacy settings (fallback only)" },
    { "type": "text", "id": "publication", "label": "Publication name" },
    { "type": "text", "id": "category", "label": "Category tag" },
    { "type": "text", "id": "headline", "label": "Headline" },
    { "type": "textarea", "id": "subhead", "label": "Deck (subhead)" },
    { "type": "text", "id": "byline", "label": "Byline" },
    { "type": "text", "id": "date", "label": "Publish date" },
    { "type": "text", "id": "read_time", "label": "Read time" },
    { "type": "image_picker", "id": "hero_image", "label": "Lead image (Shopify Files)" },
    { "type": "text", "id": "hero_asset", "label": "Theme asset filename (overrides Lead image, e.g. hero-pov.jpg)" },
    { "type": "header", "content": "Hero video (overrides image when set)" },
    { "type": "text", "id": "video_asset", "label": "Theme video asset filename (e.g. kneuro-hero.mp4)" },
    { "type": "image_picker", "id": "video_poster", "label": "Video poster image (shown while video loads)" },
    { "type": "text", "id": "caption", "label": "Image caption" },
    { "type": "text", "id": "cta_label", "label": "CTA button label", "default": "Shop now — from $19.99 →" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "text", "id": "cta_subtext", "label": "CTA subtext (small line below button)", "default": "30-day money-back · Soft heels in 30 minutes" },
    { "type": "header", "content": "Trust micro-strip" },
    { "type": "text", "id": "trust_t1", "label": "Trust token 1", "default": "Pregnancy-safe" },
    { "type": "text", "id": "trust_t2", "label": "Trust token 2", "default": "Derm-tested" },
    { "type": "text", "id": "trust_t3", "label": "Trust token 3", "default": "30-day refund" },
    { "type": "text", "id": "trust_t4", "label": "Trust token 4 (optional)" },
    { "type": "header", "content": "Rating block (above CTA)" },
    { "type": "checkbox", "id": "show_stars", "label": "Show 5-star rating block", "default": true },
    { "type": "text", "id": "stars_label", "label": "Rating label", "default": "Loved by early customers" },
    { "type": "header", "content": "CTA" },
    { "type": "text", "id": "cta_price", "label": "Price line above CTA button" },
    { "type": "header", "content": "Layout" },
    { "type": "color", "id": "bg", "label": "Background" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 28 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 24 }
  ],
  "blocks": [
    { "type": "pub_meta", "name": "Publication meta", "limit": 1, "settings": [
      { "type": "text", "id": "publication", "label": "Publication name", "default": "Soft Skin Daily" },
      { "type": "text", "id": "category", "label": "Category tag", "default": "Skincare" }
    ]},
    { "type": "headline", "name": "Headline", "limit": 1, "settings": [
      { "type": "text", "id": "text", "label": "Headline", "default": "I tried 6 foot creams, 2 peels, and a $90 pedicure. Only one thing actually softened my heels." }
    ]},
    { "type": "subhead", "name": "Deck (subhead)", "settings": [
      { "type": "textarea", "id": "text", "label": "Deck", "default": "Three years of cracked, dry heels. A goat milk + niacinamide mask fixed it in 30 minutes — without the harsh acids my dermatologist warned me about." }
    ]},
    { "type": "byline", "name": "Byline", "limit": 1, "settings": [
      { "type": "text", "id": "byline", "label": "Author", "default": "Sarah K." },
      { "type": "text", "id": "date", "label": "Publish date", "default": "April 2026" },
      { "type": "text", "id": "read_time", "label": "Read time", "default": "4 min read" }
    ]},
    { "type": "image", "name": "Image", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "alt", "label": "Alt text" },
      { "type": "text", "id": "caption", "label": "Caption", "default": "Real customer photo. One pair, one nap, soft feet." }
    ]},
    { "type": "divider", "name": "Divider", "settings": [] }
  ],
  "max_blocks": 20,
  "presets": [{
    "name": "Advertorial hero",
    "blocks": [
      { "type": "pub_meta" },
      { "type": "headline" },
      { "type": "subhead" },
      { "type": "byline" },
      { "type": "image" }
    ]
  }]
}
{% endschema %}
