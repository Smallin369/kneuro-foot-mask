<section class="container" style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color | default: 'transparent' }};">
  {% if section.settings.heading != blank %}
    <h2 class="section-title" style="margin-bottom:18px">{{ section.settings.heading }}</h2>
  {% endif %}
  <div class="product-desc">
    {% if section.settings.custom_content != blank %}
      {{ section.settings.custom_content }}
    {% else %}
      {{ product.description }}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Product description",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading (leave blank to hide)" },
    { "type": "richtext", "id": "custom_content", "label": "Override description (optional)" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 40 },
    { "type": "color", "id": "bg_color", "label": "Background" }
  ],
  "presets": [{ "name": "Product description" }]
}
{% endschema %}
