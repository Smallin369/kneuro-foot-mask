{%- liquid
  assign cta_url = section.settings.cta_url | default: '/products/goat-milk-callus-mask'

  comment
  Pre-pass: figure out where the FIRST verified-buyer review card sits.
  Used to emit a small "What real customers say" heading before that cluster.
  endcomment
  assign first_review_index = -1
  assign idx = 0
  for blk in section.blocks
    if blk.type == 'pullquote' and blk.settings.attribution contains 'Verified buyer' and first_review_index == -1
      assign first_review_index = idx
    endif
    assign idx = idx | plus: 1
  endfor
-%}
<section class="adv-story" style="padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px; background:{{ section.settings.bg | default: 'transparent' }};">
  <div class="adv-story__inner">
    {% for block in section.blocks %}
      {%- if forloop.index0 == first_review_index -%}
        <div class="adv-story__reviews-head">
          <span class="adv-story__reviews-eyebrow">What customers say</span>
          <span class="adv-story__reviews-stars">★★★★★ <span class="adv-story__reviews-count">based on 1,200+ reviews</span></span>
        </div>
      {%- endif -%}

      {% case block.type %}
        {% when 'paragraph' %}
          <p class="adv-story__p" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>

        {% when 'heading' %}
          <h2 class="adv-story__h" {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>

        {% when 'image' %}
          <figure class="adv-story__fig" {{ block.shopify_attributes }}>
            {% if block.settings.image %}
              <img src="{{ block.settings.image | image_url: width: 1200, format: 'webp' }}" srcset="{{ block.settings.image | image_url: width: 600, format: 'webp' }} 600w, {{ block.settings.image | image_url: width: 1200, format: 'webp' }} 1200w" sizes="(max-width:768px) 100vw, 700px" alt="{{ block.settings.alt | escape }}" loading="lazy" width="900" height="675">
            {% endif %}
            {% if block.settings.caption != blank %}<figcaption>{{ block.settings.caption }}</figcaption>{% endif %}
          </figure>

        {% when 'pullquote' %}
          {%- if block.settings.attribution contains 'Verified buyer' -%}
            {%- assign attr_parts = block.settings.attribution | split: '·' -%}
            {%- assign reviewer_name = attr_parts[0] | strip -%}
            {%- assign reviewer_role = attr_parts[1] | strip -%}
            {%- assign first_initial = reviewer_name | slice: 0, 1 -%}
            <article class="adv-story__review" {{ block.shopify_attributes }}>
              <div class="adv-story__review-stars">★★★★★</div>
              <p class="adv-story__review-quote">{{ block.settings.quote }}</p>
              <div class="adv-story__review-meta">
                <span class="adv-story__review-avatar" aria-hidden="true">{{ first_initial }}</span>
                <span class="adv-story__review-attr">
                  <span class="adv-story__review-name">{{ reviewer_name }}</span>
                  <span class="adv-story__review-role">{{ reviewer_role }} · <span class="adv-story__review-verified">✓ Verified buyer</span></span>
                </span>
              </div>
            </article>
          {%- else -%}
            <blockquote class="adv-story__quote" {{ block.shopify_attributes }}>
              <p>{{ block.settings.quote }}</p>
              {% if block.settings.attribution != blank %}<cite>— {{ block.settings.attribution }}</cite>{% endif %}
            </blockquote>
          {%- endif -%}

        {% when 'checkmarks' %}
          <ul class="adv-story__checks" {{ block.shopify_attributes }}>
            {% if block.settings.t1 != blank %}<li>{{ block.settings.t1 }}</li>{% endif %}
            {% if block.settings.t2 != blank %}<li>{{ block.settings.t2 }}</li>{% endif %}
            {% if block.settings.t3 != blank %}<li>{{ block.settings.t3 }}</li>{% endif %}
            {% if block.settings.t4 != blank %}<li>{{ block.settings.t4 }}</li>{% endif %}
            {% if block.settings.t5 != blank %}<li>{{ block.settings.t5 }}</li>{% endif %}
          </ul>

        {% when 'ingredients' %}
          <div class="adv-story__ing" {{ block.shopify_attributes }}>
            {% if block.settings.heading != blank %}<h3 class="adv-story__ing-h">{{ block.settings.heading }}</h3>{% endif %}
            <div class="adv-story__ing-grid">
              {% if block.settings.i1_title != blank %}
                <div class="adv-story__ing-card">
                  <span class="adv-story__ing-ico">{{ block.settings.i1_emoji }}</span>
                  <strong>{{ block.settings.i1_title }}</strong>
                  <span class="adv-story__ing-body">{{ block.settings.i1_body }}</span>
                </div>
              {% endif %}
              {% if block.settings.i2_title != blank %}
                <div class="adv-story__ing-card">
                  <span class="adv-story__ing-ico">{{ block.settings.i2_emoji }}</span>
                  <strong>{{ block.settings.i2_title }}</strong>
                  <span class="adv-story__ing-body">{{ block.settings.i2_body }}</span>
                </div>
              {% endif %}
              {% if block.settings.i3_title != blank %}
                <div class="adv-story__ing-card">
                  <span class="adv-story__ing-ico">{{ block.settings.i3_emoji }}</span>
                  <strong>{{ block.settings.i3_title }}</strong>
                  <span class="adv-story__ing-body">{{ block.settings.i3_body }}</span>
                </div>
              {% endif %}
              {% if block.settings.i4_title != blank %}
                <div class="adv-story__ing-card">
                  <span class="adv-story__ing-ico">{{ block.settings.i4_emoji }}</span>
                  <strong>{{ block.settings.i4_title }}</strong>
                  <span class="adv-story__ing-body">{{ block.settings.i4_body }}</span>
                </div>
              {% endif %}
            </div>
          </div>

        {% when 'inline_cta' %}
          <div class="adv-story__cta-wrap" {{ block.shopify_attributes }}>
            <a class="adv-story__cta" href="{{ block.settings.url | default: cta_url }}">{{ block.settings.label }}</a>
            {% if block.settings.subtext != blank %}<small>{{ block.settings.subtext }}</small>{% endif %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</section>

<style>
  .adv-story { background: #fff; }
  .adv-story__inner { max-width: 680px; margin: 0 auto; padding: 0 20px; }

  /* Body paragraphs — clean, even rhythm. No drop-cap, no decoration. */
  .adv-story__p { font-size: 17px; line-height: 1.65; color: var(--ink); margin: 0 0 18px; font-family: var(--font-body); }
  .adv-story__p strong { color: var(--ink); font-weight: 700; }

  /* Headings (rare in this story) */
  .adv-story__h { font-family: var(--font-heading); font-size: clamp(1.3rem, 3vw, 1.65rem); font-weight: 700; color: var(--ink); margin: 32px 0 14px; line-height: 1.25; }

  /* Image figures with caption */
  .adv-story__fig { margin: 26px 0; }
  .adv-story__fig img { width: 100%; border-radius: 14px; box-shadow: 0 12px 30px -12px rgba(42,28,18,.18); display: block; }
  .adv-story__fig figcaption { color: var(--muted); font-size: 13px; font-style: italic; text-align: center; margin-top: 10px; line-height: 1.45; }

  /* Sarah's literary pullquote — THE story moment, distinct from customer reviews */
  .adv-story__quote { border-left: 3px solid var(--accent); padding: 4px 0 4px 22px; margin: 32px 0; }
  .adv-story__quote p { font-family: var(--font-heading); font-size: 1.35rem; font-style: italic; color: var(--ink); margin: 0 0 8px; line-height: 1.4; }
  .adv-story__quote p::before { content: "\201C"; }
  .adv-story__quote p::after { content: "\201D"; }
  .adv-story__quote cite { display: block; color: var(--muted); font-style: normal; font-size: 13px; letter-spacing: .02em; }

  /* Customer reviews header (renders once, before the first verified-buyer card) */
  .adv-story__reviews-head { display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: 8px; margin: 36px 0 14px; padding-bottom: 12px; border-bottom: 1px solid var(--line); }
  .adv-story__reviews-eyebrow { font-family: var(--font-heading); font-size: 14px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--ink); }
  .adv-story__reviews-stars { color: #f5b14a; font-size: 14px; letter-spacing: 2px; }
  .adv-story__reviews-count { color: var(--muted); font-size: 12px; letter-spacing: 0; margin-left: 4px; }

  /* Customer review card — looks like a Yelp/Amazon review, NOT a literary quote */
  .adv-story__review { background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 18px 20px; margin: 0 0 12px; }
  .adv-story__review-stars { color: #f5b14a; font-size: 13px; letter-spacing: 2px; margin-bottom: 10px; }
  .adv-story__review-quote { font-family: var(--font-body); font-size: 15px; line-height: 1.55; color: var(--ink-2); margin: 0 0 14px; font-style: normal; }
  .adv-story__review-meta { display: flex; align-items: center; gap: 12px; padding-top: 12px; border-top: 1px solid var(--line); }
  .adv-story__review-avatar { flex: 0 0 36px; width: 36px; height: 36px; border-radius: 50%; background: var(--cream); color: var(--ink); display: grid; place-items: center; font-family: var(--font-heading); font-weight: 700; font-size: 14px; }
  .adv-story__review-attr { display: flex; flex-direction: column; line-height: 1.3; }
  .adv-story__review-name { font-weight: 700; font-size: 13px; color: var(--ink); }
  .adv-story__review-role { font-size: 12px; color: var(--muted); }
  .adv-story__review-verified { color: #1f6c2f; font-weight: 600; }

  /* Checkmark list */
  .adv-story__checks { list-style: none; padding: 20px 24px; margin: 24px 0; background: var(--cream-soft); border-radius: 12px; }
  .adv-story__checks li { padding: 6px 0 6px 28px; position: relative; color: var(--ink-2); font-size: 15px; }
  .adv-story__checks li::before { content: "\2713"; position: absolute; left: 0; top: 6px; color: var(--accent-deep); font-weight: 700; }

  /* CTA */
  .adv-story__cta-wrap { text-align: center; margin: 36px 0 24px; }
  .adv-story__cta { display: inline-block; background: var(--accent); color: #fff; text-decoration: none; padding: 18px 36px; border-radius: 999px; font-weight: 700; font-size: 16px; letter-spacing: .01em; box-shadow: 0 14px 34px -10px rgba(232,131,58,.5); transition: transform .15s ease, background .15s ease; }
  .adv-story__cta:hover { background: var(--accent-deep); transform: translateY(-2px); }
  .adv-story__cta-wrap small { display: block; color: var(--muted); margin-top: 10px; font-size: 12px; }

  /* Ingredients grid */
  .adv-story__ing { margin: 32px 0; padding: 22px 20px; background: var(--cream-soft); border-radius: 14px; }
  .adv-story__ing-h { font-family: var(--font-heading); font-size: 1.05rem; font-weight: 700; color: var(--ink); margin: 0 0 16px; text-align: center; }
  .adv-story__ing-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
  .adv-story__ing-card { display: flex; flex-direction: column; gap: 4px; padding: 12px; background: #fff; border-radius: 10px; }
  .adv-story__ing-ico { font-size: 1.4rem; margin-bottom: 4px; }
  .adv-story__ing-card strong { font-size: 14px; color: var(--ink); line-height: 1.2; }
  .adv-story__ing-body { font-size: 12px; color: var(--muted); line-height: 1.4; }

  @media (max-width: 480px) {
    .adv-story__inner { padding: 0 18px; }
    .adv-story__p { font-size: 16px; line-height: 1.62; margin: 0 0 16px; }
    .adv-story__quote p { font-size: 1.2rem; }
    .adv-story__ing-grid { grid-template-columns: 1fr; gap: 10px; }
    .adv-story__reviews-head { flex-direction: column; align-items: flex-start; gap: 4px; }
  }
</style>

{% schema %}
{
  "name": "Advertorial story",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "url", "id": "cta_url", "label": "CTA URL", "default": "/products/goat-milk-callus-mask" },
    { "type": "color", "id": "bg", "label": "Background" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 16 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 48 }
  ],
  "blocks": [
    { "type": "paragraph", "name": "Paragraph", "settings": [
      { "type": "richtext", "id": "text", "label": "Text", "default": "<p>By month three of cracked heels I'd given up. Two foot creams, a $40 callus remover, and a $90 pedicure that lasted four days. Nothing softened the dryness.</p>" }
    ]},
    { "type": "heading", "name": "Heading", "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "Then a friend sent me a 30-second video." }
    ]},
    { "type": "image", "name": "Image", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "alt", "label": "Alt text" },
      { "type": "text", "id": "caption", "label": "Caption" }
    ]},
    { "type": "pullquote", "name": "Pull quote / Review", "settings": [
      { "type": "textarea", "id": "quote", "label": "Quote" },
      { "type": "text", "id": "attribution", "label": "Attribution", "info": "Include 'Verified buyer' to render as a customer review card. Otherwise renders as a literary pullquote (use for the protagonist's voice)." }
    ]},
    { "type": "ingredients", "name": "Ingredients grid", "settings": [
      { "type": "text", "id": "heading", "label": "Heading", "default": "Four ingredients, zero compromise" },
      { "type": "text", "id": "i1_emoji", "label": "Item 1 emoji", "default": "🥛" },
      { "type": "text", "id": "i1_title", "label": "Item 1 title", "default": "Goat Milk" },
      { "type": "text", "id": "i1_body", "label": "Item 1 body", "default": "Gentle lactic acid hydrates without stripping the skin barrier." },
      { "type": "text", "id": "i2_emoji", "label": "Item 2 emoji", "default": "✨" },
      { "type": "text", "id": "i2_title", "label": "Item 2 title", "default": "Niacinamide" },
      { "type": "text", "id": "i2_body", "label": "Item 2 body", "default": "Vitamin B3 strengthens the barrier and evens skin tone." },
      { "type": "text", "id": "i3_emoji", "label": "Item 3 emoji", "default": "💧" },
      { "type": "text", "id": "i3_title", "label": "Item 3 title", "default": "Glycerin" },
      { "type": "text", "id": "i3_body", "label": "Item 3 body", "default": "Pulls deep moisture into the dermis — soft for days, not hours." },
      { "type": "text", "id": "i4_emoji", "label": "Item 4 emoji", "default": "🌿" },
      { "type": "text", "id": "i4_title", "label": "Item 4 title", "default": "Allantoin" },
      { "type": "text", "id": "i4_body", "label": "Item 4 body", "default": "Soothes irritation. Safe for sensitive, pregnant, and diabetic skin." }
    ]},
    { "type": "checkmarks", "name": "Checkmark list", "settings": [
      { "type": "text", "id": "t1", "label": "Item 1" },
      { "type": "text", "id": "t2", "label": "Item 2" },
      { "type": "text", "id": "t3", "label": "Item 3" },
      { "type": "text", "id": "t4", "label": "Item 4" },
      { "type": "text", "id": "t5", "label": "Item 5" }
    ]},
    { "type": "inline_cta", "name": "Inline CTA", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Get the Goat Milk Mask — from $19.99 →" },
      { "type": "url", "id": "url", "label": "URL" },
      { "type": "text", "id": "subtext", "label": "Subtext" }
    ]}
  ],
  "max_blocks": 30,
  "presets": [{ "name": "Advertorial story" }]
}
{% endschema %}
