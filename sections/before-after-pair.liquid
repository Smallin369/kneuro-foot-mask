{%- liquid
  assign layout = section.settings.layout | default: 'side-by-side'
  assign max_width = section.settings.max_width | default: 980
-%}

<section class="bap" style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;background:{{ section.settings.bg | default: 'transparent' }};">
  <div class="bap__inner" style="max-width:{{ max_width }}px;">
    {% if section.settings.kicker != blank %}
      <div class="bap__kicker">{{ section.settings.kicker }}</div>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="bap__heading">{{ section.settings.heading }} <em>{{ section.settings.heading_accent }}</em></h2>
    {% endif %}
    {% if section.settings.subhead != blank %}
      <p class="bap__sub">{{ section.settings.subhead }}</p>
    {% endif %}

    <div class="bap__grid bap__grid--{{ layout }}">
      {% for block in section.blocks %}
        {% if block.type == 'image_card' %}
          <figure class="bap__cell" {{ block.shopify_attributes }}>
            {% if block.settings.image %}
              <img src="{{ block.settings.image | image_url: width: 900, format: 'webp' }}" srcset="{{ block.settings.image | image_url: width: 600, format: 'webp' }} 600w, {{ block.settings.image | image_url: width: 900, format: 'webp' }} 900w, {{ block.settings.image | image_url: width: 1200, format: 'webp' }} 1200w" sizes="(max-width:768px) 100vw, 480px" alt="{{ block.settings.alt | default: 'Image' | escape }}" loading="lazy" width="800" height="800">
            {% else %}
              <div class="bap__placeholder">Add image</div>
            {% endif %}
            <figcaption>
              {% if block.settings.label != blank %}
                <span class="bap__tag" style="background:{{ block.settings.label_bg | default: '#f4e7e1' }};color:{{ block.settings.label_color | default: '#8c4a32' }};">{{ block.settings.label }}</span>
              {% endif %}
              {% if block.settings.caption != blank %}
                <span class="bap__caption">{{ block.settings.caption }}</span>
              {% endif %}
            </figcaption>
          </figure>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.fineprint != blank %}
      <p class="bap__fineprint">{{ section.settings.fineprint }}</p>
    {% endif %}
  </div>
</section>

<style>
  .bap { background: #fff; }
  .bap__inner { margin: 0 auto; padding: 0 20px; text-align: center; }
  .bap__kicker { display: inline-block; padding: 5px 12px; border: 1px solid var(--line); border-radius: 999px; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--ink); font-family: var(--font-heading); font-weight: 700; margin: 0 0 12px; }
  .bap__heading { font-family: var(--font-heading); font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 700; color: var(--ink); margin: 0 0 8px; line-height: 1.2; }
  .bap__heading em { font-style: italic; font-weight: 700; color: var(--accent); }
  .bap__sub { color: var(--ink-2); font-size: 16px; line-height: 1.5; margin: 0 auto 24px; max-width: 600px; }
  .bap__grid { display: grid; gap: 16px; margin: 0 0 16px; }
  .bap__grid--side-by-side { grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
  .bap__grid--stacked { grid-template-columns: 1fr; max-width: 540px; margin-left: auto; margin-right: auto; }
  .bap__cell { margin: 0; }
  .bap__cell img { width: 100%; height: auto; border-radius: 14px; box-shadow: 0 12px 30px -12px rgba(42,28,18,.18); display: block; aspect-ratio: 1/1; object-fit: cover; }
  .bap__placeholder { aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; background: var(--cream); color: var(--muted); border-radius: 14px; font-size: 14px; }
  .bap__cell figcaption { display: flex; flex-direction: column; align-items: center; gap: 6px; margin-top: 12px; }
  .bap__tag { display: inline-block; padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; font-family: var(--font-heading); }
  .bap__caption { font-size: 13px; color: var(--muted); font-style: italic; line-height: 1.45; max-width: 320px; }
  .bap__fineprint { color: var(--muted); font-size: 12px; line-height: 1.45; margin: 12px 0 0; }
  @media (max-width: 600px) { .bap__grid--side-by-side { grid-template-columns: 1fr; gap: 20px; } }
</style>

{% schema %}
{
  "name": "Before / after pair",
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Real result" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Three weeks." },
    { "type": "text", "id": "heading_accent", "label": "Italic accent", "default": "Same foot." },
    { "type": "textarea", "id": "subhead", "label": "Subhead" },
    { "type": "text", "id": "fineprint", "label": "Fine print" },
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "layout",
      "label": "Image layout",
      "options": [
        { "value": "side-by-side", "label": "Side by side" },
        { "value": "stacked", "label": "Stacked" }
      ],
      "default": "side-by-side"
    },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 480, "max": 1200, "step": 20, "unit": "px", "default": 980 },
    { "type": "color", "id": "bg", "label": "Background" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 }
  ],
  "blocks": [
    {
      "type": "image_card",
      "name": "Image card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Alt text", "default": "Image" },
        { "type": "text", "id": "label", "label": "Label (e.g. BEFORE / AFTER)", "default": "Before" },
        { "type": "color", "id": "label_bg", "label": "Label background color", "default": "#f4e7e1" },
        { "type": "color", "id": "label_color", "label": "Label text color", "default": "#8c4a32" },
        { "type": "text", "id": "caption", "label": "Caption" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{
    "name": "Before / after pair",
    "blocks": [
      { "type": "image_card", "settings": { "label": "Before", "label_bg": "#f4e7e1", "label_color": "#8c4a32" }},
      { "type": "image_card", "settings": { "label": "After", "label_bg": "#d6efd9", "label_color": "#1f6c2f" }}
    ]
  }]
}
{% endschema %}
