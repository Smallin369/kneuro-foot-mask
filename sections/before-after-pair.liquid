{%- liquid
  assign layout = section.settings.layout | default: 'side-by-side'
-%}

<section class="bap" style="padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px; background:{{ section.settings.bg | default: 'transparent' }};">
  <div class="bap__inner">
    {% if section.settings.kicker != blank %}
      <div class="bap__kicker">{{ section.settings.kicker }}</div>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="bap__heading">{{ section.settings.heading }} <em>{{ section.settings.heading_accent }}</em></h2>
    {% endif %}
    {% if section.settings.subhead != blank %}
      <p class="bap__sub">{{ section.settings.subhead }}</p>
    {% endif %}

    <div class="bap__grid bap__grid--{{ layout }}">
      <figure class="bap__cell">
        {% if section.settings.before_image %}
          <img src="{{ section.settings.before_image | image_url: width: 900, format: 'webp' }}" srcset="{{ section.settings.before_image | image_url: width: 600, format: 'webp' }} 600w, {{ section.settings.before_image | image_url: width: 900, format: 'webp' }} 900w, {{ section.settings.before_image | image_url: width: 1200, format: 'webp' }} 1200w" sizes="(max-width:768px) 100vw, 480px" alt="{{ section.settings.before_alt | default: 'Before' | escape }}" loading="lazy" width="800" height="800">
        {% else %}
          <div class="bap__placeholder">Add before image</div>
        {% endif %}
        <figcaption>
          <span class="bap__tag bap__tag--before">Before</span>
          {% if section.settings.before_caption != blank %}
            <span class="bap__caption">{{ section.settings.before_caption }}</span>
          {% endif %}
        </figcaption>
      </figure>

      <figure class="bap__cell">
        {% if section.settings.after_image %}
          <img src="{{ section.settings.after_image | image_url: width: 900, format: 'webp' }}" srcset="{{ section.settings.after_image | image_url: width: 600, format: 'webp' }} 600w, {{ section.settings.after_image | image_url: width: 900, format: 'webp' }} 900w, {{ section.settings.after_image | image_url: width: 1200, format: 'webp' }} 1200w" sizes="(max-width:768px) 100vw, 480px" alt="{{ section.settings.after_alt | default: 'After' | escape }}" loading="lazy" width="800" height="800">
        {% else %}
          <div class="bap__placeholder">Add after image</div>
        {% endif %}
        <figcaption>
          <span class="bap__tag bap__tag--after">After</span>
          {% if section.settings.after_caption != blank %}
            <span class="bap__caption">{{ section.settings.after_caption }}</span>
          {% endif %}
        </figcaption>
      </figure>
    </div>

    {% if section.settings.fineprint != blank %}
      <p class="bap__fineprint">{{ section.settings.fineprint }}</p>
    {% endif %}
  </div>
</section>

<style>
  .bap { background: #fff; }
  .bap__inner { max-width: 980px; margin: 0 auto; padding: 0 20px; text-align: center; }
  .bap__kicker { display: inline-block; padding: 5px 12px; border: 1px solid var(--line, #ececec); border-radius: 999px; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--ink, #0a0a0a); font-family: var(--font-heading); font-weight: 700; margin: 0 0 14px; }
  .bap__heading { font-family: var(--font-heading); font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 700; color: var(--ink, #0a0a0a); margin: 0 0 8px; line-height: 1.2; }
  .bap__heading em { font-style: italic; font-weight: 700; color: var(--accent, #0a0a0a); }
  .bap__sub { color: var(--ink-2, #2a2a2a); font-size: 16px; line-height: 1.5; margin: 0 auto 28px; max-width: 600px; }
  .bap__grid { display: grid; gap: 16px; margin: 0 0 18px; }
  .bap__grid--side-by-side { grid-template-columns: 1fr 1fr; }
  .bap__grid--stacked { grid-template-columns: 1fr; max-width: 540px; margin-left: auto; margin-right: auto; }
  .bap__cell { margin: 0; position: relative; }
  .bap__cell img { width: 100%; height: auto; border-radius: 14px; box-shadow: 0 12px 30px -12px rgba(42,28,18,.18); display: block; aspect-ratio: 1/1; object-fit: cover; }
  .bap__placeholder { aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; background: var(--cream, #f7f4f0); color: var(--muted, #888); border-radius: 14px; font-size: 14px; }
  .bap__cell figcaption { display: flex; flex-direction: column; align-items: center; gap: 6px; margin-top: 12px; }
  .bap__tag { display: inline-block; padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; font-family: var(--font-heading); }
  .bap__tag--before { background: #f4e7e1; color: #8c4a32; }
  .bap__tag--after { background: #d6efd9; color: #1f6c2f; }
  .bap__caption { font-size: 13px; color: var(--muted, #888); font-style: italic; line-height: 1.45; max-width: 320px; }
  .bap__fineprint { color: var(--muted, #888); font-size: 12px; line-height: 1.45; margin: 16px 0 0; }

  @media (max-width: 600px) {
    .bap__grid--side-by-side { grid-template-columns: 1fr; gap: 20px; }
  }
</style>

{% schema %}
{
  "name": "Before / after pair",
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Real result" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Three weeks." },
    { "type": "text", "id": "heading_accent", "label": "Italic accent", "default": "Same foot." },
    { "type": "textarea", "id": "subhead", "label": "Subhead", "default": "Weekly 30-minute sessions. No peeling, just gradual softening." },
    { "type": "header", "content": "Before image" },
    { "type": "image_picker", "id": "before_image", "label": "Before image" },
    { "type": "text", "id": "before_alt", "label": "Alt text", "default": "Dry cracked heel before treatment" },
    { "type": "text", "id": "before_caption", "label": "Caption (optional)", "default": "March 2026 — three years of dry, cracked heels." },
    { "type": "header", "content": "After image" },
    { "type": "image_picker", "id": "after_image", "label": "After image" },
    { "type": "text", "id": "after_alt", "label": "Alt text", "default": "Soft hydrated heel after treatment" },
    { "type": "text", "id": "after_caption", "label": "Caption (optional)", "default": "Three weeks later. Same foot, soft skin." },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "layout", "label": "Layout", "options": [
      { "value": "side-by-side", "label": "Side by side" },
      { "value": "stacked", "label": "Stacked" }
    ], "default": "side-by-side" },
    { "type": "text", "id": "fineprint", "label": "Fine print (optional)" },
    { "type": "color", "id": "bg", "label": "Background" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 }
  ],
  "presets": [{ "name": "Before / after pair" }]
}
{% endschema %}
