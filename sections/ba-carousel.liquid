{%- liquid
  assign max_w = section.settings.max_width | default: 1140
  assign autoplay = section.settings.autoplay | default: true
  assign interval = section.settings.interval | default: 6
-%}

<section class="bac" style="padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px; background:{{ section.settings.bg | default: 'transparent' }};">
  <div class="bac__inner" style="max-width:{{ max_w }}px;">
    {% if section.settings.eyebrow != blank %}
      <span class="bac__eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="bac__heading">{{ section.settings.heading }}{% if section.settings.heading_accent != blank %} <em>{{ section.settings.heading_accent }}</em>{% endif %}</h2>
    {% endif %}
    {% if section.settings.subhead != blank %}
      <p class="bac__sub">{{ section.settings.subhead }}</p>
    {% endif %}

    <div class="bac__viewport">
      <button type="button" class="bac__arrow bac__arrow--prev" data-bac-prev aria-label="Previous">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 6l-6 6 6 6"/></svg>
      </button>

      <div class="bac__track" data-bac-track aria-roledescription="carousel" aria-label="Customer before-and-after photos">
        {% for block in section.blocks %}
          {% if block.type == 'pair' %}
            {%- assign before_label = block.settings.before_label | default: 'Before' -%}
            {%- assign after_label = block.settings.after_label | default: 'After' -%}
            <article class="bac__card" data-bac-card aria-roledescription="slide" aria-label="{{ block.settings.name | default: 'Customer' | escape }} — {{ forloop.index }} of {{ section.blocks.size }}" {{ block.shopify_attributes }}>
              {% if block.settings.eyebrow != blank %}<span class="bac__card-eyebrow">{{ block.settings.eyebrow }}</span>{% endif %}
              {% if block.settings.heading != blank %}<h3 class="bac__card-heading">{{ block.settings.heading }}</h3>{% endif %}
              <div class="bac__split">
                <div class="bac__half">
                  {% if block.settings.before_image %}
                    <img src="{{ block.settings.before_image | image_url: width: 700, format: 'webp' }}"
                         srcset="{{ block.settings.before_image | image_url: width: 500, format: 'webp' }} 500w, {{ block.settings.before_image | image_url: width: 700, format: 'webp' }} 700w, {{ block.settings.before_image | image_url: width: 900, format: 'webp' }} 900w"
                         sizes="(max-width:760px) 50vw, 280px"
                         alt="{{ block.settings.name | default: 'Customer' | escape }} — before"
                         loading="lazy" decoding="async" width="700" height="900">
                  {% else %}
                    <div class="bac__placeholder">{{ before_label }}</div>
                  {% endif %}
                  <span class="bac__pill bac__pill--before">{{ before_label }}</span>
                </div>
                <div class="bac__half">
                  {% if block.settings.after_image %}
                    <img src="{{ block.settings.after_image | image_url: width: 700, format: 'webp' }}"
                         srcset="{{ block.settings.after_image | image_url: width: 500, format: 'webp' }} 500w, {{ block.settings.after_image | image_url: width: 700, format: 'webp' }} 700w, {{ block.settings.after_image | image_url: width: 900, format: 'webp' }} 900w"
                         sizes="(max-width:760px) 50vw, 280px"
                         alt="{{ block.settings.name | default: 'Customer' | escape }} — after"
                         loading="lazy" decoding="async" width="700" height="900">
                  {% else %}
                    <div class="bac__placeholder">{{ after_label }}</div>
                  {% endif %}
                  <span class="bac__pill bac__pill--after">{{ after_label }}</span>
                </div>
              </div>
              {% if block.settings.caption != blank %}
                <p class="bac__caption">{{ block.settings.caption }}</p>
              {% endif %}
            </article>
          {% endif %}
        {% endfor %}
      </div>

      <button type="button" class="bac__arrow bac__arrow--next" data-bac-next aria-label="Next">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6l6 6-6 6"/></svg>
      </button>
    </div>

    <div class="bac__dots" data-bac-dots role="tablist" aria-label="Slide navigation">
      {% for block in section.blocks %}
        {% if block.type == 'pair' %}
          <button type="button" class="bac__dot{% if forloop.first %} is-active{% endif %}" data-bac-dot data-index="{{ forloop.index0 }}" role="tab" aria-label="Go to slide {{ forloop.index }}" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"></button>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .bac { background: #ffffff; }
  .bac__inner { margin: 0 auto; padding: 0 20px; text-align: center; }
  .bac__eyebrow { display: inline-block; font-family: var(--font-heading); font-size: 11px; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; color: var(--muted, #7a6770); padding: 4px 12px; border: 1px solid var(--line, #ece4dc); border-radius: 999px; margin: 0 0 12px; }
  .bac__heading { font-family: var(--font-heading); font-size: clamp(1.7rem, 4vw, 2.4rem); font-weight: 600; color: var(--ink, #1a1216); margin: 0 0 8px; line-height: 1.14; letter-spacing: -0.022em; text-wrap: balance; font-variation-settings: "opsz" 96; }
  .bac__heading em { font-style: italic; font-weight: 600; color: var(--accent-deep, #3D2535); }
  .bac__sub { font-family: var(--font-body); font-size: 1rem; line-height: 1.5; color: var(--ink-2, #3a2a31); margin: 0 auto 26px; max-width: 580px; }

  .bac__viewport { position: relative; }
  .bac__track { display: flex; gap: 16px; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; padding: 8px 0 16px; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
  .bac__track::-webkit-scrollbar { display: none; }
  .bac__card { flex: 0 0 88%; scroll-snap-align: center; background: #ffffff; border: 1px solid var(--line, #ece4dc); border-radius: 18px; padding: 20px 18px 22px; box-shadow: 0 1px 2px rgba(42,28,18,.04), 0 14px 36px -22px rgba(42,28,18,.18); text-align: left; }
  @media (min-width: 760px) { .bac__card { flex: 0 0 calc(50% - 8px); padding: 26px 24px 28px; } }
  @media (min-width: 1100px) { .bac__card { flex: 0 0 calc(50% - 8px); } }

  .bac__card-eyebrow { display: inline-block; font-family: var(--font-heading); font-size: 10.5px; font-weight: 700; letter-spacing: .16em; text-transform: uppercase; color: var(--accent-deep, #3D2535); margin: 0 0 8px; }
  .bac__card-heading { font-family: var(--font-heading); font-size: clamp(1.15rem, 2.6vw, 1.45rem); font-weight: 600; color: var(--ink, #1a1216); margin: 0 0 14px; line-height: 1.2; letter-spacing: -0.018em; font-variation-settings: "opsz" 72; }

  .bac__split { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; border-radius: 14px; overflow: hidden; aspect-ratio: 16/10; background: var(--cream-soft, #fbf6ee); }
  .bac__half { position: relative; overflow: hidden; }
  .bac__half img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .bac__placeholder { display: grid; place-items: center; height: 100%; color: var(--muted, #7a6770); font-size: 13px; font-style: italic; }
  .bac__pill { position: absolute; top: 10px; font-family: var(--font-heading); font-weight: 700; font-size: 10px; letter-spacing: .14em; text-transform: uppercase; padding: 4px 10px; border-radius: 999px; }
  .bac__pill--before { left: 10px; background: rgba(255,255,255,.94); color: var(--ink, #1a1216); }
  .bac__pill--after { right: 10px; background: var(--accent-deep, #3D2535); color: #ffffff; }

  .bac__caption { font-family: var(--font-body); font-size: 14px; line-height: 1.5; color: var(--ink-2, #3a2a31); margin: 14px 0 0; font-style: italic; }

  .bac__arrow { display: none; position: absolute; top: 50%; transform: translateY(-50%); z-index: 2; width: 44px; height: 44px; border-radius: 50%; background: #ffffff; border: 1px solid var(--line, #ece4dc); color: var(--ink, #1a1216); cursor: pointer; align-items: center; justify-content: center; box-shadow: 0 8px 22px -10px rgba(42,28,18,.25); transition: transform .15s ease, background .15s ease; }
  .bac__arrow:hover { background: var(--accent, #5C3A4A); color: #ffffff; transform: translateY(-50%) scale(1.05); }
  .bac__arrow svg { width: 20px; height: 20px; }
  .bac__arrow--prev { left: -8px; }
  .bac__arrow--next { right: -8px; }
  @media (min-width: 760px) { .bac__arrow { display: inline-flex; } .bac__arrow--prev { left: -22px; } .bac__arrow--next { right: -22px; } }

  .bac__dots { display: flex; justify-content: center; gap: 8px; margin: 16px 0 0; }
  .bac__dot { width: 10px; height: 10px; border-radius: 50%; border: 1px solid var(--line, #ece4dc); background: transparent; padding: 0; cursor: pointer; transition: background .15s ease, border-color .15s ease, transform .15s ease; }
  .bac__dot.is-active { background: var(--accent, #5C3A4A); border-color: var(--accent, #5C3A4A); transform: scale(1.18); }
  .bac__dot:hover { border-color: var(--accent, #5C3A4A); }

  @media (prefers-reduced-motion: reduce) {
    .bac__track { scroll-behavior: auto; }
  }
</style>

<script>
  (function () {
    var roots = document.querySelectorAll('.bac');
    if (!roots.length) return;
    var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    roots.forEach(function (root) {
      var track = root.querySelector('[data-bac-track]');
      var prev = root.querySelector('[data-bac-prev]');
      var next = root.querySelector('[data-bac-next]');
      var dots = Array.prototype.slice.call(root.querySelectorAll('[data-bac-dot]'));
      var cards = Array.prototype.slice.call(root.querySelectorAll('[data-bac-card]'));
      if (!track || !cards.length) return;

      var autoplay = {{ autoplay | json }};
      var intervalMs = ({{ interval | json }} || 6) * 1000;
      var pauseTimer = null;
      var advanceTimer = null;

      function getCardWidth() {
        var first = cards[0];
        if (!first) return track.clientWidth;
        var rect = first.getBoundingClientRect();
        var styles = window.getComputedStyle(track);
        var gap = parseFloat(styles.columnGap || styles.gap || 16) || 0;
        return rect.width + gap;
      }

      function activeIndex() {
        var trackRect = track.getBoundingClientRect();
        var bestIndex = 0;
        var bestOverlap = 0;
        cards.forEach(function (card, i) {
          var r = card.getBoundingClientRect();
          var overlap = Math.min(r.right, trackRect.right) - Math.max(r.left, trackRect.left);
          if (overlap > bestOverlap) { bestOverlap = overlap; bestIndex = i; }
        });
        return bestIndex;
      }

      function syncDots() {
        var i = activeIndex();
        dots.forEach(function (d, idx) {
          var active = idx === i;
          d.classList.toggle('is-active', active);
          d.setAttribute('aria-selected', active ? 'true' : 'false');
        });
      }

      function scrollToIndex(i) {
        if (i < 0) i = cards.length - 1;
        if (i >= cards.length) i = 0;
        var x = cards[i].offsetLeft - track.offsetLeft;
        track.scrollTo({ left: x, behavior: prefersReducedMotion ? 'auto' : 'smooth' });
      }

      function nextSlide() {
        var current = activeIndex();
        var nextIdx = current + 1 >= cards.length ? 0 : current + 1;
        scrollToIndex(nextIdx);
      }

      function prevSlide() {
        var current = activeIndex();
        var prevIdx = current - 1 < 0 ? cards.length - 1 : current - 1;
        scrollToIndex(prevIdx);
      }

      function startAutoplay() {
        if (!autoplay || prefersReducedMotion) return;
        stopAutoplay();
        advanceTimer = setInterval(nextSlide, intervalMs);
      }

      function stopAutoplay() {
        if (advanceTimer) { clearInterval(advanceTimer); advanceTimer = null; }
      }

      function pauseAutoplay(resumeAfter) {
        stopAutoplay();
        if (pauseTimer) clearTimeout(pauseTimer);
        if (typeof resumeAfter === 'number') {
          pauseTimer = setTimeout(startAutoplay, resumeAfter);
        }
      }

      // Wire up controls
      if (next) next.addEventListener('click', function () { pauseAutoplay(8000); nextSlide(); });
      if (prev) prev.addEventListener('click', function () { pauseAutoplay(8000); prevSlide(); });
      dots.forEach(function (d) {
        d.addEventListener('click', function () {
          var i = parseInt(d.getAttribute('data-index') || '0', 10);
          pauseAutoplay(8000);
          scrollToIndex(i);
        });
      });

      // Pause on user interaction
      ['mouseenter', 'focusin', 'touchstart', 'pointerdown'].forEach(function (evt) {
        root.addEventListener(evt, function () { pauseAutoplay(); }, { passive: true });
      });
      ['mouseleave', 'focusout'].forEach(function (evt) {
        root.addEventListener(evt, function () { pauseAutoplay(8000); }, { passive: true });
      });

      // Sync dots on manual scroll
      var scrollSyncTimer = null;
      track.addEventListener('scroll', function () {
        if (scrollSyncTimer) clearTimeout(scrollSyncTimer);
        scrollSyncTimer = setTimeout(syncDots, 80);
      }, { passive: true });

      // Only autoplay when carousel is in viewport
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) startAutoplay();
            else stopAutoplay();
          });
        }, { threshold: 0.4 });
        io.observe(root);
      } else {
        startAutoplay();
      }

      // Initial sync
      syncDots();
    });
  })();
</script>

{% schema %}
{
  "name": "BA carousel",
  "settings": [
    { "type": "header", "content": "Section heading" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The proof" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real customers." },
    { "type": "text", "id": "heading_accent", "label": "Italic accent", "default": "Real heels." },
    { "type": "textarea", "id": "subhead", "label": "Subhead" },
    { "type": "header", "content": "Carousel behavior" },
    { "type": "checkbox", "id": "autoplay", "label": "Auto-advance every 6 seconds", "default": true },
    { "type": "range", "id": "interval", "label": "Auto-advance interval", "min": 3, "max": 12, "step": 1, "unit": "s", "default": 6 },
    { "type": "header", "content": "Layout" },
    { "type": "color", "id": "bg", "label": "Background" },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 720, "max": 1280, "step": 20, "unit": "px", "default": 1140 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 }
  ],
  "blocks": [
    {
      "type": "pair",
      "name": "Before/after pair",
      "settings": [
        { "type": "image_picker", "id": "before_image", "label": "Before image" },
        { "type": "text", "id": "before_label", "label": "Before label", "default": "Before" },
        { "type": "image_picker", "id": "after_image", "label": "After image" },
        { "type": "text", "id": "after_label", "label": "After label", "default": "After" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow (e.g. customer name + duration)" },
        { "type": "text", "id": "heading", "label": "Card heading" },
        { "type": "text", "id": "name", "label": "Customer name (used for alt text)" },
        { "type": "textarea", "id": "caption", "label": "Caption / quote" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [{
    "name": "BA carousel",
    "blocks": [
      { "type": "pair" },
      { "type": "pair" },
      { "type": "pair" }
    ]
  }]
}
{% endschema %}
