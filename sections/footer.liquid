<footer class="footer">
  <div class="footer__inner">
    <div class="page-width">
      <div class="site-header__brand">{{ section.settings.brand_text }}</div>
      <div class="footer__columns" style="margin-top: 2rem;">
        {% for block in section.blocks %}
          <div {{ block.shopify_attributes }}>
            <div class="footer__heading">{{ block.settings.heading }}</div>
            <div class="footer__menu">
              {% for link in block.settings.menu.links %}
                <a href="{{ link.url }}">{{ link.title }}</a>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "brand_text", "label": "Brand text", "default": "KNEURO" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
