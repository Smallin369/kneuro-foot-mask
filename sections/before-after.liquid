    { "type": "text", "id": "col_3", "label": "Column 3", "default": "Generic peel" },
    { "type": "text", "id": "col_4", "label": "Column 4", "default": "Foot cream" },
    { "type": "text", "id": "row_1_label", "label": "Row 1 label", "default": "Pregnancy-safe" },
    { "type": "text", "id": "row_1_brand", "label": "Row 1 brand value (yes/no/partial)", "default": "yes" },
    { "type": "text", "id": "row_1_c2", "label": "Row 1 col 2", "default": "no" },
    { "type": "text", "id": "row_1_c3", "label": "Row 1 col 3", "default": "no" },
    { "type": "text", "id": "row_1_c4", "label": "Row 1 col 4", "default": "yes" },
    { "type": "text", "id": "row_2_label", "label": "Row 2 label", "default": "No harsh acids" },
    { "type": "text", "id": "row_2_brand", "label": "Row 2 brand", "default": "yes" },
    { "type": "text", "id": "row_2_c2", "label": "Row 2 col 2", "default": "no" },
    { "type": "text", "id": "row_2_c3", "label": "Row 2 col 3", "default": "no" },
    { "type": "text", "id": "row_2_c4", "label": "Row 2 col 4", "default": "yes" },
    { "type": "text", "id": "row_3_label", "label": "Row 3 label", "default": "Visible result in 30 min" },
    { "type": "text", "id": "row_3_brand", "label": "Row 3 brand", "default": "yes" },
    { "type": "text", "id": "row_3_c2", "label": "Row 3 col 2", "default": "no" },
    { "type": "text", "id": "row_3_c3", "label": "Row 3 col 3", "default": "no" },
    { "type": "text", "id": "row_3_c4", "label": "Row 3 col 4", "default": "no" },
    { "type": "text", "id": "row_4_label", "label": "Row 4 label", "default": "No painful peeling" },
    { "type": "text", "id": "row_4_brand", "label": "Row 4 brand", "default": "yes" },
    { "type": "text", "id": "row_4_c2", "label": "Row 4 col 2", "default": "no" },
    { "type": "text", "id": "row_4_c3", "label": "Row 4 col 3", "default": "no" },
    { "type": "text", "id": "row_4_c4", "label": "Row 4 col 4", "default": "yes" },
    { "type": "text", "id": "row_5_label", "label": "Row 5 label", "default": "Goat milk + niacinamide" },
