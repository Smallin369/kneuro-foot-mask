{%- liquid
  assign layout = section.settings.layout | default: 'side-by-side'
  assign max_width = section.settings.max_width | default: 1100
-%}

<section class="ba" style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;background:{{ section.settings.bg | default: 'transparent' }};">
  <div class="ba__inner" style="max-width:{{ max_width }}px;">
    {%- if section.settings.kicker != blank -%}
      <div class="ba__kicker">{{ section.settings.kicker }}</div>
    {%- endif -%}
    {%- if section.settings.heading_lead != blank or section.settings.heading_accent != blank -%}
      <h2 class="ba__heading">{{ section.settings.heading_lead }} <em>{{ section.settings.heading_accent }}</em></h2>
    {%- endif -%}
    {%- if section.settings.subhead != blank -%}
      <p class="ba__sub">{{ section.settings.subhead }}</p>
    {%- endif -%}

    {%- assign image_blocks = section.blocks | where: 'type', 'image_card' -%}
    {%- if image_blocks.size > 0 -%}
      <div class="ba__grid ba__grid--{{ layout }}">
        {%- for block in image_blocks -%}
          <figure class="ba__cell" {{ block.shopify_attributes }}>
            {% if block.settings.image %}
              <img src="{{ block.settings.image | image_url: width: 900, format: 'webp' }}" srcset="{{ block.settings.image | image_url: width: 600, format: 'webp' }} 600w, {{ block.settings.image | image_url: width: 900, format: 'webp' }} 900w, {{ block.settings.image | image_url: width: 1200, format: 'webp' }} 1200w" sizes="(max-width:768px) 100vw, 480px" alt="{{ block.settings.alt | default: block.settings.label | escape }}" loading="lazy" width="800" height="800">
            {% else %}
              <div class="ba__placeholder">Add image</div>
            {% endif %}
            <figcaption>
              {% if block.settings.label != blank %}
                <span class="ba__tag" style="background:{{ block.settings.label_bg | default: '#f4e7e1' }};color:{{ block.settings.label_color | default: '#8c4a32' }};">{{ block.settings.label }}</span>
              {% endif %}
              {% if block.settings.caption != blank %}
                <span class="ba__caption">{{ block.settings.caption }}</span>
              {% endif %}
            </figcaption>
          </figure>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- assign review_blocks = section.blocks | where: 'type', 'review' -%}
    {%- if review_blocks.size > 0 -%}
      <div class="ba__reviews">
        {%- for block in review_blocks -%}
          {%- assign initial = block.settings.name | default: '?' | slice: 0, 1 -%}
          <article class="ba__review" {{ block.shopify_attributes }}>
            <div class="ba__stars">★★★★★</div>
            <p class="ba__quote">{{ block.settings.quote }}</p>
            <div class="ba__meta">
              <span class="ba__avatar" aria-hidden="true">{{ initial }}</span>
              <span class="ba__attr">
                <span class="ba__name">{{ block.settings.name }}</span>
                {% if block.settings.role != blank %}
                  <span class="ba__role">{{ block.settings.role }}{% if block.settings.verified %} · <span class="ba__verified">✓ Verified buyer</span>{% endif %}</span>
                {% endif %}
              </span>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <div class="ba__cta-wrap">
        <a class="ba__cta" href="{{ section.settings.cta_url | default: '/products/goat-milk-callus-mask' }}">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .ba { background: #fff; }
  .ba__inner { margin: 0 auto; padding: 0 20px; text-align: center; }
  .ba__kicker { display: inline-block; padding: 5px 12px; border: 1px solid var(--line); border-radius: 999px; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--ink); font-family: var(--font-heading); font-weight: 700; margin: 0 0 12px; }
  .ba__heading { font-family: var(--font-heading); font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 700; color: var(--ink); margin: 0 0 8px; line-height: 1.2; }
  .ba__heading em { font-style: italic; font-weight: 700; color: var(--accent); }
  .ba__sub { color: var(--ink-2); font-size: 16px; line-height: 1.5; margin: 0 auto 28px; max-width: 640px; }
  .ba__grid { display: grid; gap: 16px; margin: 0 0 32px; }
  .ba__grid--side-by-side { grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
  .ba__grid--stacked { grid-template-columns: 1fr; max-width: 540px; margin-left: auto; margin-right: auto; }
  .ba__cell { margin: 0; }
  .ba__cell img { width: 100%; height: auto; border-radius: 14px; box-shadow: 0 12px 30px -12px rgba(42,28,18,.18); display: block; aspect-ratio: 1/1; object-fit: cover; }
  .ba__placeholder { aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; background: var(--cream); color: var(--muted); border-radius: 14px; font-size: 14px; }
  .ba__cell figcaption { display: flex; flex-direction: column; align-items: center; gap: 6px; margin-top: 12px; }
  .ba__tag { display: inline-block; padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; font-family: var(--font-heading); }
  .ba__caption { font-size: 13px; color: var(--muted); font-style: italic; line-height: 1.45; max-width: 320px; }
  .ba__reviews { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; margin: 0 0 24px; text-align: left; }
  .ba__review { background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 18px 20px; }
  .ba__stars { color: #f5b14a; font-size: 13px; letter-spacing: 2px; margin-bottom: 10px; }
  .ba__quote { font-family: var(--font-body); font-size: 15px; line-height: 1.55; color: var(--ink-2); margin: 0 0 14px; }
  .ba__meta { display: flex; align-items: center; gap: 12px; padding-top: 12px; border-top: 1px solid var(--line); }
  .ba__avatar { flex: 0 0 36px; width: 36px; height: 36px; border-radius: 50%; background: var(--cream); color: var(--ink); display: grid; place-items: center; font-family: var(--font-heading); font-weight: 700; font-size: 14px; }
  .ba__attr { display: flex; flex-direction: column; line-height: 1.3; }
  .ba__name { font-weight: 700; font-size: 13px; color: var(--ink); }
  .ba__role { font-size: 12px; color: var(--muted); }
  .ba__verified { color: #1f6c2f; font-weight: 600; }
  .ba__cta-wrap { margin-top: 24px; }
  .ba__cta { display: inline-block; padding: 16px 32px; background: var(--accent); color: #fff; text-decoration: none; border-radius: 999px; font-weight: 700; font-size: 15px; }
  @media (max-width: 600px) { .ba__grid--side-by-side { grid-template-columns: 1fr; gap: 20px; } }
</style>

{% schema %}
{
  "name": "Before & after",
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Real customers, real heels" },
    { "type": "text", "id": "heading_lead", "label": "Heading lead", "default": "Before & after," },
    { "type": "text", "id": "heading_accent", "label": "Italic accent", "default": "in 30 minutes." },
    { "type": "textarea", "id": "subhead", "label": "Subhead" },
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "layout",
      "label": "Image layout",
      "options": [
        { "value": "side-by-side", "label": "Side by side" },
        { "value": "stacked", "label": "Stacked" }
      ],
      "default": "side-by-side"
    },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 480, "max": 1200, "step": 20, "unit": "px", "default": 1100 },
    { "type": "color", "id": "bg", "label": "Background" },
    { "type": "header", "content": "Bottom CTA (optional)" },
    { "type": "text", "id": "cta_label", "label": "CTA label" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 }
  ],
  "blocks": [
    {
      "type": "image_card",
      "name": "Image (Before/After)",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Alt text", "default": "Image" },
        { "type": "text", "id": "label", "label": "Label (BEFORE / AFTER / custom)", "default": "Before" },
        { "type": "color", "id": "label_bg", "label": "Label background", "default": "#f4e7e1" },
        { "type": "color", "id": "label_color", "label": "Label text color", "default": "#8c4a32" },
        { "type": "text", "id": "caption", "label": "Caption" }
      ]
    },
    {
      "type": "review",
      "name": "Customer review",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Add the customer review text here." },
        { "type": "text", "id": "name", "label": "Customer name", "default": "Jane D." },
        { "type": "text", "id": "role", "label": "Role / context (e.g. Sensitive skin)" },
        { "type": "checkbox", "id": "verified", "label": "Show 'Verified buyer' badge", "default": true }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [{
    "name": "Before & after",
    "blocks": [
      { "type": "image_card", "settings": { "label": "Before", "label_bg": "#f4e7e1", "label_color": "#8c4a32" }},
      { "type": "image_card", "settings": { "label": "After", "label_bg": "#d6efd9", "label_color": "#1f6c2f" }}
    ]
  }]
}
{% endschema %}
