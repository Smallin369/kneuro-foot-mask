<section class="container" style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color | default: 'transparent' }};">
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'kicker' %}
        <div class="section-kicker" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
      {% when 'heading' %}
        <h2 class="section-title" {{ block.shopify_attributes }}>{{ block.settings.lead }} <em>{{ block.settings.accent }}</em></h2>
      {% when 'subheading' %}
        <p class="section-sub" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
      {% when 'steps_row' %}
        {%- liquid
          assign step_imgs = '' | split: ','
        -%}
        <div class="steps" {{ block.shopify_attributes }}>
          {% for i in (1..3) %}
            {%- liquid
              assign k_title = 's' | append: i | append: '_title'
              assign k_body = 's' | append: i | append: '_body'
              assign k_image = 's' | append: i | append: '_image'
              assign s_title = block.settings[k_title]
              assign s_body = block.settings[k_body]
              assign s_image = block.settings[k_image]
              assign fallback = step_imgs[forloop.index0]
              assign num_str = '0' | append: i
            -%}
            {% if s_title != blank %}
              <div class="step">
                {% if s_image %}
                  <div class="img">
                    <img src="{{ s_image | image_url: width: 900, format: 'webp' }}" alt="{{ s_title | escape }}" loading="lazy" width="600" height="450">
                  </div>
                {% elsif fallback != blank %}
                  <div class="img">
                    <img src="{{ fallback | asset_url }}" alt="{{ s_title | escape }}" loading="lazy" width="600" height="450">
                  </div>
                {% else %}
                  <div class="img img--placeholder"><span class="step-num-big">{{ num_str }}</span></div>
                {% endif %}
                <div class="body">
                  <div class="num">{{ num_str }}</div>
                  <h3>{{ s_title }}</h3>
                  <p>{{ s_body }}</p>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% when 'rich_text' %}
        <div class="rich-text-block" {{ block.shopify_attributes }}>{{ block.settings.content }}</div>
      {% when '@app' %}
        {% render block %}
    {% endcase %}
  {% endfor %}
</section>

{% schema %}
{
  "name": "How it works",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 88 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 88 },
    { "type": "color", "id": "bg_color", "label": "Background" }
  ],
  "blocks": [
    { "type": "@app" },
    { "type": "kicker", "name": "Kicker", "settings": [ { "type": "text", "id": "text", "label": "Text", "default": "How it works" } ] },
    { "type": "heading", "name": "Heading", "settings": [
      { "type": "text", "id": "lead", "label": "Lead", "default": "Three steps," },
      { "type": "text", "id": "accent", "label": "Italic accent", "default": "under a minute." }
    ]},
    { "type": "subheading", "name": "Subheading", "settings": [ { "type": "textarea", "id": "text", "label": "Text", "default": "Your pet, your couch, your car seat, your favorite sweater — same mitt." } ] },
    { "type": "steps_row", "name": "Steps row (3 steps)", "limit": 1, "settings": [
      { "type": "header", "content": "Step 1" },
      { "type": "image_picker", "id": "s1_image", "label": "Image (optional)" },
      { "type": "text", "id": "s1_title", "label": "Title", "default": "Slip it on" },
      { "type": "textarea", "id": "s1_body", "label": "Body", "default": "Adjustable strap fits any hand." },
      { "type": "header", "content": "Step 2" },
      { "type": "image_picker", "id": "s2_image", "label": "Image (optional)" },
      { "type": "text", "id": "s2_title", "label": "Title", "default": "Wait 30 minutes" },
      { "type": "textarea", "id": "s2_body", "label": "Body", "default": "Fur lifts into the mesh." },
      { "type": "header", "content": "Step 3" },
      { "type": "image_picker", "id": "s3_image", "label": "Image (optional)" },
      { "type": "text", "id": "s3_title", "label": "Title", "default": "Peel & rinse" },
      { "type": "textarea", "id": "s3_body", "label": "Body", "default": "Roll the mat off, rinse clean." }
    ]},
    { "type": "rich_text", "name": "Rich text", "settings": [ { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Add anything here.</p>" } ] }
  ],
  "max_blocks": 20,
  "presets": [{
    "name": "How it works",
    "blocks": [
      { "type": "kicker" },
      { "type": "heading" },
      { "type": "subheading" },
      { "type": "steps_row" }
    ]
  }]
}
{% endschema %}
