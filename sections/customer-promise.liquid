{%- liquid
  assign hero = section.settings.hero_image
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign subhead = section.settings.subhead
-%}

<section class="cpx" style="padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px; background:{{ section.settings.bg | default: 'transparent' }};">
  <div class="cpx__inner">
    {% if hero %}
      <figure class="cpx__hero">
        <img src="{{ hero | image_url: width: 1200, format: 'webp' }}"
             srcset="{{ hero | image_url: width: 600, format: 'webp' }} 600w, {{ hero | image_url: width: 900, format: 'webp' }} 900w, {{ hero | image_url: width: 1200, format: 'webp' }} 1200w"
             sizes="(max-width:768px) 100vw, 720px"
             alt="{{ heading | default: 'Kneuro' | escape }}"
             loading="lazy" decoding="async" width="1200" height="900">
      </figure>
    {% endif %}

    {% if eyebrow != blank %}<span class="cpx__eyebrow">{{ eyebrow }}</span>{% endif %}
    {% if heading != blank %}<h2 class="cpx__heading">{{ heading }}</h2>{% endif %}
    {% if subhead != blank %}<p class="cpx__sub">{{ subhead }}</p>{% endif %}

    <ul class="cpx__grid">
      {% for i in (1..4) %}
        {%- assign title_key = 'title_' | append: i -%}
        {%- assign body_key = 'body_' | append: i -%}
        {%- assign icon_key = 'icon_' | append: i -%}
        {%- assign t = section.settings[title_key] -%}
        {%- assign b = section.settings[body_key] -%}
        {%- assign ic = section.settings[icon_key] | default: 'clock' -%}
        {% if t != blank %}
          <li class="cpx__tile">
            <span class="cpx__icon" aria-hidden="true">
              {%- case ic -%}
                {%- when 'clock' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2.5"/></svg>
                {%- when 'sparkle' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/><circle cx="12" cy="12" r="3"/></svg>
                {%- when 'heart' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7.5-4.5-9.4-9.2C1.2 7.8 4 4.5 7.5 4.5c2 0 3.5 1 4.5 2.6 1-1.6 2.5-2.6 4.5-2.6 3.5 0 6.3 3.3 4.9 7.3C19.5 16.5 12 21 12 21z"/></svg>
                {%- when 'refresh' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 4v5h-5"/></svg>
                {%- when 'leaf' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 19c0-9 7-14 16-14 0 9-5 16-14 16-1 0-2 0-2-2z"/><path d="M5 19c4-4 7-7 11-9"/></svg>
                {%- when 'shield' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z"/><path d="M9 12l2 2 4-4"/></svg>
                {%- when 'drop' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3s-6 7-6 11a6 6 0 0 0 12 0c0-4-6-11-6-11z"/></svg>
                {%- when 'check' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8 12.5l3 3 5-6"/></svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/></svg>
              {%- endcase -%}
            </span>
            <h3 class="cpx__title">{{ t }}</h3>
            {% if b != blank %}<p class="cpx__body">{{ b }}</p>{% endif %}
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</section>

<style>
  .cpx { background: var(--cream-soft, #faf8f5); }
  .cpx__inner { max-width: 980px; margin: 0 auto; padding: 0 20px; text-align: center; }
  .cpx__hero { margin: 0 auto 28px; max-width: 680px; border-radius: 18px; overflow: hidden; box-shadow: 0 14px 40px -22px rgba(42,28,18,.25); }
  .cpx__hero img { display: block; width: 100%; height: auto; aspect-ratio: 4/3; object-fit: cover; }
  .cpx__eyebrow { display: inline-block; font-family: var(--font-heading); font-size: 11px; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; color: var(--muted, #71665C); padding: 4px 12px; border: 1px solid var(--line, #e8dfd3); border-radius: 999px; margin: 0 0 12px; }
  .cpx__heading { font-family: var(--font-heading); font-size: clamp(1.4rem, 3.6vw, 1.9rem); font-weight: 800; color: var(--ink, #1a1a1a); margin: 0 0 8px; line-height: 1.18; letter-spacing: -0.02em; text-wrap: balance; }
  .cpx__sub { font-family: var(--font-body); font-size: .98rem; line-height: 1.5; color: var(--ink-2, #2a2a2a); margin: 0 auto 26px; max-width: 560px; }
  .cpx__grid { list-style: none; padding: 0; margin: 0; display: grid; gap: 12px; grid-template-columns: 1fr; text-align: left; }
  @media(min-width: 600px) { .cpx__grid { grid-template-columns: 1fr 1fr; gap: 14px; } }
  .cpx__tile { position: relative; background: linear-gradient(180deg, #ffffff 0%, #fbf6ee 100%); border: 1px solid var(--line, #ece4dc); border-radius: 20px; padding: 30px 26px 28px; box-shadow: 0 1px 2px rgba(42,28,18,.04), 0 14px 36px -22px rgba(42,28,18,.18); transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease; overflow: hidden; }
  .cpx__tile::before { content: ""; position: absolute; top: 0; left: 0; width: 28px; height: 4px; border-radius: 0 0 4px 4px; background: var(--accent, #5C3A4A); }
  .cpx__tile:hover { transform: translateY(-3px); box-shadow: 0 2px 6px rgba(42,28,18,.06), 0 22px 48px -18px rgba(42,28,18,.22); border-color: rgba(92,58,74,.24); }
  .cpx__icon { display: inline-flex; align-items: center; justify-content: center; width: 60px; height: 60px; border-radius: 16px; background: var(--cream, #f4ede2); color: var(--accent-deep, #3D2535); margin: 0 0 16px; transition: transform .22s ease; }
  .cpx__icon svg { width: 30px; height: 30px; display: block; }
  .cpx__tile:hover .cpx__icon { transform: rotate(-4deg) scale(1.06); }
  /* Plum-family swatches: variety within a single hue family for cohesion */
  .cpx__tile:nth-child(1) .cpx__icon { background: #ede0e4; color: #5C3A4A; }
  .cpx__tile:nth-child(1)::before { background: #5C3A4A; }
  .cpx__tile:nth-child(2) .cpx__icon { background: #e7e3d7; color: #5e533c; }
  .cpx__tile:nth-child(2)::before { background: #5e533c; }
  .cpx__tile:nth-child(3) .cpx__icon { background: #f1e2dc; color: #8a4357; }
  .cpx__tile:nth-child(3)::before { background: #8a4357; }
  .cpx__tile:nth-child(4) .cpx__icon { background: #e0d8e0; color: #3D2535; }
  .cpx__tile:nth-child(4)::before { background: #3D2535; }
  .cpx__title { font-family: var(--font-heading); font-size: 1.18rem; font-weight: 600; color: var(--ink, #1a1216); margin: 0 0 6px; line-height: 1.2; letter-spacing: -0.012em; font-variation-settings: "opsz" 72; }
  .cpx__body { font-family: var(--font-body); font-size: .94rem; line-height: 1.5; color: var(--muted, #7a6770); margin: 0; }
</style>

{% schema %}
{
  "name": "Clarity tiles",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image (optional, sits above heading)" },
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What you get" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What this actually does" },
    { "type": "textarea", "id": "subhead", "label": "Subhead" },
    { "type": "header", "content": "Tile 1" },
    { "type": "text", "id": "title_1", "label": "Title", "default": "Soft skin in 30 minutes" },
    { "type": "textarea", "id": "body_1", "label": "Body", "default": "One short session. No 5-day peeling phase." },
    { "type": "select", "id": "icon_1", "label": "Icon", "default": "clock", "options": [
      { "value": "clock", "label": "Clock" },
      { "value": "sparkle", "label": "Sparkle" },
      { "value": "heart", "label": "Heart" },
      { "value": "refresh", "label": "Refresh / Refund" },
      { "value": "leaf", "label": "Leaf" },
      { "value": "shield", "label": "Shield" },
      { "value": "drop", "label": "Drop" },
      { "value": "check", "label": "Check" }
    ]},
    { "type": "header", "content": "Tile 2" },
    { "type": "text", "id": "title_2", "label": "Title", "default": "No harsh acids" },
    { "type": "textarea", "id": "body_2", "label": "Body", "default": "Goat milk + niacinamide. No salicylic, no glycolic, no burning." },
    { "type": "select", "id": "icon_2", "label": "Icon", "default": "leaf", "options": [
      { "value": "clock", "label": "Clock" },
      { "value": "sparkle", "label": "Sparkle" },
      { "value": "heart", "label": "Heart" },
      { "value": "refresh", "label": "Refresh / Refund" },
      { "value": "leaf", "label": "Leaf" },
      { "value": "shield", "label": "Shield" },
      { "value": "drop", "label": "Drop" },
      { "value": "check", "label": "Check" }
    ]},
    { "type": "header", "content": "Tile 3" },
    { "type": "text", "id": "title_3", "label": "Title", "default": "Pregnancy-safe" },
    { "type": "textarea", "id": "body_3", "label": "Body", "default": "Gentle enough for pregnancy, diabetics, sensitive skin." },
    { "type": "select", "id": "icon_3", "label": "Icon", "default": "shield", "options": [
      { "value": "clock", "label": "Clock" },
      { "value": "sparkle", "label": "Sparkle" },
      { "value": "heart", "label": "Heart" },
      { "value": "refresh", "label": "Refresh / Refund" },
      { "value": "leaf", "label": "Leaf" },
      { "value": "shield", "label": "Shield" },
      { "value": "drop", "label": "Drop" },
      { "value": "check", "label": "Check" }
    ]},
    { "type": "header", "content": "Tile 4" },
    { "type": "text", "id": "title_4", "label": "Title", "default": "30-day money-back" },
    { "type": "textarea", "id": "body_4", "label": "Body", "default": "If your heels aren't softer, full refund. No questions." },
    { "type": "select", "id": "icon_4", "label": "Icon", "default": "refresh", "options": [
      { "value": "clock", "label": "Clock" },
      { "value": "sparkle", "label": "Sparkle" },
      { "value": "heart", "label": "Heart" },
      { "value": "refresh", "label": "Refresh / Refund" },
      { "value": "leaf", "label": "Leaf" },
      { "value": "shield", "label": "Shield" },
      { "value": "drop", "label": "Drop" },
      { "value": "check", "label": "Check" }
    ]},
    { "type": "header", "content": "Layout" },
    { "type": "color", "id": "bg", "label": "Background" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 }
  ],
  "presets": [{ "name": "Clarity tiles" }]
}
{% endschema %}
