<section class="section-shell section-cream">
  <div class="page-width section-pad">
    {% if section.settings.eyebrow != blank %}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{% endif %}
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    {% if section.blocks.size > 0 %}
      <table class="comparison-table">
        <thead>
          <tr>
            <th>{{ section.settings.column_label }}</th>
            <th>{{ section.settings.column_kneuro }}</th>
            <th>{{ section.settings.column_other }}</th>
          </tr>
        </thead>
        <tbody>
          {% for block in section.blocks %}
            <tr {{ block.shopify_attributes }}>
              <td>{{ block.settings.label }}</td>
              <td>{{ block.settings.kneuro }}</td>
              <td>{{ block.settings.other }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Comparison table",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why people switch" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Kneuro vs. harsh foot peels" },
    { "type": "text", "id": "column_label", "label": "Left column heading", "default": "Metric" },
    { "type": "text", "id": "column_kneuro", "label": "Middle column heading", "default": "Kneuro" },
    { "type": "text", "id": "column_other", "label": "Right column heading", "default": "Other peels" }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Peeling phase" },
        { "type": "text", "id": "kneuro", "label": "Kneuro", "default": "No peeling" },
        { "type": "text", "id": "other", "label": "Other", "default": "Usually 5-7 days" }
      ]
    }
  ]
}
{% endschema %}
