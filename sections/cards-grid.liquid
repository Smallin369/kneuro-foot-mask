<section class="section-shell {% if section.settings.surface == 'paper' %}section-paper{% elsif section.settings.surface == 'dark' %}section-dark{% else %}section-cream{% endif %}">
  <div class="page-width section-pad">
    {% if section.settings.eyebrow != blank %}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{% endif %}
    {% if section.settings.heading != blank %}<h2 class="section-title">{{ section.settings.heading }}</h2>{% endif %}
    {% if section.settings.subheading != blank %}<div class="section-subtitle">{{ section.settings.subheading }}</div>{% endif %}
    <div class="{% if section.settings.columns == '3' %}grid-3{% else %}grid-2{% endif %}" style="margin-top: 2rem;">
      {% for block in section.blocks %}
        <article class="card {% if block.type == 'testimonial' %}quote-card{% endif %}" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="media-frame" style="margin-bottom: 1rem;">
              {% render 'media-or-placeholder', image: block.settings.image, label: block.settings.placeholder_label %}
            </div>
          {% endif %}
          {% if block.settings.kicker != blank %}<div class="eyebrow" style="justify-content: flex-start;">{{ block.settings.kicker }}</div>{% endif %}
          {% if block.settings.title != blank %}<h3 style="margin: .875rem 0 .5rem; font: 400 1.55rem/1.15 var(--font-display);">{{ block.settings.title }}</h3>{% endif %}
          {% if block.settings.text != blank %}<div class="rte">{{ block.settings.text }}</div>{% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cards grid",
  "settings": [
    { "type": "select", "id": "surface", "label": "Surface", "default": "paper", "options": [ { "value": "cream", "label": "Cream" }, { "value": "paper", "label": "Paper" }, { "value": "dark", "label": "Dark" } ] },
    { "type": "select", "id": "columns", "label": "Columns", "default": "3", "options": [ { "value": "2", "label": "2" }, { "value": "3", "label": "3" } ] },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "placeholder_label", "label": "Placeholder label", "default": "Card image" },
        { "type": "text", "id": "kicker", "label": "Kicker" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Card text</p>" }
      ]
    },
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Verified buyer" },
        { "type": "text", "id": "title", "label": "Headline", "default": "Soft heels, no fuss." },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Use this for reviews or before/after captions.</p>" }
      ]
    }
  ]
}
{% endschema %}
