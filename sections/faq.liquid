<section class="section-shell section-cream">
  <div class="page-width section-pad">
    {% if section.settings.eyebrow != blank %}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{% endif %}
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    <div class="faq-list">
      {% for block in section.blocks %}
        <div class="faq-item" data-faq-item {{ block.shopify_attributes }}>
          <button type="button" data-faq-trigger aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}" style="width:100%;display:flex;justify-content:space-between;gap:1rem;background:none;border:0;padding:0;text-align:left;color:inherit;">
            <span style="font-size: 1.3rem;">{{ block.settings.question }}</span>
            <span data-faq-icon style="font: 500 1rem/1 var(--font-mono);">{% if forloop.first %}−{% else %}+{% endif %}</span>
          </button>
          <div class="faq-answer rte" data-faq-answer {% unless forloop.first %}hidden{% endunless %} style="padding-top: .75rem; color: var(--color-muted);">
            {{ block.settings.answer }}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Before you order" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The honest answers." }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Will it peel my skin?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>No. This theme keeps the answer in a block, not hardcoded in the section markup.</p>" }
      ]
    }
  ]
}
{% endschema %}
