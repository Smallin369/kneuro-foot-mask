<section class="rr" style="padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px; background:{{ section.settings.bg | default: 'transparent' }};">
  <div class="rr__inner">
    {% if section.settings.kicker != blank %}<span class="rr__kicker">{{ section.settings.kicker }}</span>{% endif %}
    <h2 class="rr__heading">{{ section.settings.heading_lead }} <em>{{ section.settings.heading_accent }}</em></h2>
    {% if section.settings.subhead != blank %}<p class="rr__sub">{{ section.settings.subhead }}</p>{% endif %}

    <div class="rr__grid">
      {% for block in section.blocks %}
        <div class="rr__card" {{ block.shopify_attributes }}>
          {% if block.settings.image %}
            <img class="rr__img" src="{{ block.settings.image | image_url: width: 600 }}" srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 600 }} 600w" sizes="(max-width:768px) 100vw, 320px" alt="Customer photo" loading="lazy" width="500" height="500">
          {% elsif block.settings.image_asset != blank %}
            <img class="rr__img" src="{{ block.settings.image_asset | asset_url }}" alt="Customer photo" loading="lazy" width="500" height="500">
          {% elsif block.settings.image_url != blank %}
            <img class="rr__img" src="{{ block.settings.image_url }}" alt="Customer photo" loading="lazy" width="500" height="500">
          {% endif %}
          <div class="rr__body">
            <div class="rr__stars">
              {%- assign r = block.settings.rating | default: 5 -%}
              {%- for i in (1..5) -%}{% if i <= r %}★{% else %}☆{% endif %}{%- endfor -%}
            </div>
            <p class="rr__text">{{ block.settings.review }}</p>
            <div class="rr__by">
              <strong>{{ block.settings.name | default: 'Verified buyer' }}</strong>
              {% if block.settings.meta != blank %} · <span>{{ block.settings.meta }}</span>{% endif %}
              <span class="rr__verified">✓ Verified</span>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.cta_label != blank %}
      <a class="rr__cta" href="{{ section.settings.cta_url | default: '/products/furgone-gloves' }}">{{ section.settings.cta_label }}</a>
    {% endif %}
  </div>
</section>

<style>
  .rr { background: #fff; }
  .rr__inner { max-width: 1100px; margin: 0 auto; padding: 0 20px; text-align: center; }
  .rr__kicker { display:inline-block; text-transform:uppercase; letter-spacing:.18em; font-size:.72rem; font-weight:700; color:var(--accent-deep); margin-bottom:14px; }
  .rr__heading { font-family: var(--font-heading); font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 600; color: var(--ink); margin: 0 0 12px; line-height: 1.2; }
  .rr__heading em { font-style: italic; color: var(--accent-deep); }
  .rr__sub { color: var(--ink-2); margin: 0 auto 36px; max-width: 560px; }
  .rr__grid { display: grid; gap: 22px; grid-template-columns: 1fr; text-align: left; }
  @media(min-width: 720px) { .rr__grid { grid-template-columns: repeat(2, 1fr); } }
  @media(min-width: 1000px) { .rr__grid { grid-template-columns: repeat(3, 1fr); max-width: 980px; margin-left: auto; margin-right: auto; } }
  .rr__card { background: var(--cream-soft); border-radius: 14px; overflow: hidden; box-shadow: 0 6px 18px -10px rgba(42,28,18,.15); display: flex; flex-direction: column; }
  .rr__img { width: 100%; aspect-ratio: 1/1; object-fit: cover; display: block; background: #eee; }
  .rr__body { padding: 16px; flex: 1; display: flex; flex-direction: column; }
  .rr__stars { color: var(--accent); letter-spacing: 2px; font-size: .95rem; margin-bottom: 8px; }
  .rr__text { font-size: .92rem; line-height: 1.55; color: var(--ink-2); margin: 0 0 12px; flex: 1; }
  .rr__by { font-size: .82rem; color: var(--muted); margin-top: auto; }
  .rr__by strong { color: var(--ink); font-weight: 600; }
  .rr__verified { display: inline-block; margin-left: 6px; color: var(--sage); font-weight: 600; font-size: .78rem; }
  .rr__cta { display: inline-block; margin-top: 36px; background: var(--accent); color: #fff; padding: 14px 28px; border-radius: 999px; font-weight: 700; text-decoration: none; box-shadow: 0 8px 22px -8px rgba(232,131,58,.55); }
  .rr__cta:hover { background: var(--accent-deep); }
</style>

{% schema %}
{
  "name": "Real reviews",
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Real customers, real reviews" },
    { "type": "text", "id": "heading_lead", "label": "Heading lead", "default": "What pet parents" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent", "default": "actually say." },
    { "type": "text", "id": "subhead", "label": "Subhead", "default": "Verified reviews from FurGone customers — including the honest ones." },
    { "type": "header", "content": "CTA" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Get yours — from $29.99 →" },
    { "type": "url", "id": "cta_url", "label": "Button link" },
    { "type": "header", "content": "Layout" },
    { "type": "color", "id": "bg", "label": "Background" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 }
  ],
  "blocks": [
    { "type": "review", "name": "Review", "settings": [
      { "type": "image_picker", "id": "image", "label": "Customer photo (preferred)" },
      { "type": "text", "id": "image_asset", "label": "Theme asset filename (e.g. glove_review_1.avif)" },
      { "type": "url", "id": "image_url", "label": "Customer photo URL (fallback)" },
      { "type": "range", "id": "rating", "label": "Stars", "min": 1, "max": 5, "step": 1, "default": 5 },
      { "type": "textarea", "id": "review", "label": "Review text", "default": "Honest review goes here." },
      { "type": "text", "id": "name", "label": "Name", "default": "Verified buyer" },
      { "type": "text", "id": "meta", "label": "Meta (e.g. cat mom · 3 weeks ago)" }
    ]}
  ],
  "max_blocks": 8,
  "presets": [{ "name": "Real reviews" }]
}
{% endschema %}
