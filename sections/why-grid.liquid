{%- liquid
  assign grid_open = false
-%}
<section class="container why-grid-section--compact" style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color | default: 'transparent' }};">
  <div class="why-grid-section__inner">
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'kicker' %}
        {% if grid_open %}</div>{% assign grid_open = false %}{% endif %}
        <div class="section-kicker" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
      {% when 'heading' %}
        {% if grid_open %}</div>{% assign grid_open = false %}{% endif %}
        <h2 class="section-title" {{ block.shopify_attributes }}>{{ block.settings.lead }} <em>{{ block.settings.accent }}</em></h2>
      {% when 'subheading' %}
        {% if grid_open %}</div>{% assign grid_open = false %}{% endif %}
        <p class="section-sub" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
      {% when 'card' %}
        {% unless grid_open %}<div class="why-grid">{% assign grid_open = true %}{% endunless %}
        <div class="why-card" {{ block.shopify_attributes }}>
          {% if block.settings.image %}
            <div class="why-card-image"><img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="300" height="300"></div>
          {% elsif block.settings.emoji != blank %}
            <div class="emoji">{{ block.settings.emoji }}</div>
          {% endif %}
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.body }}</p>
        </div>
      {% when 'rich_text' %}
        {% if grid_open %}</div>{% assign grid_open = false %}{% endif %}
        <div class="rich-text-block" {{ block.shopify_attributes }}>{{ block.settings.content }}</div>
      {% when '@app' %}
        {% if grid_open %}</div>{% assign grid_open = false %}{% endif %}
        {% render block %}
    {% endcase %}
  {% endfor %}
  {% if grid_open %}</div>{% endif %}
  </div>
</section>

<style>
  .why-grid-section--compact .why-grid-section__inner { max-width: 720px; margin: 0 auto; padding: 0 20px; background: var(--cream-soft, #fbf6ee); border-radius: 16px; padding: 22px 22px 26px; }
  .why-grid-section--compact .section-kicker { font-size: .68rem; letter-spacing: .14em; margin: 0 0 6px; text-transform: uppercase; color: var(--ink-2); font-weight: 700; text-align: center; }
  .why-grid-section--compact .section-title { font-family: var(--font-heading); font-size: 1.15rem; font-weight: 700; line-height: 1.25; margin: 0 0 4px; text-align: center; color: var(--ink); }
  .why-grid-section--compact .section-title em { font-style: italic; color: var(--accent-deep, var(--ink)); }
  .why-grid-section--compact .section-sub { font-size: .82rem; line-height: 1.45; color: var(--muted); margin: 0 0 14px; text-align: center; }
  .why-grid-section--compact .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin: 0; }
  .why-grid-section--compact .why-card { padding: 10px 8px; background: #fff; border-radius: 10px; box-shadow: 0 1px 3px rgba(0,0,0,.04); display: flex; flex-direction: column; gap: 2px; text-align: center; align-items: center; }
  .why-grid-section--compact .why-card .emoji { font-size: 1.3rem; margin: 0 0 2px; }
  .why-grid-section--compact .why-card-image { display: none; }
  .why-grid-section--compact .why-card h3 { font-size: .82rem; font-weight: 700; margin: 0; line-height: 1.2; color: var(--ink); }
  .why-grid-section--compact .why-card p { font-size: .68rem; line-height: 1.35; color: var(--muted); margin: 2px 0 0; }
  @media (max-width: 600px) {
    .why-grid-section--compact .why-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
    .why-grid-section--compact .section-title { font-size: 1.05rem; }
  }
</style>

{% schema %}
{
  "name": "Why grid",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 32 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 32 },
    { "type": "color", "id": "bg_color", "label": "Background" }
  ],
  "blocks": [
    { "type": "@app" },
    { "type": "kicker", "name": "Kicker", "settings": [ { "type": "text", "id": "text", "label": "Text", "default": "Why pet parents switch" } ] },
    { "type": "heading", "name": "Heading", "settings": [
      { "type": "text", "id": "lead", "label": "Lead", "default": "Four reasons clean-skincare fans" },
      { "type": "text", "id": "accent", "label": "Italic accent", "default": "will never do." }
    ]},
    { "type": "subheading", "name": "Subheading", "settings": [ { "type": "textarea", "id": "text", "label": "Text", "default": "We obsessed over this mitt so you can go back to obsessing over your pet." } ] },
    { "type": "card", "name": "Card", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image (optional)" },
      { "type": "text", "id": "emoji", "label": "Emoji (if no image)", "default": "🪄" },
      { "type": "text", "id": "title", "label": "Title", "default": "Goat milk hydration" },
      { "type": "textarea", "id": "body", "label": "Body", "default": "Lactic acid softens without stripping the skin barrier." }
    ]},
    { "type": "rich_text", "name": "Rich text", "settings": [ { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Add anything here.</p>" } ] }
  ],
  "max_blocks": 20,
  "presets": [{
    "name": "Why grid",
    "blocks": [
      { "type": "kicker" },
      { "type": "heading" },
      { "type": "subheading" },
      { "type": "card", "settings": { "emoji": "🪄", "title": "Goat milk hydration", "body": "Lactic acid softens without stripping the skin barrier." } },
      { "type": "card", "settings": { "emoji": "🐾", "title": "Gentle on pets", "body": "Soft mesh doubles as a calming grooming tool." } },
      { "type": "card", "settings": { "emoji": "🛋️", "title": "Every surface", "body": "Hardwood, rugs, couches, clothes, car seats." } },
      { "type": "card", "settings": { "emoji": "💧", "title": "Rinses in 10s", "body": "Peel the mat off, run it under the tap." } }
    ]
  }]
}
{% endschema %}
