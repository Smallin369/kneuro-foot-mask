{%- liquid
  assign max_width = section.settings.max_width | default: 680
-%}

<section class="sp" style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;background:{{ section.settings.bg | default: 'transparent' }};">
  <div class="sp__inner" style="max-width:{{ max_width }}px;">
    <div class="sp__text">{{ section.settings.text }}</div>
  </div>
</section>

<style>
  .sp__inner { margin: 0 auto; padding: 0 20px; }
  .sp__text { font-family: var(--font-body); font-size: 17px; line-height: 1.65; color: var(--ink); }
  .sp__text p { margin: 0 0 16px; }
  .sp__text p:last-child { margin-bottom: 0; }
  @media (max-width: 600px) { .sp__text { font-size: 16px; } }
</style>

{% schema %}
{
  "name": "Story paragraph",
  "settings": [
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Add your story paragraph here.</p>" },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 480, "max": 1200, "step": 20, "unit": "px", "default": 680 },
    { "type": "color", "id": "bg", "label": "Background" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 12 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 12 }
  ],
  "presets": [{ "name": "Story paragraph" }]
}
{% endschema %}
