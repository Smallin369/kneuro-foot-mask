<section class="section-shell section-dark">
  <div class="page-width section-pad">
    {% if section.settings.eyebrow != blank %}<div class="eyebrow" style="color: rgba(255,235,215,.65);">{{ section.settings.eyebrow }}</div>{% endif %}
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    <div class="ingredients-grid">
      {% for block in section.blocks %}
        <div class="ingredient-row" {{ block.shopify_attributes }}>
          <div style="display: flex; justify-content: space-between; gap: 1rem; align-items: baseline;">
            <h3 style="margin: 0; font: 400 1.45rem/1.15 var(--font-display);">{{ block.settings.title }}</h3>
            <div style="font: 500 11px/1 var(--font-mono); letter-spacing: .16em; text-transform: uppercase; color: rgba(255,235,215,.62);">{{ block.settings.meta }}</div>
          </div>
          <div class="rte" style="color: rgba(255,235,215,.78);">{{ block.settings.text }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ingredients list",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What's actually in it" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Three ingredients doing the work." }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        { "type": "text", "id": "title", "label": "Name", "default": "Goat-milk lactic acid" },
        { "type": "text", "id": "meta", "label": "Meta", "default": "4%" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Ingredient explanation.</p>" }
      ]
    }
  ]
}
{% endschema %}
