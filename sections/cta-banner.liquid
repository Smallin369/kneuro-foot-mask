<section class="section-shell section-dark">
  <div class="page-width section-pad" style="text-align:center;">
    {% if section.settings.eyebrow != blank %}<div class="eyebrow" style="justify-content:center; color: rgba(255,235,215,.62);">{{ section.settings.eyebrow }}</div>{% endif %}
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    <div class="section-subtitle" style="margin-inline:auto; color: rgba(255,235,215,.72);">{{ section.settings.text }}</div>
    {% if section.settings.button_label != blank %}
      <p style="margin-top: 1.5rem;">
        <a class="button-secondary" href="{{ section.settings.button_link | default: '#' }}" style="border-color: var(--color-paper); color: var(--color-paper);">{{ section.settings.button_label }}</a>
      </p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "CTA banner",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "One more thing" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Soft heels. No peeling. No nagging." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "30 minutes. No harsh acids. Backed by a 30-day money-back guarantee." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ]
}
{% endschema %}
