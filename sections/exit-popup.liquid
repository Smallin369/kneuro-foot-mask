{%- liquid
  assign code = section.settings.discount_code | default: 'WELCOME10'
  assign discount_text = section.settings.discount_text | default: '10% off'
-%}

{%- unless customer -%}
<div id="exitPopup" class="ep" hidden role="dialog" aria-modal="true" aria-labelledby="epTitle">
  <div class="ep__backdrop" data-ep-close></div>
  <div class="ep__card" role="document">
    <button class="ep__x" type="button" aria-label="Close" data-ep-close>×</button>

    <div class="ep__view ep__view--offer" data-ep-view="offer">
      <div class="ep__eyebrow">{{ section.settings.eyebrow | default: 'Wait — before you go' }}</div>
      <h2 id="epTitle" class="ep__title">{{ section.settings.headline | default: 'Get your first pack at <em>10% off</em>' }}</h2>
      <p class="ep__sub">{{ section.settings.sub | default: 'Drop your email and we will send the code. No spam, just one welcome note and the discount.' }}</p>

      <form class="ep__form" data-ep-form action="/contact#contact_form" method="post" accept-charset="UTF-8">
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="contact[tags]" value="newsletter,exit-popup">
        <input type="hidden" name="contact[accepts_marketing]" value="1">
        <label class="visually-hidden" for="epEmail">Email</label>
        <input id="epEmail" class="ep__input" type="email" name="contact[email]" placeholder="you@email.com" required autocomplete="email">
        <button class="ep__btn" type="submit">Get my {{ discount_text }}</button>
      </form>

      <p class="ep__fine">By continuing you agree to receive marketing emails. Unsubscribe anytime.</p>
    </div>

    <div class="ep__view ep__view--code" data-ep-view="code" hidden>
      <div class="ep__check" aria-hidden="true">✓</div>
      <h2 class="ep__title">Your code is <em>ready</em></h2>
      <p class="ep__sub">Use this at checkout for {{ discount_text }} off your first order.</p>
      <button class="ep__code" type="button" data-ep-copy data-code="{{ code }}">
        <span class="ep__code-label">{{ code }}</span>
        <span class="ep__code-copy">Tap to copy</span>
      </button>
      <a class="ep__btn ep__btn--ghost" href="/products/goat-milk-callus-mask" data-ep-close>Shop the foot mask →</a>
    </div>
  </div>
</div>

<style>
  .ep { position: fixed; inset: 0; z-index: 9998; display: flex; align-items: center; justify-content: center; padding: 20px; }
  .ep[hidden] { display: none; }
  .ep__backdrop { position: absolute; inset: 0; background: rgba(10, 8, 6, 0.72); backdrop-filter: blur(2px); animation: epFadeIn .25s ease forwards; }
  .ep__card { position: relative; background: var(--surface, #fff); border-radius: 22px; max-width: 460px; width: 100%; padding: 36px 28px 28px; box-shadow: 0 30px 80px rgba(0,0,0,0.35); animation: epSlideUp .35s cubic-bezier(.2,.9,.3,1) forwards; }
  .ep__x { position: absolute; top: 10px; right: 14px; background: transparent; border: 0; font-size: 26px; line-height: 1; cursor: pointer; color: var(--muted, #888); padding: 6px 10px; }
  .ep__x:hover { color: var(--ink, #000); }
  .ep__eyebrow { display: inline-block; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--muted, #888); padding: 6px 12px; border: 1px solid var(--line, #eee); border-radius: 999px; margin-bottom: 14px; }
  .ep__title { margin: 0 0 8px; font-family: var(--font-heading); font-size: 26px; line-height: 1.18; color: var(--ink, #0a0a0a); }
  .ep__title em { font-style: italic; font-weight: 700; color: var(--accent, #0a0a0a); }
  .ep__sub { margin: 0 0 18px; font-size: 14px; line-height: 1.55; color: var(--ink-2, #2a2a2a); }
  .ep__form { display: flex; flex-direction: column; gap: 10px; }
  .ep__input { padding: 14px 16px; border: 1.5px solid var(--line, #eee); border-radius: 12px; font-size: 15px; font-family: var(--font-body); outline: none; transition: border-color .15s ease; }
  .ep__input:focus { border-color: var(--accent, #0a0a0a); }
  .ep__btn { padding: 16px 20px; background: var(--accent, #0a0a0a); color: #fff; border: 0; border-radius: 12px; font-size: 15px; font-weight: 600; cursor: pointer; font-family: var(--font-body); transition: transform .12s ease, opacity .12s ease; }
  .ep__btn:hover { transform: translateY(-1px); }
  .ep__btn:disabled { opacity: .5; cursor: wait; }
  .ep__btn--ghost { background: transparent; color: var(--accent, #0a0a0a); border: 1.5px solid var(--accent, #0a0a0a); margin-top: 14px; text-align: center; text-decoration: none; display: block; }
  .ep__fine { margin: 14px 0 0; font-size: 11px; line-height: 1.5; color: var(--muted, #999); }
  .ep__check { width: 56px; height: 56px; border-radius: 50%; background: #d6efd9; color: #1f6c2f; display: grid; place-items: center; font-size: 28px; margin: 0 auto 16px; }
  .ep__view--code { text-align: center; }
  .ep__code { display: block; width: 100%; margin: 18px 0 6px; padding: 18px; background: var(--cream, #f7f4f0); border: 2px dashed var(--accent, #0a0a0a); border-radius: 14px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 22px; font-weight: 700; letter-spacing: .12em; cursor: pointer; transition: background .15s ease; }
  .ep__code:hover { background: #efe9e0; }
  .ep__code-label { display: block; }
  .ep__code-copy { display: block; font-size: 11px; font-weight: 500; letter-spacing: .14em; text-transform: uppercase; color: var(--muted, #888); margin-top: 6px; font-family: var(--font-body); }
  .visually-hidden { position: absolute !important; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
  @keyframes epFadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes epSlideUp { from { opacity: 0; transform: translateY(20px) scale(.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
  @media (max-width: 480px) {
    .ep__card { padding: 30px 22px 22px; border-radius: 18px; }
    .ep__title { font-size: 22px; }
  }
</style>

<script>
(function() {
  var KEY = 'ep_seen_v1';
  var DELAY = {{ section.settings.mobile_delay_seconds | default: 25 | times: 1000 }};
  if (sessionStorage.getItem(KEY)) return;

  var el = document.getElementById('exitPopup');
  if (!el) return;

  var shown = false;
  function show() {
    if (shown) return; shown = true;
    sessionStorage.setItem(KEY, '1');
    el.hidden = false;
    document.body.style.overflow = 'hidden';
  }
  function hide() {
    el.hidden = true;
    document.body.style.overflow = '';
  }

  // Desktop: trigger on mouse leaving top of viewport
  document.addEventListener('mouseout', function(e) {
    if (e.clientY <= 0 && !e.relatedTarget) show();
  });
  // Mobile: trigger after delay + any scroll-up gesture
  var mobile = matchMedia('(max-width: 768px)').matches;
  if (mobile) {
    var lastY = window.scrollY;
    var armed = false;
    setTimeout(function() { armed = true; }, DELAY);
    window.addEventListener('scroll', function() {
      if (armed && window.scrollY < lastY - 30 && window.scrollY > 100) show();
      lastY = window.scrollY;
    }, { passive: true });
  }

  el.addEventListener('click', function(e) {
    if (e.target.matches('[data-ep-close]')) hide();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !el.hidden) hide();
  });

  // Form: AJAX submit to Shopify newsletter, then reveal code
  var form = el.querySelector('[data-ep-form]');
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var btn = form.querySelector('button[type="submit"]');
      btn.disabled = true; btn.textContent = 'Saving…';
      var fd = new FormData(form);
      fetch('/contact', { method: 'POST', body: fd, headers: { Accept: 'application/json' } })
        .then(function() {
          el.querySelector('[data-ep-view="offer"]').hidden = true;
          el.querySelector('[data-ep-view="code"]').hidden = false;
        })
        .catch(function() {
          // Even on fail (CSRF, etc), show the code — capture is bonus
          el.querySelector('[data-ep-view="offer"]').hidden = true;
          el.querySelector('[data-ep-view="code"]').hidden = false;
        });
    });
  }

  // Copy-on-tap for code
  var codeBtn = el.querySelector('[data-ep-copy]');
  if (codeBtn) {
    codeBtn.addEventListener('click', function() {
      var c = codeBtn.getAttribute('data-code');
      if (navigator.clipboard) navigator.clipboard.writeText(c).catch(function(){});
      var label = codeBtn.querySelector('.ep__code-copy');
      if (label) { label.textContent = 'Copied!'; setTimeout(function() { label.textContent = 'Tap to copy'; }, 1800); }
    });
  }
})();
</script>
{%- endunless -%}

{% schema %}
{
  "name": "Exit-intent popup",
  "settings": [
    { "type": "header", "content": "Offer" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Wait — before you go" },
    { "type": "text", "id": "headline", "label": "Headline (HTML allowed)", "default": "Get your first pack at <em>10% off</em>" },
    { "type": "textarea", "id": "sub", "label": "Subhead", "default": "Drop your email and we'll send the code. No spam, just one welcome note and the discount." },
    { "type": "text", "id": "discount_code", "label": "Discount code", "default": "WELCOME10", "info": "Create this code in Shopify Admin → Discounts. Make it free shipping or 10% off, no minimum." },
    { "type": "text", "id": "discount_text", "label": "Discount short label", "default": "10% off" },
    { "type": "header", "content": "Behavior" },
    { "type": "range", "id": "mobile_delay_seconds", "label": "Mobile trigger delay", "min": 10, "max": 90, "step": 5, "default": 25, "unit": "s", "info": "Mobile popup arms after this many seconds, then fires on next scroll-up." }
  ],
  "presets": [{ "name": "Exit-intent popup" }]
}
{% endschema %}
